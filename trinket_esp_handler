-- Cache de funções globais (evita lookup na tabela global a cada chamada)
local type          = type
local tostring      = tostring
local pairs         = pairs
local pcall         = pcall
local setmetatable  = setmetatable
local ipairs        = ipairs
local tableInsert   = table.insert
local tableRemove   = table.remove

-- Destrói uma Instance sem lançar erro (usado em cleanup)
local function safeDestroy(obj)
    if obj == nil then return end
    pcall(obj.Destroy, obj)
end

-- Baixa e executa um módulo remoto
local function safeRequireRemote(url, name)
    local tag = "[trinket_esp_handler]"

    local dlOk, raw = pcall(game.HttpGet, game, url)
    if not dlOk or type(raw) ~= "string" or raw == "" then
        warn(tag, "Download falhou:", name, tostring(raw))
        return nil
    end

    local fn, compErr = loadstring(raw)
    if type(fn) ~= "function" then
        warn(tag, "Compilação falhou:", name, tostring(compErr))
        return nil
    end

    local execOk, mod = pcall(fn)
    if not execOk then
        warn(tag, "Execução falhou:", name, tostring(mod))
        return nil
    end

    return mod
end

