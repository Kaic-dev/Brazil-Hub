local trinketCache = {}
local function isTrinket(obj)
    local objType = obj.ClassName
    if trinketCache[obj] ~= nil then
        return trinketCache[obj]
    end
    if objType ~= "Part" and objType ~= "MeshPart" then
        trinketCache[obj] = false
        return false
    end
    local hasID = obj:FindFirstChild("ID") ~= nil
    trinketCache[obj] = hasID
    return hasID
end

local function identifyByParticles(part)
    local hasOrb, hasLight, hasSphere = false, false, false

    for _, child in ipairs(part:GetDescendants()) do
        if child.ClassName == "ParticleEmitter" then
            local tex = cleanTextureId(child.Texture)
            if child.Name == "OrbParticle" then
                hasOrb = true
            elseif tex == TEXTURE_IDOL_OF_WAR then
                return "Idol of War"
            elseif tex == TEXTURE_ICE_ESSENCE then
                return "Ice Essence"
            elseif tex == TEXTURE_PHOENIX then
                local cs = child.Color
                if cs and cs.Keypoints and #cs.Keypoints >= 2 then
                    local k1 = cs.Keypoints[1]
                    if k1.Value == Config.ColorSequences.PhoenixDown[1].Value then
                        return "Phoenix Down"
                    elseif k1.Value == Config.ColorSequences.AzaelHorn[1].Value then
                        return "Azael Horn"
                    elseif k1.Value == Config.ColorSequences.MysteriousArtifact[1].Value then
                        return "Mysterious Artifact"
                    elseif k1.Value == Config.ColorSequences.PhoenixFlower[1].Value then
                        return "Phoenix Flower"
                    end
                end
            end
        elseif child.ClassName == "PointLight" then
            hasLight = true
        elseif child.ClassName == "SpecialMesh" and child.MeshType == Config.MeshTypes.Sphere then
            hasSphere = true
        end
    end

    if hasOrb and hasLight and hasSphere then
        return "???"
    end

    return nil
end

local function getTrinketInfo(part)
    local particleIdentity = identifyByParticles(part)
    if particleIdentity then
        return particleIdentity
    end

    local meshId
    if part:IsA("MeshPart") then
        meshId = part.MeshId
    else
        local mesh = part:FindFirstChildWhichIsA("SpecialMesh") or part:FindFirstChildWhichIsA("Mesh")
        meshId = mesh and mesh.MeshId
    end

    if meshId and meshId ~= "" then
        local cleanId = cleanMeshId(meshId)
        local trinketData = Config.MeshIDs[cleanId]

        if cleanId == "2877143560" or cleanId == "2877143592" or cleanId == "2877143624" then
            local brickColor = part.BrickColor
            local colorName = brickColor.Name
            local colorValue = brickColor.Color

            if colorName == "Really red" or colorName == "Bright red" or (colorValue.R > 0.7 and colorValue.G < 0.3 and colorValue.B < 0.3) then
                return "Ruby"
            elseif colorName == "Bright blue" or colorName == "Cyan" or colorName == "Lapis" or (colorValue.R < 0.3 and colorValue.G < 0.3 and colorValue.B > 0.7) then
                return "Sapphire"
            elseif colorName == "Bright green" or colorName == "Forest green" or colorName == "Lime green" or (colorValue.R < 0.3 and colorValue.G > 0.7 and colorValue.B < 0.3) then
                return "Emerald"
            elseif colorName == "White" or colorName == "Institutional white" or (colorValue.R > 0.8 and colorValue.G > 0.8 and colorValue.B > 0.8) then
                return "Diamond"
            else
                return "Rift Gem"
            end
        end

        if trinketData then
            return trinketData.name
        end
    end

    local material = part.Material

    if material == Config.Materials.Slate then
        return "Idol of the Forgotten"
    end

    if material == Config.Materials.Glass and part:FindFirstChildOfClass("SpecialMesh") then
        return "Opal"
    end

    if material == Config.Materials.Neon then
        if part.BrickColor == BrickColor.new("Gold") or part.BrickColor.Name == "New Yeller" then
            return "Lost Sunshine"
        end
        return part:FindFirstChildOfClass("PointLight") and "Amulet of the White King" or "Nightstone"
    end

    return "Unknown"
end

local TrinketESP = {}
