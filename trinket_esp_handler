    distLabel.BackgroundTransparency = 1
    distLabel.Size = UDim2_new(1, 0, 0, 12)
    distLabel.AutomaticSize = Enum.AutomaticSize.None
    distLabel.TextXAlignment = Enum.TextXAlignment.Center
    distLabel.Parent = root

    -- Linha de ancoragem
    local anchorLine = Instance_new("Frame")
    anchorLine.Name = "AnchorLine"
