local function safeRequireRemote(url, name)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    if not success then
        warn("[trinket_esp_handler] Failed to download module:", name or url, tostring(result))
        return nil
    end

    local moduleFunc, err = loadstring(result)
    if not moduleFunc then
        warn("[trinket_esp_handler] Failed to compile module:", name or url, tostring(err))
        return nil
    end

    local ok, module = pcall(moduleFunc)
    if not ok then
        warn("[trinket_esp_handler] Failed to execute module:", name or url, tostring(module))
        return nil
    end

    return module
end

