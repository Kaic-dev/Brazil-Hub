do
    local _rawCM = safeRequireRemote(
        "https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/main/ConnectionManager",
        "ConnectionManager"
    )
    if type_(_rawCM) == "table" and type_(_rawCM.new) == "function" then
        _fallbackCM = _rawCM
    end
end

