local function getLocalRootPart()
    local player = Players.LocalPlayer
    if not player then return nil end
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function formatDistance(dist)
    if dist >= 1000 then
        return string.format("%.1fkm", dist / 1000)
    end
    return string.format("%dm", mathFloor(dist))
end

--------------------------------------------------------------------------------
-- IDENTIFICAÇÃO
-- FIX [1]: isTrinket usa pcall no acesso a ClassName para não explodir
--          caso o objeto seja destruído exatamente antes de ser lido.
-- FIX [3]: scanLevel virou função local flat (sem closure recriada a cada
--          chamada), eliminando alocação por trinket processado.
--------------------------------------------------------------------------------

-- FIX [3]: estado de scan exposto como upvalues do módulo e resetado antes
-- de cada chamada a identifyByParticles, evitando closure recriada.
local _scanOrb    = false
local _scanLight  = false
local _scanSphere = false

local function scanLevel(container)
    -- Lê filhos diretos; desce em Attachments (onde partículas vivem)
    local ok, children = pcall_(container.GetChildren, container)
    if not ok or type_(children) ~= "table" then return nil end

    for i = 1, #children do
        local child = children[i]
        local cnOk, cn = pcall_(function() return child.ClassName end)
        if not cnOk then continue end   -- objeto destruído durante iteração

        if cn == "ParticleEmitter" then
            local nameOk, childName = pcall_(function() return child.Name end)
            if nameOk and childName == "OrbParticle" then
                _scanOrb = true
            else
                local texOk, tex = pcall_(function() return tostring_(child.Texture) end)
                if texOk then
                    if tex == ICE_TEXTURE then
                        return "Ice Essence"
                    elseif tex == PHOENIX_TEXTURE then
                        local csOk, cs = pcall_(function() return child.Color end)
                        if csOk and cs then
                            local kpsOk, kps = pcall_(function() return cs.Keypoints end)
                            if kpsOk and kps and #kps >= 2 then
                                local kval = kps[1].Value
                                if kval == PARTICLE_KEYS.PhoenixDown then
                                    return "Phoenix Down"
                                elseif kval == PARTICLE_KEYS.AzaelHorn then
                                    return "Azael Horn"
                                elseif kval == PARTICLE_KEYS.MysteriousArtifact then
                                    return "Mysterious Artifact"
                                elseif kval == PARTICLE_KEYS.PhoenixFlower then
                                    return "Phoenix Flower"
                                end
                            end
                        end
                    end
                end
            end

        elseif cn == "PointLight" then
            _scanLight = true

        elseif cn == "SpecialMesh" then
            local mtOk, mt = pcall_(function() return child.MeshType end)
            if mtOk and mt == MESH_SPHERE then
                _scanSphere = true
            end

        elseif cn == "Attachment" then
            local res = scanLevel(child)
            if res then return res end
        end
    end

    return nil
end

local function identifyByParticles(part)
    -- Reseta estado do scan (FIX [3]: sem closure, estado compartilhado)
    _scanOrb    = false
    _scanLight  = false
    _scanSphere = false

    local result = scanLevel(part)
    if result then return result end

    if _scanOrb and _scanLight and _scanSphere then
        return "???"
    end

    return nil
end

-- FIX [2]: identifyGem isola todos os acessos em pcall
local function identifyGem(part)
    local ok, r, g, b, name = pcall_(function()
        local cv = part.BrickColor.Color
        return cv.R, cv.G, cv.B, part.BrickColor.Name
    end)

    if not ok then return "Rift Gem" end

    if name == "Really red" or name == "Bright red" or (r > 0.7 and g < 0.3 and b < 0.3) then
        return "Ruby"
    elseif name == "Bright blue" or name == "Cyan" or name == "Lapis" or (r < 0.3 and g < 0.3 and b > 0.7) then
        return "Sapphire"
    elseif name == "Bright green" or name == "Forest green" or name == "Lime green" or (r < 0.3 and g > 0.7 and b < 0.3) then
        return "Emerald"
    elseif name == "White" or name == "Institutional white" or (r > 0.8 and g > 0.8 and b > 0.8) then
        return "Diamond"
    end

    return "Rift Gem"
end

local function cleanMeshId(id)
    return tostring_(id):gsub("%%20", ""):gsub("%s+", ""):gsub("rbxassetid://", "")
end

-- FIX [1]: isTrinket usa pcall no acesso a ClassName
local function isTrinket(obj, cache)
    local cached = cache[obj]
    if cached ~= nil then return cached end

    -- ClassName pode explodir se obj foi destruído antes de chegar aqui
    local cnOk, cn = pcall_(function() return obj.ClassName end)
    if not cnOk or (cn ~= "Part" and cn ~= "MeshPart") then
        cache[obj] = false
        return false
    end

    local idOk, child = pcall_(obj.FindFirstChild, obj, "ID")
    local result = idOk and child ~= nil
    cache[obj] = result
    return result
end

local function getTrinketInfo(part)
    -- 1. Partículas
    local byParticle = identifyByParticles(part)
    if byParticle then return byParticle end

    -- 2. MeshID
    local meshId = ""
    pcall_(function()
        if part:IsA("MeshPart") then
            meshId = part.MeshId or ""
        else
            local mesh = part:FindFirstChildWhichIsA("SpecialMesh")
                      or part:FindFirstChildWhichIsA("Mesh")
            if mesh then meshId = mesh.MeshId or "" end
        end
    end)

    if meshId ~= "" then
        local cleanId = cleanMeshId(meshId)

        if GEM_IDS[cleanId] then
            return identifyGem(part)
        end

        local known = MESH_IDS[cleanId]
        if known then return known end
    end

    -- 3. Material (acessos diretos: estamos dentro de pcall no _runQueue)
    local mat = part.Material

    if mat == MAT_SLATE then return "Idol of the Forgotten" end

    if mat == MAT_GLASS and part:FindFirstChildOfClass("SpecialMesh") then
        return "Opal"
    end

    if mat == MAT_NEON then
        local bcName = part.BrickColor.Name
        if bcName == "Gold" or bcName == "New Yeller" then
            return "Lost Sunshine"
        end
        if part:FindFirstChildOfClass("PointLight") then
            return "Amulet of the White King"
        end
        return "Nightstone"
    end

    return "Unknown"
end

