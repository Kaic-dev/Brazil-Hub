local TrinketESP   = {}
TrinketESP.__index = TrinketESP

function TrinketESP.new()
    local cm
    local ok = pcall_(function() cm = ConnectionManager.new() end)
    if not ok or type_(cm) ~= "table" then
        cm = _fallbackCM.new()
    end

    -- Copia profunda do DEFAULT_CONFIG para cada instância
    local cfg = {}
    for k, v in pairs_(DEFAULT_CONFIG) do
        if type_(v) == "table" then
            local t = {}
            for i, e in pairs_(v) do t[i] = e end
            cfg[k] = t
        else
            cfg[k] = v
        end
    end

    return setmetatable_({
        espBillboards      = {},
        _connectionManager = cm,
        _cfg               = cfg,
        enabled            = false,

        _queue             = {},
        _queueHead         = 1,
        _queueRunning      = false,

        _trinketCache      = setmetatable_({}, { __mode = "k" }),
        _processedObjects  = setmetatable_({}, { __mode = "k" }),
        _pendingConns      = setmetatable_({}, { __mode = "k" }),

        _heartbeatConn     = nil,
    }, TrinketESP)
end

--------------------------------------------------------------------------------
-- CONFIGURAÇÃO PÚBLICA
--------------------------------------------------------------------------------

-- Retorna cópia da configuração atual
function TrinketESP:getConfig()
    local copy = {}
    for k, v in pairs_(self._cfg) do
        if type_(v) == "table" then
            local t = {}
            for i, e in pairs_(v) do t[i] = e end
            copy[k] = t
        else
            copy[k] = v
        end
    end
    return copy
end

-- Aplica campos de `newCfg` (parcial ou completo) e propaga imediatamente
function TrinketESP:setConfig(newCfg)
    if type_(newCfg) ~= "table" then return end

    for k, v in pairs_(newCfg) do
        if k == "filterList" and type_(v) == "table" then
            -- cópia da lista
            local t = {}
            for i, e in pairs_(v) do t[i] = e end
            self._cfg.filterList = t
        elseif DEFAULT_CONFIG[k] ~= nil then
            self._cfg[k] = v
        end
    end

    -- Propaga imediatamente para todos os billboards existentes
    self:_applyConfigToAll()

    -- Filtragem: remove billboards de trinkets que agora estão filtrados
    -- e re-enfileira objetos pendentes que agora passam no filtro.
    -- Para simplicidade: força rescan (disable+enable mantém estado de processos).
    -- Apenas re-aplica visibilidade e campo — não força rescan completo.
end

-- [A] Força um nome de trinket contra o filtro configurado.
-- Retorna true se deve ser exibido.
function TrinketESP:_passesFilter(trinketName)
    local mode = self._cfg.filterMode
    if mode == "none" or mode == nil then return true end

    local list = self._cfg.filterList
    local found = false
    for _, n in pairs_(list) do
        if n == trinketName then
            found = true
            break
        end
    end

    if mode == "whitelist" then return found end
    if mode == "blacklist" then return not found end
    return true
end

--------------------------------------------------------------------------------
-- PROPAGAÇÃO DE CONFIG PARA BILLBOARDS EXISTENTES
--------------------------------------------------------------------------------

function TrinketESP:_applyConfigToBillboard(trinket, refs)
    if not refs or not refs.billboard then return end
    local bb = refs.billboard
    pcall_(function()
        bb.AlwaysOnTop  = self._cfg.alwaysOnTop
        bb.StudsOffset  = Vector3.new(0, self._cfg.studOffset, 0)
    end)

    local root      = bb:FindFirstChild("Root")
    if not root then return end

    local pill      = root:FindFirstChild("Pill")
    local distLabel = root:FindFirstChild("DistLabel")
    local anchorLine= root:FindFirstChild("AnchorLine")

    if pill then
        pcall_(function()
            pill.BackgroundTransparency = self._cfg.pillTransparency
        end)
        local dot       = pill:FindFirstChild("Dot")
        local nameLabel = pill:FindFirstChild("NameLabel")
        if dot then
            pcall_(function() dot.Visible = self._cfg.showDot end)
        end
        if nameLabel then
            pcall_(function()
                nameLabel.Visible  = self._cfg.showName
                nameLabel.TextSize = self._cfg.textSize
            end)
        end
    end

    if distLabel then
        pcall_(function()
            distLabel.Visible  = self._cfg.showDistance
            distLabel.TextSize = self._cfg.distTextSize
        end)
    end

    if anchorLine then
        pcall_(function() anchorLine.Visible = self._cfg.showLine end)
    end
end

function TrinketESP:_applyConfigToAll()
    for trinket, refs in pairs_(self.espBillboards) do
        self:_applyConfigToBillboard(trinket, refs)
    end
end

