--------------------------------------------------------------------------------
-- CACHE DE TRINKETS
-- Usa weak keys: objetos destruídos são coletados automaticamente pelo GC,
-- eliminando o vazamento de memória da versão anterior.
--------------------------------------------------------------------------------

local trinketCache = setmetatable({}, { __mode = "k" })

--------------------------------------------------------------------------------
-- IDENTIFICAÇÃO
--------------------------------------------------------------------------------

--- Retorna true se o objeto é um trinket (Part/MeshPart com filho "ID").
--- Hot path: acesso direto, sem pcall.
local function isTrinket(obj)
    -- Weak-cache hit
    local cached = trinketCache[obj]
    if cached ~= nil then return cached end

    local cn = obj.ClassName
    if cn ~= "Part" and cn ~= "MeshPart" then
        trinketCache[obj] = false
        return false
    end

    local result = obj:FindFirstChild("ID") ~= nil
    trinketCache[obj] = result
    return result
end

--- Identifica gema por BrickColor quando os MeshIDs são compartilhados.
local function identifyGem(part)
    local cv = part.BrickColor.Color
    local r, g, b = cv.R, cv.G, cv.B
    local name = part.BrickColor.Name

    if name == "Really red" or name == "Bright red" or (r > 0.7 and g < 0.3 and b < 0.3) then
        return "Ruby"
    elseif name == "Bright blue" or name == "Cyan" or name == "Lapis" or (r < 0.3 and g < 0.3 and b > 0.7) then
        return "Sapphire"
    elseif name == "Bright green" or name == "Forest green" or name == "Lime green" or (r < 0.3 and g > 0.7 and b < 0.3) then
        return "Emerald"
    elseif name == "White" or name == "Institutional white" or (r > 0.8 and g > 0.8 and b > 0.8) then
        return "Diamond"
    end

    return "Rift Gem"
end

--- Varre partículas para identificar trinkets especiais.
--- Usa GetChildren em cada nível em vez de GetDescendants (menos alocações).
local function identifyByParticles(part)
    local hasOrb    = false
    local hasLight  = false
    local hasSphere = false

    -- Itera direto os filhos do part e de cada Attachment
    local function scanLevel(container)
        for _, child in ipairs(container:GetChildren()) do
            local cn = child.ClassName

            if cn == "ParticleEmitter" then
                if child.Name == "OrbParticle" then
                    hasOrb = true
                elseif tostring(child.Texture) == PHOENIX_TEXTURE then
                    local cs = child.Color
                    if cs then
                        local kps = cs.Keypoints
                        if kps and #kps >= 2 then
                            local kval = kps[1].Value
                            if kval == PARTICLE_KEYS.PhoenixDown then
                                return "Phoenix Down"
                            elseif kval == PARTICLE_KEYS.AzaelHorn then
                                return "Azael Horn"
                            elseif kval == PARTICLE_KEYS.MysteriousArtifact then
                                return "Mysterious Artifact"
                            elseif kval == PARTICLE_KEYS.PhoenixFlower then
                                return "Phoenix Flower"
                            end
                        end
                    end
                end

            elseif cn == "PointLight" then
                hasLight = true

            elseif cn == "SpecialMesh" and child.MeshType == MESH_SPHERE then
                hasSphere = true

            elseif cn == "Attachment" then
                -- Desce um nível (partículas dentro de Attachments)
                local res = scanLevel(child)
                if res then return res end
            end
        end

        return nil
    end

    local result = scanLevel(part)
    if result then return result end

    if hasOrb and hasLight and hasSphere then
        return "???"
    end

    return nil
end

--- Limpa e normaliza um MeshId.
local function cleanMeshId(id)
    return tostring(id):gsub("%%20", ""):gsub("%s+", ""):gsub("rbxassetid://", "")
end

--- Retorna o nome do trinket. Nunca lança erro (chamado dentro de pcall).
local function getTrinketInfo(part)
    -- 1. Partículas
    local byParticle = identifyByParticles(part)
    if byParticle then return byParticle end

    -- 2. MeshID
    local meshId = ""
    if part:IsA("MeshPart") then
        meshId = part.MeshId
    else
        local mesh = part:FindFirstChildWhichIsA("SpecialMesh")
                  or part:FindFirstChildWhichIsA("Mesh")
        if mesh then meshId = mesh.MeshId end
    end

    if meshId ~= "" then
        local cleanId = cleanMeshId(meshId)

        if GEM_IDS[cleanId] then
            return identifyGem(part)
        end

        local known = MESH_IDS[cleanId]
        if known then return known end
    end

    -- 3. Material
    local mat = part.Material

    if mat == MAT_SLATE then
        return "Idol of the Forgotten"
    end

    if mat == MAT_GLASS and part:FindFirstChildOfClass("SpecialMesh") then
        return "Opal"
    end

    if mat == MAT_NEON then
        local bcName = part.BrickColor.Name
        if bcName == "Gold" or bcName == "New Yeller" then
            return "Lost Sunshine"
        end
        if part:FindFirstChildOfClass("PointLight") then
            return "Amulet of the White King"
        end
        return "Nightstone"
    end

    return "Unknown"
end

--------------------------------------------------------------------------------
-- CLASSE TrinketESP
--------------------------------------------------------------------------------

local TrinketESP   = {}
TrinketESP.__index = TrinketESP

function TrinketESP.new()
    local cm
    local ok = pcall(function() cm = ConnectionManager.new() end)
    if not ok or type(cm) ~= "table" then
        cm = _fallbackCM.new()
    end

    return setmetatable({
        espBillboards      = {},
        _connectionManager = cm,
        enabled            = false,

        -- Fila implementada com head pointer:
        -- _queue[_head] até _queue[#_queue] são os pendentes.
        -- Evita O(n) do table.remove(t, 1).
        _queue     = {},
        _queueHead = 1,
        _queueRunning = false,

        _processedObjects = setmetatable({}, { __mode = "k" }), -- weak keys
    }, TrinketESP)
end

--- Cria o BillboardGui no trinket.
function TrinketESP:createBillboard(trinket, trinketName)
    if self.espBillboards[trinket] then return end
    if trinket.Parent == nil then return end -- objeto já foi destruído

    local name      = type(trinketName) == "string" and trinketName or "Unknown"
    local color     = COLOR_TRINKETS[name] or COLOR_DEFAULT

    local billboard = Instance.new("BillboardGui")
    billboard.Name           = "TrinketESP"
    billboard.Adornee        = trinket
    billboard.LightInfluence = 1
    billboard.ZIndexBehavior = Config.UI.ZIndexBehavior
    billboard.AlwaysOnTop    = true
    billboard.Size           = Config.ESP.BillboardSize

    local label = Instance.new("TextLabel", billboard)
    label.Text                   = name
    label.TextColor3             = color
    label.TextStrokeTransparency = Config.ESP.TextStrokeTransparency
    label.TextStrokeColor3       = Config.ESP.TextStrokeColor
    label.Font                   = Config.ESP.Font
    label.TextSize               = Config.ESP.TextSize
    label.BackgroundTransparency = 1
    label.BorderSizePixel        = 0
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.Position               = UDim2.new(0.5, 0, 0.5, 0)
    label.AnchorPoint            = Vector2.new(0.5, 0.5)

    -- Parenteia o billboard por último para evitar renders parciais
    billboard.Parent = trinket

    self.espBillboards[trinket] = billboard
end

--- Remove o BillboardGui de um trinket.
function TrinketESP:removeBillboard(trinket)
    local bb = self.espBillboards[trinket]
    if bb then
        safeDestroy(bb)
        self.espBillboards[trinket] = nil
    end
    trinketCache[trinket]             = nil
    self._processedObjects[trinket]   = nil
end

--- Processa a fila de trinkets pendentes em lotes.
function TrinketESP:_runQueue()
    if self._queueRunning then return end
    self._queueRunning = true

    task.spawn(function()
        local q    = self._queue
        local max  = Config.ESP.MaxProcessPerFrame

        while self.enabled do
            -- Verifica se há itens não processados
            if self._queueHead > #q then
                break
            end

            local processed = 0

            while self._queueHead <= #q and processed < max do
                local trinket = q[self._queueHead]
                q[self._queueHead] = nil  -- libera referência imediatamente
                self._queueHead = self._queueHead + 1
                processed = processed + 1

                if trinket ~= nil
                and not self._processedObjects[trinket]
                and trinket.Parent ~= nil then
                    self._processedObjects[trinket] = true

                    -- getTrinketInfo e createBillboard isolados:
                    -- um trinket bugado não para toda a fila
                    local name = "Unknown"
                    local infoOk = pcall(function()
                        name = getTrinketInfo(trinket)
                    end)

                    if infoOk then
                        pcall(function()
                            self:createBillboard(trinket, name)
                        end)
                    end
                end
            end

            -- Compacta a fila periodicamente para evitar crescimento ilimitado
            if self._queueHead > 500 then
                local newQ = {}
                for i = self._queueHead, #q do
                    newQ[#newQ + 1] = q[i]
                end
                self._queue     = newQ
                self._queueHead = 1
                q = self._queue
            end

            -- Aguarda próximo frame se ainda há pendentes
            if self._queueHead <= #q and self.enabled then
                RunService.Heartbeat:Wait()
            else
                break
            end
        end

        self._queueRunning = false
    end)
end

--- Enfileira um trinket para processamento.
function TrinketESP:_enqueue(obj)
    self._queue[#self._queue + 1] = obj
    if not self._queueRunning then
        self:_runQueue()
    end
end

--- Callback: filho adicionado ao Workspace.
function TrinketESP:onChildAdded(obj)
    if not self.enabled then return end
    if not isTrinket(obj) then return end
    if self._processedObjects[obj] then return end
    self:_enqueue(obj)
end

--- Callback: filho removido do Workspace.
function TrinketESP:onChildRemoved(obj)
    if not self.enabled then return end
    if self.espBillboards[obj] == nil then return end
    self:removeBillboard(obj)
end

--- Varre os filhos existentes do Workspace.
function TrinketESP:scanExistingTrinkets()
    local children = Workspace:GetChildren()
    for i = 1, #children do
        local obj = children[i]
        if isTrinket(obj) and not self._processedObjects[obj] then
            self._queue[#self._queue + 1] = obj
        end
    end

    if #self._queue >= self._queueHead then
        self:_runQueue()
    end
end

--- Ativa o ESP.
function TrinketESP:enable()
    if self.enabled then return end
    self.enabled = true

    self:scanExistingTrinkets()

    -- pcall nas conexões pois dependem do ConnectionManager externo
    pcall(function()
        self._connectionManager:add(
            Workspace.ChildAdded:Connect(function(obj)
                self:onChildAdded(obj)
            end),
            "Workspace.ChildAdded"
        )
    end)

    pcall(function()
        self._connectionManager:add(
            Workspace.ChildRemoved:Connect(function(obj)
                self:onChildRemoved(obj)
            end),
            "Workspace.ChildRemoved"
        )
    end)
end

--- Desativa o ESP e remove todos os billboards.
function TrinketESP:disable()
    self.enabled = false

    pcall(function() self._connectionManager:disconnectAll() end)

    -- Coleta chaves antes de iterar (evita mutação durante loop)
    local keys = {}
    for trinket in pairs(self.espBillboards) do
        keys[#keys + 1] = trinket
    end
    for i = 1, #keys do
        self:removeBillboard(keys[i])
    end

    -- Reseta fila
    self._queue        = {}
    self._queueHead    = 1
    self._queueRunning = false

    -- Limpa caches (os weak tables se limpam sozinhos, mas um reset explícito
    -- garante que nada fique pendente)
    trinketCache              = setmetatable({}, { __mode = "k" })
    self._processedObjects    = setmetatable({}, { __mode = "k" })
end

--- Destrói a instância completamente.
function TrinketESP:destroy()
    pcall(function() self:disable() end)
    self._connectionManager = nil
    self.espBillboards      = nil
    self._processedObjects  = nil
    self._queue             = nil
end

return TrinketESP
