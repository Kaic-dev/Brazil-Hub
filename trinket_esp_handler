-- Obtém o HumanoidRootPart do jogador local para cálculo de distância
local function getLocalRootPart()
    local player = Players.LocalPlayer
    if not player then return nil end
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

-- Calcula distância em studs entre o trinket e o jogador
local function getDistance(part)
    local root = getLocalRootPart()
    if not root then return 0 end
    return (part.Position - root.Position).Magnitude
end

-- Formata distância legível para o range real do jogo (10m–5000m)
local function formatDistance(dist)
    if dist >= 1000 then
        return string.format("%.1fkm", dist / 1000)
    else
        return string.format("%dm", math_floor(dist))
    end
end

-- Normaliza texture IDs para comparação — remove prefixos rbxassetid:// e http://www.roblox.com/asset/?id=
local function cleanTextureId(texture)
    local str = tostring(texture)
    str = str:gsub("rbxassetid://", "")
    str = str:gsub("http://www%.roblox%.com/asset/%?id=", "")
    str = str:gsub("https://www%.roblox%.com/asset/%?id=", "")
    return str
end

