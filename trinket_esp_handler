local type_        = type
local tostring_    = tostring
local pairs_       = pairs
local setmetatable_= setmetatable
local mathFloor    = math.floor
local pcall_       = pcall

local function safeDestroy(obj)
    if obj == nil then return end
    pcall_(obj.Destroy, obj)
end

local function safeRequireRemote(url, name)
    local tag = "[trinket_esp_handler]"

    local dlOk, raw = pcall_(game.HttpGet, game, url)
    if not dlOk or type_(raw) ~= "string" or raw == "" then
        warn(tag, "Download falhou:", name, tostring_(raw))
        return nil
    end

    local fn, compErr = loadstring(raw)
    if type_(fn) ~= "function" then
        warn(tag, "Compilação falhou:", name, tostring_(compErr))
        return nil
    end

    local execOk, mod = pcall_(fn)
    if not execOk then
        warn(tag, "Execução falhou:", name, tostring_(mod))
        return nil
    end

    return mod
end

