-- [B] Atualiza distâncias E visibilidade por maxDistance
function TrinketESP:updateDistances()
    local root = getLocalRootPart()
    local maxDist = self._cfg.maxDistance

    if not root then
        for _, refs in pairs_(self.espBillboards) do
            pcall_(function() refs.distLabel.Text = "?" end)
        end
        return
    end

    local rootPos = root.Position

    for trinket, refs in pairs_(self.espBillboards) do
        if trinket and trinket.Parent then
            pcall_(function()
                local dist = (trinket.Position - rootPos).Magnitude
                -- Visibilidade por maxDistance
                local visible = (maxDist <= 0) or (dist <= maxDist)
                refs.billboard.Enabled = visible
                if visible and self._cfg.showDistance then
                    refs.distLabel.Text = formatDistance(dist)
                end
            end)
        end
    end
end

-- [4] Limpa billboard E conexão temporária pendente
function TrinketESP:removeBillboard(trinket)
    local refs = self.espBillboards[trinket]
    if refs then
        safeDestroy(refs.billboard)
        self.espBillboards[trinket] = nil
    end

    self._trinketCache[trinket]     = nil
    self._processedObjects[trinket] = nil

    local conn = self._pendingConns[trinket]
    if conn then
        pcall_(conn.Disconnect, conn)
        self._pendingConns[trinket] = nil
    end
end

--------------------------------------------------------------------------------
-- FILA DE PROCESSAMENTO
--------------------------------------------------------------------------------

function TrinketESP:_runQueue()
    if self._queueRunning then return end
    self._queueRunning = true

    task.spawn(function()
        local max = CFG_ESP.MaxProcessPerFrame

        while self.enabled do
            if self._queueHead > #self._queue then break end

            local processed = 0

            while self._queueHead <= #self._queue and processed < max do
                local trinket = self._queue[self._queueHead]
                self._queue[self._queueHead] = nil
                self._queueHead = self._queueHead + 1
                processed       = processed + 1

                if trinket == nil
                or self._processedObjects[trinket]
                or trinket.Parent == nil then
                    continue
                end

                local name = "Unknown"
                local infoOk, infoErr = pcall_(function()
                    name = getTrinketInfo(trinket)
                end)
                if not infoOk then
                    warn("[TrinketESP] getTrinketInfo falhou para",
                         tostring_(trinket), ":", tostring_(infoErr))
                end

                -- [A] Checa filtro antes de criar billboard
                if not self:_passesFilter(name) then
                    -- Marca como "processado" para não tentar novamente
                    self._processedObjects[trinket] = true
                    continue
                end

                -- [3] Só marca como processado após sucesso
                local billOk, billErr = pcall_(function()
                    self:createBillboard(trinket, name)
                end)

                if billOk then
                    self._processedObjects[trinket] = true
                else
                    warn("[TrinketESP] createBillboard falhou para",
                         tostring_(trinket), ":", tostring_(billErr))
                end
            end

            if self._queueHead > 500 then
                local old  = self._queue
                local newQ = {}
                for i = self._queueHead, #old do
                    newQ[#newQ + 1] = old[i]
                end
                self._queue     = newQ
                self._queueHead = 1
            end

            if self._queueHead <= #self._queue and self.enabled then
                RunService.Heartbeat:Wait()
            else
                break
            end
        end

        self._queueRunning = false
    end)
end

function TrinketESP:_enqueue(obj)
    self._queue[#self._queue + 1] = obj
    if not self._queueRunning then
        self:_runQueue()
    end
end

--------------------------------------------------------------------------------
-- WATCH FOR ID
--------------------------------------------------------------------------------

-- [2] Fecha race condition com releitura imediata após Connect
function TrinketESP:_watchForID(obj)
    if self._pendingConns[obj] then return end

    local conn
    conn = obj.ChildAdded:Connect(function(child)
        if child.Name ~= "ID" or not child:IsA("StringValue") then return end
        pcall_(conn.Disconnect, conn)
        self._pendingConns[obj] = nil
        self._trinketCache[obj] = nil
        if self.enabled and not self._processedObjects[obj] and obj.Parent ~= nil then
            self:_enqueue(obj)
        end
    end)

    self._pendingConns[obj] = conn

    -- [2] Releitura imediata
    self._trinketCache[obj] = nil
    if isTrinket(obj, self._trinketCache) then
        pcall_(conn.Disconnect, conn)
        self._pendingConns[obj] = nil
        if self.enabled and not self._processedObjects[obj] and obj.Parent ~= nil then
            self:_enqueue(obj)
        end
    end
end

--------------------------------------------------------------------------------
-- CALLBACKS
--------------------------------------------------------------------------------

function TrinketESP:onChildAdded(obj)
    if not self.enabled then return end
    if self._processedObjects[obj] then return end

    if isTrinket(obj, self._trinketCache) then
        self:_enqueue(obj)
        return
    end

    self:_watchForID(obj)
end

-- [4] Chamado incondicionalmente
function TrinketESP:onChildRemoved(obj)
    if not self.enabled then return end
    self:removeBillboard(obj)
end

-- [1] Objetos sem "ID" recebem _watchForID
function TrinketESP:scanExistingTrinkets()
    local ok, children = pcall_(Workspace.GetChildren, Workspace)
    if not ok or type_(children) ~= "table" then return end

    for i = 1, #children do
        local obj = children[i]
        if self._processedObjects[obj] then continue end

        if isTrinket(obj, self._trinketCache) then
            self._queue[#self._queue + 1] = obj
        else
            -- [1] "ID" pode não ter replicado ainda
            self:_watchForID(obj)
        end
    end

    if #self._queue >= self._queueHead then
        self:_runQueue()
    end
end

--------------------------------------------------------------------------------
-- CICLO DE VIDA
--------------------------------------------------------------------------------

function TrinketESP:enable()
    if self.enabled then return end
    self.enabled = true

    self:scanExistingTrinkets()

    pcall_(function()
        self._connectionManager:add(
            Workspace.ChildAdded:Connect(function(obj)
                self:onChildAdded(obj)
            end),
            "Workspace.ChildAdded"
        )
    end)

    pcall_(function()
        self._connectionManager:add(
            Workspace.ChildRemoved:Connect(function(obj)
                self:onChildRemoved(obj)
            end),
            "Workspace.ChildRemoved"
        )
    end)

    local frameCount = 0
    self._heartbeatConn = RunService.Heartbeat:Connect(function()
        frameCount = frameCount + 1
        if frameCount >= DIST_UPDATE_RATE then
            frameCount = 0
            self:updateDistances()
        end
    end)
end

function TrinketESP:disable()
    self.enabled = false

    pcall_(function() self._connectionManager:disconnectAll() end)

    if self._heartbeatConn then
        pcall_(function() self._heartbeatConn:Disconnect() end)
        self._heartbeatConn = nil
    end

    for obj, conn in pairs_(self._pendingConns) do
        pcall_(conn.Disconnect, conn)
        self._pendingConns[obj] = nil
    end

    local keys = {}
    for trinket in pairs_(self.espBillboards) do
        keys[#keys + 1] = trinket
    end
    for i = 1, #keys do
        self:removeBillboard(keys[i])
    end

    self._queue        = {}
    self._queueHead    = 1
    self._queueRunning = false

    self._trinketCache     = setmetatable_({}, { __mode = "k" })
    self._processedObjects = setmetatable_({}, { __mode = "k" })
    self._pendingConns     = setmetatable_({}, { __mode = "k" })
end

function TrinketESP:destroy()
    pcall_(function() self:disable() end)
    self._connectionManager = nil
    self.espBillboards      = nil
    self._processedObjects  = nil
    self._trinketCache      = nil
    self._pendingConns      = nil
    self._queue             = nil
    self._cfg               = nil
end

return TrinketESP
