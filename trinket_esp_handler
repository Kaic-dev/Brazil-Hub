function TrinketESP.new()
    return setmetatable({
        espBillboards = {},
        _connectionManager = ConnectionManager.new(),
        enabled = false,
        _pendingTrinkets = {},
        _processingQueue = false,
        _processedObjects = {},
        -- Conexão do Heartbeat para atualização de distância/fade
        _heartbeatConnection = nil,
    }, TrinketESP)
end

--// Cria o BillboardGui com pill + dot + distância + linha de ancoragem
function TrinketESP:createBillboard(trinket, trinketName)
    if self.espBillboards[trinket] then return end

    local color = Config.Colors.Trinkets[trinketName] or Config.Colors.Default

    -- Billboard principal: posicionada acima do item, com offset vertical
    local billboard = Instance_new("BillboardGui")
    billboard.Name = "TrinketESP"
    billboard.Adornee = trinket
    billboard.LightInfluence = 0
    billboard.ZIndexBehavior = Config.UI.ZIndexBehavior
    billboard.AlwaysOnTop = true
    billboard.Size = Config.ESP.BillboardSize
    -- Offset para flutuar ~1.5 studs acima do item
    billboard.StudsOffset = Vector3.new(0, 1.5, 0)
    billboard.Parent = trinket

    -- Frame raiz (transparente, organiza os filhos verticalmente)
    local root = Instance_new("Frame")
    root.Name = "Root"
    root.BackgroundTransparency = 1
    root.Size = UDim2_new(1, 0, 1, 0)
    root.Parent = billboard

    local layout = Instance_new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Vertical
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Top
    layout.Padding = UDim.new(0, 2)
    layout.Parent = root

    -- Pill: fundo escuro + borda colorida — tamanho automático pelo conteúdo
    local pill = Instance_new("Frame")
    pill.Name = "Pill"
    pill.BackgroundColor3 = Config.Colors.PillBackground
    pill.BackgroundTransparency = Config.Colors.PillBackgroundTransparency
    pill.Size = UDim2_new(0, 0, 0, 20)
    pill.AutomaticSize = Enum.AutomaticSize.X
    pill.BorderSizePixel = 0
    pill.Parent = root

    local pillCorner = Instance_new("UICorner")
    pillCorner.CornerRadius = UDim.new(1, 0)
    pillCorner.Parent = pill

    local pillStroke = Instance_new("UIStroke")
    pillStroke.Color = color
    pillStroke.Thickness = 1
    pillStroke.Transparency = 0.3
    pillStroke.Parent = pill

    local pillLayout = Instance_new("UIListLayout")
    pillLayout.FillDirection = Enum.FillDirection.Horizontal
    pillLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    pillLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    pillLayout.Padding = UDim.new(0, 5)
    pillLayout.Parent = pill

    local pillPadding = Instance_new("UIPadding")
    pillPadding.PaddingLeft = UDim.new(0, 7)
    pillPadding.PaddingRight = UDim.new(0, 7)
    pillPadding.Parent = pill

    -- Dot colorido
    local dot = Instance_new("Frame")
    dot.Name = "Dot"
    dot.BackgroundColor3 = color
    dot.Size = UDim2_new(0, 7, 0, 7)
    dot.BorderSizePixel = 0
    dot.Parent = pill

    local dotCorner = Instance_new("UICorner")
    dotCorner.CornerRadius = UDim.new(1, 0)
    dotCorner.Parent = dot

    -- Label com nome do trinket — tamanho automático pelo texto
    local nameLabel = Instance_new("TextLabel")
    nameLabel.Name = "NameLabel"
    nameLabel.Text = trinketName
    nameLabel.TextColor3 = color
    nameLabel.Font = Config.ESP.Font
    nameLabel.TextSize = Config.ESP.TextSize
    nameLabel.BackgroundTransparency = 1
    nameLabel.Size = UDim2_new(0, 0, 1, 0)
    nameLabel.AutomaticSize = Enum.AutomaticSize.X
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = pill

    -- Tag de distância — acompanha largura do pill
    local distLabel = Instance_new("TextLabel")
    distLabel.Name = "DistLabel"
    distLabel.Text = "..."
    distLabel.TextColor3 = Config.Colors.DistanceColor
    distLabel.Font = Config.ESP.FontDist
