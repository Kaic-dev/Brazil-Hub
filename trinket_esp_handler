    end,
}

do
    local _rawCM = safeRequireRemote(
        "https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/main/ConnectionManager",
        "ConnectionManager"
    )
    if not (type_(_rawCM) == "table" and type_(_rawCM.new) == "function") then
        _rawCM = nil
    end
    -- expõe ao escopo do módulo
    if _rawCM then
        _fallbackCM = _rawCM  -- reutiliza a variável como "ConnectionManager"
    end
end

local ConnectionManager = _fallbackCM   -- sempre válido aqui

