-- UtilsService Module
-- Main utility service that orchestrates all utility modules
-- Usage: local Utils = require(path); local utils = Utils.new(); utils:getPlayerData(player)

-- Load sub-modules using loadstring
local function safeRequireRemote(url, name)
    local ok, result = pcall(function()
        return game:HttpGet(url)
    end)
    if not ok then
        warn("[UtilsService] Failed to download module:", name or url, tostring(result))
        return nil
    end

    local moduleFunc, err = loadstring(result)
    if not moduleFunc then
        warn("[UtilsService] Failed to compile module:", name or url, tostring(err))
        return nil
    end

    local success, module = pcall(moduleFunc)
    if not success then
        warn("[UtilsService] Failed to execute module:", name or url, tostring(module))
        return nil
    end

    return module
end

local PlayerData = safeRequireRemote("https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/main/Utils/PlayerData", "PlayerData")
local ForceField = safeRequireRemote("https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/main/Utils/ForceField", "ForceField")
local ToolManager = safeRequireRemote("https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/main/Utils/ToolManager", "ToolManager")
local BillboardUtils = safeRequireRemote("https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/main/Utils/BillboardUtils", "BillboardUtils")

local UtilsService = {}
UtilsService.__index = UtilsService

--// Function: UtilsService.new
--// Description: Creates a new UtilsService instance with all sub-modules.
function UtilsService.new()
    local self = setmetatable({}, UtilsService)
    
    -- Initialize sub-modules
    self.playerData = PlayerData and PlayerData.new() or nil
    self.forceField = ForceField and ForceField.new() or nil
    self.toolManager = ToolManager and ToolManager.new() or nil
    self.billboardUtils = BillboardUtils and BillboardUtils.new() or nil
    
    return self
end

--// PlayerData Delegation Methods
function UtilsService:getPlayerBasicData(player)
    return self.playerData and self.playerData:getBasicData(player) or nil
end

function UtilsService:getPlayerRogueData(player)
    return self.playerData and self.playerData:getRogueData(player) or nil
end

function UtilsService:getPlayerEdictData(player)
    return self.playerData and self.playerData:getEdictData(player) or nil
end

function UtilsService:getPlayerPrestigeData(player)
    return self.playerData and self.playerData:getPrestigeData(player) or nil
end

function UtilsService:getPlayerHealthData(player)
    return self.playerData and self.playerData:getHealthData(player) or nil
end

function UtilsService:getPlayerFullData(player)
    return self.playerData and self.playerData:getFullData(player) or nil
end

function UtilsService:getPlayerRogueDisplay(player)
    return self.playerData and self.playerData:getRogueDisplay(player) or nil
end

function UtilsService:getPlayerEdictDisplay(player)
    return self.playerData and self.playerData:getEdictDisplay(player) or nil
end

function UtilsService:getPlayerHealthDisplay(player)
    return self.playerData and self.playerData:getHealthDisplay(player) or nil
end

--// ForceField Delegation Methods
function UtilsService:hasForceField(player)
    return self.forceField and self.forceField:hasForceField(player) or false
end

function UtilsService:getForceFieldTimeLeft(player)
    return self.forceField and self.forceField:getTimeLeft(player) or 0
end

function UtilsService:getForceFieldColor(timeLeft)
    return self.forceField and self.forceField:getColor(timeLeft) or Color3.fromRGB(255, 255, 255)
end

function UtilsService:getForceFieldData(player)
    return self.forceField and self.forceField:getData(player) or {
        hasForceField = false,
        timeLeft = 0,
        timeLeftFormatted = "0.0s",
        color = Color3.fromRGB(255, 255, 255),
        status = "Inactive"
    }
end

function UtilsService:getForceFieldStatus(player)
    return self.forceField and self.forceField:getStatus(player) or "FF: Inactive"
end

--// ToolManager Delegation Methods
function UtilsService:getPlayerTools(player)
    return self.toolManager and self.toolManager:getPlayerTools(player) or {}
end

function UtilsService:getToolDetails(tool)
    return self.toolManager and self.toolManager:getToolDetails(tool) or { name = tool and tool.Name or "Unknown" }
end

function UtilsService:getEquippedTool(player)
    local character = player and player.Character
    if not character then return nil end
    return character:FindFirstChildOfClass("Tool")
end

function UtilsService:getToolCount(player)
    local tools = self.toolManager and self.toolManager:getPlayerTools(player) or nil
    return tools and #tools or 0
end

--// Backward Compatibility Methods (for existing code)
function UtilsService:getPlayerData(player)
    return self:getPlayerFullData(player)
end

--// Billboard/Frame/Label Utility Methods
function UtilsService:createBillboard(parent, adornee, size, name)
    return self.billboardUtils and self.billboardUtils:createBillboard(parent, adornee, size, name) or nil
end

function UtilsService:createFrameWithLayout(parent, frameName, layoutConfig)
    return self.billboardUtils and self.billboardUtils:createFrameWithLayout(parent, frameName, layoutConfig) or nil
end

function UtilsService:createLabel(parent, text)
    return self.billboardUtils and self.billboardUtils:createLabel(parent, text) or nil
end

function UtilsService:createUIListLayout(parent, layoutConfig)
    return self.billboardUtils and self.billboardUtils:createUIListLayout(parent, layoutConfig) or nil
end

--// Main Export
return UtilsService 
