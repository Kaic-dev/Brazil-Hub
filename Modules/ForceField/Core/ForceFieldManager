-- FFHandler.lua - Arquitetura Modular com OOP e Otimização de Performance

local Players    = game:GetService('Players')
local RunService = game:GetService('RunService')

-- Módulos Externos
local Config               = loadstring(game:HttpGet('https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/Modules/ForceField/Config/FFConfig'))()
local BillboardRenderer    = loadstring(game:HttpGet('https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/Modules/ForceField/Core/BillboardRenderer'))()
local FFTracker            = loadstring(game:HttpGet('https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/Modules/ForceField/Core/ForceFieldTracker'))()
local CharacterConnections = loadstring(game:HttpGet('https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/Modules/ForceField/Core/CharacterConnectionManager'))()
local ConnectionManager    = loadstring(game:HttpGet('https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/ConnectionManager'))()

local getTime = os.clock

-- FIX #5: guard contra ff destruído antes do SetAttribute
local function ensureStartTime(ff)
    local startTime = ff:GetAttribute("StartTime")
    if not startTime then
        startTime = getTime()
        if ff and ff.Parent then
            ff:SetAttribute("StartTime", startTime)
        end
    end
    return startTime
end

-- ─── FFDetector ───────────────────────────────────────────────────────────────

local FFDetector = {}
FFDetector.__index = FFDetector

function FFDetector.new()
    local self = setmetatable({}, FFDetector)

    self.enabled            = false
    self._connMgr           = ConnectionManager.new()
    self._charConnMgrs      = {}
    self._billboardRenderer = BillboardRenderer.new()
    self._ffTracker         = FFTracker.new()
    self._lastUpdate        = 0

    -- FIX #3: buffer pré-alocado para evitar alocação de tabela a cada update
    self._removeBuffer = {}
    self._removeCount  = 0

    -- FIX #6: contador de geração por personagem para debounce de CharacterAdded
    self._charGenerations = {}

    return self
end

-- ─── Dados de ForceField ──────────────────────────────────────────────────────

function FFDetector:removeForceFieldData(character, ff)
    if not self._charConnMgrs[character] then return end

    local trackedFF = self._ffTracker:find(character)
    if trackedFF ~= ff then return end

    self._ffTracker:remove(character, ff)

    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("ForceField") and child ~= ff then
            local startTime = ensureStartTime(child)
            self._ffTracker:set(character, child)
            self._billboardRenderer:create(character, child, startTime)

            local charMgr = self._charConnMgrs[character]
            if charMgr then charMgr:trackFF(child) end
            return
        end
    end

    self._billboardRenderer:remove(character)
end

function FFDetector:clearCharacterData(character)
    self._billboardRenderer:remove(character)
    self._ffTracker:clear(character)
    self._charGenerations[character] = nil

    local mgr = self._charConnMgrs[character]
    if mgr then
        mgr:disconnect()
        self._charConnMgrs[character] = nil
    end
end

-- ─── Cleanup interno (apenas estado) ─────────────────────────────────────────

-- FIX #2: separado de disconnectAll() para que enable/disable controlem
--         a ordem exata: desconectar primeiro, limpar estado depois.
function FFDetector:_cleanupState()
    for _, mgr in pairs(self._charConnMgrs) do
        mgr:disconnect()
    end
    self._charConnMgrs    = {}
    self._charGenerations = {}

    for character in pairs(self._ffTracker:getAll()) do
        self._billboardRenderer:remove(character)
    end

    self._ffTracker:clearAll()

    -- Recria instâncias para estado limpo
    self._billboardRenderer = BillboardRenderer.new()
    self._ffTracker         = FFTracker.new()

    -- Reseta buffer de remoção
    self._removeCount = 0
end

-- Mantido para compatibilidade externa (chamado apenas por disable agora)
function FFDetector:cleanup()
    self._connMgr:disconnectAll()
    self:_cleanupState()
    self._connMgr = ConnectionManager.new()
end

-- ─── Eventos de ForceField ────────────────────────────────────────────────────

function FFDetector:onForceFieldAdded(character, ff)
    local startTime = ensureStartTime(ff)

    local currentFF = self._ffTracker:find(character)
    if currentFF == ff then return end

    self._ffTracker:set(character, ff)
    self._billboardRenderer:create(character, ff, startTime)

    local charMgr = self._charConnMgrs[character]
    if charMgr then charMgr:trackFF(ff) end
end

-- ─── Registro de personagem ───────────────────────────────────────────────────

function FFDetector:registerCharacterFF(character)
    if not self.enabled then return end

    -- FIX #6: geração garante que apenas o registro mais recente prossegue.
    --         Protege contra CharacterAdded duplicado na mesma frame.
    local gen = (self._charGenerations[character] or 0) + 1
    self._charGenerations[character] = gen

    local existing = self._charConnMgrs[character]
    if existing then
        existing:disconnect()
        self._charConnMgrs[character] = nil
    end

    -- Se a geração já foi superada por outro evento, abandona.
    if self._charGenerations[character] ~= gen then return end

    local manager = CharacterConnections.new(character)
    manager:setHandlers({
        onFFAdded = function(ff)
            if self._charGenerations[character] ~= gen then return end
            self:onForceFieldAdded(character, ff)
        end,
        onCharacterRemoved = function()
            self:clearCharacterData(character)
        end,
        onFFRemoved = function(ff)
            if self._charGenerations[character] ~= gen then return end
            self:removeForceFieldData(character, ff)
        end,
    })
    manager:watch()
    self._charConnMgrs[character] = manager

    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("ForceField") then
            local startTime = ensureStartTime(child)

            if not self._ffTracker:exists(character) then
                self._ffTracker:set(character, child)
            end

            self._billboardRenderer:create(character, child, startTime)
            manager:trackFF(child)
        end
    end
end

-- ─── Registro de player ───────────────────────────────────────────────────────

function FFDetector:registerPlayer(player)
    if player.Character then
        self:registerCharacterFF(player.Character)
    end

    self._connMgr:add(
        player.CharacterAdded:Connect(function(character)
            self:registerCharacterFF(character)
        end),
        player.Name .. ".CharacterAdded"
    )

    self._connMgr:add(
        player.CharacterRemoving:Connect(function(character)
            self:clearCharacterData(character)
        end),
        player.Name .. ".CharacterRemoving"
    )
end

-- ─── Update de billboards ─────────────────────────────────────────────────────

function FFDetector:updateBillboards()
    local currentTime = getTime()
    if currentTime - self._lastUpdate < Config.FF.UpdateInterval then return end
    self._lastUpdate = currentTime

    -- FIX #3: reutiliza buffer pré-alocado, sem criar tabela nova por frame
    self._removeCount = 0

    for character, ffData in pairs(self._ffTracker:getAll()) do
        local ff = ffData.ff
        if ff and ff.Parent == character then
            self._billboardRenderer:create(character, ff, ffData.startTime)
        else
            self._removeCount = self._removeCount + 1
            self._removeBuffer[self._removeCount] = character
        end
    end

    for i = 1, self._removeCount do
        local character = self._removeBuffer[i]
        self._removeBuffer[i] = nil  -- libera referência sem realocar tabela
        local trackedFF = self._ffTracker:find(character)
        if trackedFF then
            self:removeForceFieldData(character, trackedFF)
        end
    end
end

-- ─── Enable / Disable ─────────────────────────────────────────────────────────

function FFDetector:enable()
    if self.enabled then return end
    self.enabled = true

    -- FIX #1 + #2: desconecta Heartbeat e conexões globais ANTES de recriar estado,
    --              eliminando o tick de Heartbeat que poderia acessar estado parcial.
    self._connMgr:disconnectAll()
    self:_cleanupState()
    self._connMgr = ConnectionManager.new()

    for _, player in ipairs(Players:GetPlayers()) do
        self:registerPlayer(player)
    end

    self._connMgr:add(
        Players.PlayerAdded:Connect(function(player)
            self:registerPlayer(player)
        end),
        "Players.PlayerAdded"
    )

    self._connMgr:add(
        Players.PlayerRemoving:Connect(function(player)
            if player.Character then
                self:clearCharacterData(player.Character)
            end
        end),
        "Players.PlayerRemoving"
    )

    self._connMgr:add(
        RunService.Heartbeat:Connect(function()
            self:updateBillboards()
        end),
        "RunService.Heartbeat"
    )
end

function FFDetector:disable()
    if not self.enabled then return end
    self.enabled = false

    -- FIX #1: desconecta Heartbeat imediatamente, antes de qualquer limpeza de estado.
    --         Garante que updateBillboards() não dispara mais nenhum tick após disable().
    self._connMgr:disconnectAll()
    self:_cleanupState()
    self._connMgr = ConnectionManager.new()
end

-- ─── API pública ──────────────────────────────────────────────────────────────

function FFDetector:setBillboardMaxDistance(value)
    self._billboardRenderer:setMaxDistance(value)
end

function FFDetector:setBillboardTextSize(value)
    self._billboardRenderer:setTextSize(value)
end

return FFDetector
