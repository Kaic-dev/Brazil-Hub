-- ConnectionManager.lua
-- Utilitário para gerenciar RBXScriptConnections de forma segura e centralizada

local ConnectionManager = {}
ConnectionManager.__index = ConnectionManager

local function safeMakeFolder(path)
    if not makefolder or not isfolder then
        return
    end
    local parts = string.split(path, "/")
    local current = ""
    for i = 1, #parts - 1 do
        current = (current == "") and parts[i] or (current .. "/" .. parts[i])
        if not isfolder(current) then
            pcall(makefolder, current)
        end
    end
end

local function safeWriteFile(path, content)
    if not writefile then
        return false, "writefile unavailable"
    end
    safeMakeFolder(path)
    local ok, err = pcall(writefile, path, content)
    return ok, err
end

-- Cria uma nova instância do ConnectionManager
function ConnectionManager.new()
    return setmetatable({ _conns = {} }, ConnectionManager)
end

-- Conecta um sinal a uma função e adiciona a conexão ao manager
-- @param signal O sinal (evento) a ser conectado
-- @param callback A função a ser chamada quando o evento for disparado
-- @return A conexão criada
function ConnectionManager:connect(signal, callback)
    local conn = signal:Connect(callback)
    self:add(conn)
    return conn
end

-- Conecta um sinal a uma função com tratamento de erros integrado (pcall)
-- @param signal O sinal (evento) a ser conectado
-- @param callback A função a ser chamada quando o evento for disparado
-- @return A conexão criada
function ConnectionManager:safeConnect(signal, callback)
    local safeCallback = function(...)
        local success, err = pcall(callback, ...)
        if not success then
            warn("[Brazil Hub SafeCall Error]:", tostring(err))
        end
    end
    local conn = signal:Connect(safeCallback)
    self:add(conn)
    return conn
end

-- Adiciona uma conexão existente ao manager
-- @param conn A conexão a ser adicionada (deve ser uma RBXScriptConnection)
function ConnectionManager:add(conn, name)
    if typeof(conn) ~= "RBXScriptConnection" then
        warn("Tentativa de adicionar um objeto que não é uma RBXScriptConnection")
        return
    end
    if not self._conns[conn] then
        self._conns[conn] = {
            name = name or tostring(conn),
            conn = conn,
            stack = debug and debug.traceback("", 2) or nil
        }
    end
end

-- Remove e desconecta uma conexão específica
-- @param conn A conexão a ser removida
function ConnectionManager:remove(conn)
    if self._conns[conn] then
        if conn.Connected then
            conn:Disconnect()
        end
        self._conns[conn] = nil
    end
end

-- Desconecta todas as conexões e limpa a lista
function ConnectionManager:disconnectAll()
    for conn, record in pairs(self._conns) do
        if conn.Connected then
            conn:Disconnect()
        end
    end
    self._conns = {}
end

-- Conta o número de conexões gerenciadas
-- @return O número de conexões ativas
function ConnectionManager:count()
    local count = 0
    for _ in pairs(self._conns) do
        count = count + 1
    end
    return count
end

-- Retorna detalhes das conexões gerenciadas
-- @return Tabela de registros com campos name e connected
function ConnectionManager:getDetails()
    local details = {}
    for conn, record in pairs(self._conns) do
        table.insert(details, {
            name = record.name or tostring(conn),
            connected = conn.Connected,
            stack = record.stack or ""
        })
    end
    return details
end

function ConnectionManager:dumpToFile(filename)
    filename = filename or ("BrazilHub/connection_logs/connections_" .. os.date("%Y%m%d_%H%M%S") .. ".txt")
    local lines = {}
    for conn, record in pairs(self._conns) do
        local connected = tostring(conn.Connected)
        table.insert(lines, string.format("name=%s connected=%s\nstack=%s\n", record.name, connected, record.stack or ""))
    end
    local content = table.concat(lines, "\n")
    local ok, err = safeWriteFile(filename, content)
    if not ok then
        warn("[ConnectionManager] Failed to write dump:", tostring(err))
    end
    return ok
end

return ConnectionManager
