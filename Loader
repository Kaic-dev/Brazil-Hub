-- Brazil Hub Loader
-- O usuário deve executar apenas esta linha no executor:
-- loadstring(game:HttpGet("https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/Loader"))()

local ScriptURL = "https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/CoreManager"
local LoaderURL = "https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/Loader"

-- Aguarda o carregamento inicial do jogo se necessário
if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Tratamento de erros robusto para o download
local success, result = pcall(function()
    return game:HttpGet(ScriptURL)
end)

if success then
    local func, err = loadstring(result)
    if func then
        -- Agenda o recarregamento do LOADER (não do CoreManager) para teleports futuros
        local queue = queue_on_teleport or (syn and syn.queue_on_teleport)
        if queue then
            pcall(function()
                queue('loadstring(game:HttpGet("' .. LoaderURL .. '"))()')
            end)
        end

        -- Executa o script principal
        local execOk, execErr = pcall(func)
        if not execOk then
            warn("[Brazil Hub] Erro ao executar script principal:", tostring(execErr))
        end
    else
        warn("[Brazil Hub] Erro ao compilar script principal: " .. tostring(err))
    end
else
    warn("[Brazil Hub] Falha ao baixar o script principal. Verifique sua conexão ou status do GitHub!")
end
