-- URL do Módulo
local SUPER_LEADERBOARD_URL = "https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/CustomLBModule"

local function safeLoadModule(url, name)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)

    if not success then
        warn("[Init] Failed to download module:", name or url, tostring(result))
        return nil
    end

    local moduleFunction, loadError = loadstring(result)
    if not moduleFunction then
        warn("[Init] Failed to compile module:", name or url, tostring(loadError))
        return nil
    end

    local ok, module = pcall(moduleFunction)
    if not ok then
        warn("[Init] Failed to execute module:", name or url, tostring(module))
        return nil
    end

    return module
end

-- Função para carregar o módulo usando game:HttpGet e loadstring
local function loadSuperLeaderboard()
    return safeLoadModule(SUPER_LEADERBOARD_URL, "SuperLeaderboard")
end

-- Carregar o SuperLeaderboardModule
local SuperLeaderboardModule = loadSuperLeaderboard()
if not SuperLeaderboardModule then
    warn("[Init] SuperLeaderboardModule não foi carregado")
    return
end

-- Instanciar o SuperLeaderboard
local leaderboard = SuperLeaderboardModule.new()
