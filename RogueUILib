-- CREATE WINDOW
-- ══════════════════════════════════════════════════════════════════════════════
function RogueUI:CreateWindow(options)
    local titleText = options.Title     or "[Rogue UI]"
    local toggleKey = options.ToggleKey or Enum.KeyCode.RightShift

    local self_Window = {
