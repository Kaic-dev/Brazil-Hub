    local tex = Instance.new("ImageLabel")
    tex.Size                  = UDim2.new(1,0,1,0)
    tex.BackgroundTransparency = 1
    tex.Image                 = self.Theme.ParchmentTexture
    tex.ImageTransparency     = self.Theme.ParchmentTransparency
    tex.ScaleType             = Enum.ScaleType.Tile
    tex.TileSize              = UDim2.new(0,256,0,256)
    tex.Parent                = mainWindow

    local wStroke = Instance.new("UIStroke")
    wStroke.Thickness       = 1
    wStroke.Color           = self.Theme.BorderColor
    wStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    wStroke.Parent          = mainWindow

    local header = Instance.new("Frame")
    header.Name             = "Header"
    header.Size             = UDim2.new(1,0,0,32)
    header.BackgroundColor3 = self.Theme.HeaderBackground
    header.BorderSizePixel  = 0
    header.Parent           = mainWindow

    local hLine = Instance.new("Frame")
    hLine.Size             = UDim2.new(1,0,0,1)
    hLine.Position         = UDim2.new(0,0,1,-1)
    hLine.BackgroundColor3 = self.Theme.BorderColor
    hLine.BorderSizePixel  = 0
    hLine.Parent           = header

    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size                = UDim2.new(1,-80,1,0)
    titleLbl.Position            = UDim2.new(0,12,0,0)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text                = titleText
    titleLbl.TextColor3          = self.Theme.TextActive
    titleLbl.Font                = Enum.Font.Garamond
    titleLbl.TextSize            = 18
    titleLbl.TextXAlignment      = Enum.TextXAlignment.Left
    titleLbl.Parent              = header

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size               = UDim2.new(0,32,0,32)
    closeBtn.Position           = UDim2.new(1,-32,0,0)
    closeBtn.BackgroundTransparency = 1
    closeBtn.Text               = "X"
    closeBtn.TextColor3         = self.Theme.TextNormal
    closeBtn.Font               = Enum.Font.Garamond
    closeBtn.TextSize           = 16
    closeBtn.Parent             = header
    closeBtn.MouseEnter:Connect(function() closeBtn.TextColor3=self.Theme.ToggleXColor end)
    closeBtn.MouseLeave:Connect(function() closeBtn.TextColor3=self.Theme.TextNormal   end)
    closeBtn.MouseButton1Click:Connect(function() playClick(); screenGui.Enabled=false end)

    local minBtn = Instance.new("TextButton")
    minBtn.Size               = UDim2.new(0,32,0,32)
    minBtn.Position           = UDim2.new(1,-64,0,0)
    minBtn.BackgroundTransparency = 1
    minBtn.Text               = "-"
    minBtn.TextColor3         = self.Theme.TextNormal
    minBtn.Font               = Enum.Font.Garamond
    minBtn.TextSize           = 18
    minBtn.Parent             = header

    local tabContainer = Instance.new("Frame")
    tabContainer.Name             = "TabContainer"
    tabContainer.Size             = UDim2.new(0,120,1,-32)
    tabContainer.Position         = UDim2.new(0,0,0,32)
    tabContainer.BackgroundColor3 = self.Theme.HeaderBackground
    tabContainer.BorderSizePixel  = 0
    tabContainer.Parent           = mainWindow

    local pages = Instance.new("Frame")
    pages.Name               = "Pages"
    pages.Size               = UDim2.new(1,-120,1,-32)
    pages.Position           = UDim2.new(0,120,0,32)
    pages.BackgroundTransparency = 1
    pages.Parent             = mainWindow

    local isMinimized = false
    local TWEEN_MIN   = TweenInfo.new(0.15,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)

    minBtn.MouseEnter:Connect(function() minBtn.TextColor3=self.Theme.TextActive; playHover() end)
    minBtn.MouseLeave:Connect(function() minBtn.TextColor3=self.Theme.TextNormal end)
    minBtn.MouseButton1Click:Connect(function()
        playClick(); isMinimized=not isMinimized
        if isMinimized then
            TweenService:Create(mainWindow,TWEEN_MIN,{Size=UDim2.new(0,570,0,32)}):Play()
            task.delay(0.08,function() tabContainer.Visible=false; pages.Visible=false end)
            minBtn.Text="+"
        else
            tabContainer.Visible=true; pages.Visible=true
            TweenService:Create(mainWindow,TWEEN_MIN,{Size=UDim2.new(0,570,0,420)}):Play()
            minBtn.Text="-"
        end
    end)

    makeDraggable(mainWindow, header, addCleanup)

    local tabLine = Instance.new("Frame")
    tabLine.Size             = UDim2.new(0,1,1,0)
    tabLine.Position         = UDim2.new(1,-1,0,0)
