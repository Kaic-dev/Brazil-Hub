                label.TextSize = 15
                label.TextTruncate = Enum.TextTruncate.AtEnd
                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Parent = toggleFrame
                
                local toggleData = { Value = default, OnChangedCallbacks = { callback } }
                RogueUI.Toggles[id] = toggleData
                
                local function set(state)
                    toggleData.Value = state
                    mark.Visible = state
                    label.TextColor3 = state and RogueUI.Theme.TextActive or RogueUI.Theme.TextNormal
                    boxBorder.Color = state and RogueUI.Theme.BorderColor or RogueUI.Theme.BorderInactive
                    
                    for _, cb in ipairs(toggleData.OnChangedCallbacks) do
                        task.spawn(cb, state)
                    end
                end
                
                local function fire()
                    playClick()
                    set(not toggleData.Value)
                end
                
                box.MouseButton1Click:Connect(fire)
                label.MouseButton1Click:Connect(fire)
                
                label.MouseEnter:Connect(function()
                    playHover()
                    if not toggleData.Value then
                        label.TextColor3 = RogueUI.Theme.TextActive
                    end
                end)
                label.MouseLeave:Connect(function()
                    if not toggleData.Value then
                        label.TextColor3 = RogueUI.Theme.TextNormal
                    end
                end)
                
                function toggleData:SetValue(state)
                    set(state)
                end
                
                function toggleData:OnChanged(cb)
                    table.insert(toggleData.OnChangedCallbacks, cb)
                end
                
