        ActiveTab          = nil,
        ToggleKeybind      = { Value = toggleKey },
        CleanupConnections = {},
        _activeDropdown    = nil,  -- dropdown do groupbox atualmente aberto
    }

    local function addCleanup(conn)
        if type(conn)=="function" or (conn and conn.Disconnect) then
            table.insert(self_Window.CleanupConnections, conn)
        end
        return conn
    end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name           = "RogueHubGui"
    screenGui.ResetOnSpawn   = false
    screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    screenGui.Parent         = UIParent
    self_Window.Gui          = screenGui

    local mainWindow = Instance.new("Frame")
