    addCleanup(UserInputService.InputBegan:Connect(function(input)
        local ck = self_Window.ToggleKeybind and self_Window.ToggleKeybind.Value
        if not UserInputService:GetFocusedTextBox() and ck and input.KeyCode==ck then
            screenGui.Enabled=not screenGui.Enabled; playClick()
        end
    end))

    -- ── AddTab ───────────────────────────────────────────────────────────────
    function self_Window:AddTab(tabName)
        local tabBtn = Instance.new("TextButton")
        tabBtn.Name             = tabName.."Tab"
        tabBtn.Size             = UDim2.new(1,0,0,36)
        tabBtn.BackgroundTransparency = 1
        tabBtn.Text             = tabName
        tabBtn.TextColor3       = RogueUI.Theme.TextMuted
        tabBtn.Font             = Enum.Font.Garamond
        tabBtn.TextSize         = 16
        tabBtn.Parent           = tabContainer

        local tabBLine = Instance.new("Frame")
        tabBLine.Size             = UDim2.new(1,0,0,1)
        tabBLine.Position         = UDim2.new(0,0,1,-1)
        tabBLine.BackgroundColor3 = RogueUI.Theme.BorderInactive
        tabBLine.BorderSizePixel  = 0
        tabBLine.Parent           = tabBtn

        local page = Instance.new("ScrollingFrame")
        page.Name               = tabName.."Page"
        page.Size               = UDim2.new(1,0,1,0)
        page.BackgroundTransparency = 1
        page.Visible            = false
        page.ScrollBarThickness = 4
        page.ScrollBarImageColor3 = RogueUI.Theme.BorderColor
        page.CanvasSize         = UDim2.new(0,0,0,0)
        page.Parent             = pages

        local pageLayout = Instance.new("UIListLayout")
        pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        pageLayout.Padding   = UDim.new(0,10)
        pageLayout.Parent    = page

        local pagePad = Instance.new("UIPadding")
        pagePad.PaddingTop    = UDim.new(0,10); pagePad.PaddingBottom = UDim.new(0,10)
        pagePad.PaddingLeft   = UDim.new(0,10); pagePad.PaddingRight  = UDim.new(0,10)
        pagePad.Parent        = page

        local cols = Instance.new("Frame")
        cols.Name               = "Columns"
        cols.Size               = UDim2.new(1,0,1,0)
        cols.BackgroundTransparency = 1
        cols.Parent             = page

        local leftCol = Instance.new("Frame")
        leftCol.Name               = "LeftColumn"
        leftCol.Size               = UDim2.new(0.5,-5,1,0)
        leftCol.BackgroundTransparency = 1
        leftCol.Parent             = cols

        local leftLayout = Instance.new("UIListLayout")
        leftLayout.SortOrder = Enum.SortOrder.LayoutOrder
        leftLayout.Padding   = UDim.new(0,10)
        leftLayout.Parent    = leftCol

        local rightCol = Instance.new("Frame")
        rightCol.Name               = "RightColumn"
        rightCol.Size               = UDim2.new(0.5,-5,1,0)
        rightCol.Position           = UDim2.new(0.5,5,0,0)
        rightCol.BackgroundTransparency = 1
        rightCol.Parent             = cols

        local rightLayout = Instance.new("UIListLayout")
        rightLayout.SortOrder = Enum.SortOrder.LayoutOrder
        rightLayout.Padding   = UDim.new(0,10)
        rightLayout.Parent    = rightCol

        local tabData = { Button=tabBtn, Page=page, Left=leftCol, Right=rightCol }

        local function updateCanvas()
            local lh = leftLayout.AbsoluteContentSize.Y
            local rh = rightLayout.AbsoluteContentSize.Y
            local mh = math.max(lh,rh)
            cols.Size       = UDim2.new(1,0,0,mh)
            page.CanvasSize = UDim2.new(0,0,0,mh+30)
        end
        leftLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
        rightLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

        local function activate()
            if self_Window.ActiveTab then
                self_Window.ActiveTab.Button.TextColor3 = RogueUI.Theme.TextMuted
                self_Window.ActiveTab.Page.Visible      = false
            end
            self_Window.ActiveTab   = tabData
            tabBtn.TextColor3       = RogueUI.Theme.TextActive
            page.Visible            = true
            updateCanvas()
        end

        tabBtn.MouseButton1Click:Connect(function() playClick(); activate() end)
        tabBtn.MouseEnter:Connect(function()
            if self_Window.ActiveTab~=tabData then tabBtn.TextColor3=RogueUI.Theme.TextNormal; playHover() end
        end)
        tabBtn.MouseLeave:Connect(function()
            if self_Window.ActiveTab~=tabData then tabBtn.TextColor3=RogueUI.Theme.TextMuted end
        end)
        if not self_Window.ActiveTab then activate() end

        -- ── AddGroupbox ───────────────────────────────────────────────────────
        local function addGroupbox(parentCol, groupTitle)
            local gf = Instance.new("Frame")
            gf.Name             = groupTitle.."Group"
            gf.Size             = UDim2.new(1,0,0,40)
            gf.BackgroundColor3 = RogueUI.Theme.GroupBackground
            gf.BorderSizePixel  = 0
            gf.Parent           = parentCol

            local gStroke = Instance.new("UIStroke")
            gStroke.Thickness = 1; gStroke.Color = RogueUI.Theme.BorderInactive; gStroke.Parent = gf

            local gtLbl = Instance.new("TextLabel")
            gtLbl.Size               = UDim2.new(1,-16,0,22)
            gtLbl.Position           = UDim2.new(0,8,0,2)
            gtLbl.BackgroundTransparency = 1
            gtLbl.Text               = groupTitle
            gtLbl.TextColor3         = RogueUI.Theme.TextActive
            gtLbl.Font               = Enum.Font.Garamond
            gtLbl.TextSize           = 15
            gtLbl.TextXAlignment     = Enum.TextXAlignment.Left
            gtLbl.Parent             = gf

            local gLine = Instance.new("Frame")
            gLine.Size             = UDim2.new(1,-16,0,1)
            gLine.Position         = UDim2.new(0,8,0,22)
            gLine.BackgroundColor3 = RogueUI.Theme.BorderInactive
            gLine.BorderSizePixel  = 0
            gLine.Parent           = gf

            local content = Instance.new("Frame")
            content.Name               = "Content"
            content.Size               = UDim2.new(1,0,1,-24)
            content.Position           = UDim2.new(0,0,0,24)
            content.BackgroundTransparency = 1
            content.Parent             = gf

            local cLayout = Instance.new("UIListLayout")
            cLayout.SortOrder = Enum.SortOrder.LayoutOrder
            cLayout.Padding   = UDim.new(0,6)
            cLayout.Parent    = content

            local cPad = Instance.new("UIPadding")
            cPad.PaddingLeft   = UDim.new(0,8); cPad.PaddingRight  = UDim.new(0,8)
            cPad.PaddingTop    = UDim.new(0,6); cPad.PaddingBottom = UDim.new(0,6)
            cPad.Parent        = content

            cLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                gf.Size = UDim2.new(1,0,0, cLayout.AbsoluteContentSize.Y+38)
                updateCanvas()
            end)

            local group_Self = {}

            -- ── Toggle ────────────────────────────────────────────────────────
            function group_Self:AddToggle(id, opts)
                local text       = opts.Text     or id
                local default    = opts.Default  or false
                local cb         = opts.Callback or function() end
                local hasKeybind = opts.Keybind  or false
                local defKey     = opts.KeybindKey

                local toggleData = {
                    Value              = default,
                    OnChangedCallbacks = { cb },
                    KeybindEnabled     = hasKeybind and (defKey~=nil),
                    KeybindKey         = defKey or nil,
                    KeybindMode        = "Toggle",
                    _configPanel       = nil,
                }
                RogueUI.Toggles[id] = toggleData

                local tFrame = Instance.new("Frame")
                tFrame.Name               = id.."Toggle"
                tFrame.Size               = UDim2.new(1,0,0,18)
                tFrame.BackgroundTransparency = 1
                tFrame.Parent             = content

                local box = Instance.new("TextButton")
                box.Name             = "Box"
                box.Size             = UDim2.new(0,14,0,14)
                box.Position         = UDim2.new(0,0,0.5,-7)
                box.BackgroundColor3 = RogueUI.Theme.MainBackground
                box.Text             = ""
                box.BorderSizePixel  = 0
                box.Parent           = tFrame

                local bStroke = Instance.new("UIStroke")
