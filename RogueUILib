-- CONFIG PANEL
-- ══════════════════════════════════════════════════════════════════════════════
local PANEL_W    = 260
local PANEL_ZIDX = 400
local TWEEN_FAST = TweenInfo.new(0.13, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local COLOR_PRESETS = {
    Color3.fromRGB(255,255,255), Color3.fromRGB(205,170,105),
    Color3.fromRGB(130,130,132), Color3.fromRGB(180,50, 50),
    Color3.fromRGB(0,  200,100), Color3.fromRGB(80, 180,255),
    Color3.fromRGB(255,140,0),   Color3.fromRGB(200,50, 200),
}

local function createRichConfigPanel(screenGui, anchorFrame, titleText, theme, addCleanup)

    local panel = Instance.new("Frame")
    panel.Name             = "CP_"..titleText
    panel.Size             = UDim2.new(0,PANEL_W,0,0)
    panel.BackgroundColor3 = theme.ConfigBackground
    panel.BorderSizePixel  = 0
    panel.Visible          = false
    panel.ZIndex           = PANEL_ZIDX
    panel.ClipsDescendants = true
    panel.Parent           = screenGui

    local panelStroke = Instance.new("UIStroke")
    panelStroke.Thickness       = 1
    panelStroke.Color           = theme.BorderColor
    panelStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    panelStroke.Parent          = panel

    -- Rastreia se o cursor está dentro do painel (mais confiável que hit-test geométrico)
    panel.MouseEnter:Connect(function() cursorInPanel = true end)
    panel.MouseLeave:Connect(function() cursorInPanel = false end)

    local ph = Instance.new("Frame")
    ph.Size             = UDim2.new(1,0,0,24)
    ph.BackgroundColor3 = theme.ConfigHeaderBg
    ph.BorderSizePixel  = 0
    ph.ZIndex           = PANEL_ZIDX+1
    ph.Parent           = panel

    local phLine = Instance.new("Frame")
    phLine.Size             = UDim2.new(1,0,0,1)
    phLine.Position         = UDim2.new(0,0,1,-1)
    phLine.BackgroundColor3 = theme.BorderColor
    phLine.BorderSizePixel  = 0
    phLine.ZIndex           = PANEL_ZIDX+1
    phLine.Parent           = ph

    local phTitle = Instance.new("TextLabel")
    phTitle.Size                = UDim2.new(1,-24,1,0)
    phTitle.Position            = UDim2.new(0,8,0,0)
    phTitle.BackgroundTransparency = 1
    phTitle.Text                = titleText
    phTitle.TextColor3          = theme.TextActive
    phTitle.Font                = Enum.Font.Garamond
    phTitle.TextSize            = 13
    phTitle.TextXAlignment      = Enum.TextXAlignment.Left
    phTitle.ZIndex              = PANEL_ZIDX+2
    phTitle.Parent              = ph

    local phClose = Instance.new("TextButton")
    phClose.Size               = UDim2.new(0,24,0,24)
    phClose.Position           = UDim2.new(1,-24,0,0)
    phClose.BackgroundTransparency = 1
    phClose.Text               = "x"
    phClose.TextColor3         = theme.TextMuted
    phClose.Font               = Enum.Font.Garamond
    phClose.TextSize           = 17
    phClose.ZIndex             = PANEL_ZIDX+2
    phClose.Parent             = ph
    phClose.MouseEnter:Connect(function() phClose.TextColor3 = theme.ToggleXColor end)
    phClose.MouseLeave:Connect(function() phClose.TextColor3 = theme.TextMuted    end)

    local scroll = Instance.new("ScrollingFrame")
    scroll.Name                = "Content"
    scroll.Size                = UDim2.new(1,0,1,-24)
    scroll.Position            = UDim2.new(0,0,0,24)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel     = 0
    scroll.ScrollBarThickness  = 3
    scroll.ScrollBarImageColor3 = theme.BorderColor
    scroll.CanvasSize          = UDim2.new(0,0,0,0)
    scroll.ZIndex              = PANEL_ZIDX+1
    scroll.Parent              = panel

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding   = UDim.new(0,0)
    layout.Parent    = scroll

    local contentPad = Instance.new("UIPadding")
    contentPad.PaddingLeft   = UDim.new(0,8)
    contentPad.PaddingRight  = UDim.new(0,8)
    contentPad.PaddingTop    = UDim.new(0,6)
    contentPad.PaddingBottom = UDim.new(0,6)
    contentPad.Parent        = scroll

    local open           = false
    local sliderDragging = false  -- impede fechamento ao arrastar sliders
    local cursorInPanel  = false  -- rastreado via MouseEnter/Leave do painel

    local function recalc()
        local h = layout.AbsoluteContentSize.Y + 16
        scroll.CanvasSize = UDim2.new(0,0,0,h)
        if open then
            local target = math.min(24 + h, 400)
            TweenService:Create(panel, TWEEN_FAST, {Size=UDim2.new(0,PANEL_W,0,target)}):Play()
        end
    end
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(recalc)

    local posConn = nil
    local function reposition()
        if not anchorFrame or not anchorFrame.Parent then return end
        local ap  = anchorFrame.AbsolutePosition
        local as  = anchorFrame.AbsoluteSize
        local sw  = screenGui.AbsoluteSize.X
        local sh  = screenGui.AbsoluteSize.Y
        local phh = panel.AbsoluteSize.Y
        local x = (ap.X + as.X + 4 + PANEL_W <= sw)
                  and (ap.X + as.X + 4)
                  or  (ap.X - PANEL_W - 4)
        local y = math.clamp(ap.Y, 0, math.max(0, sh - phh - 4))
        panel.Position = UDim2.new(0, x, 0, y)
    end

    local function closePanel()
        if not open then return end
        open = false
        cursorInPanel = false
        if posConn then posConn:Disconnect(); posConn = nil end
        TweenService:Create(panel, TWEEN_FAST, {Size=UDim2.new(0,PANEL_W,0,0)}):Play()
        task.delay(0.14, function() if not open then panel.Visible = false end end)
        playClick()
    end

    local function openPanel()
        if open then return end
        open = true
        reposition()
        panel.Visible = true
        local h = math.min(24 + layout.AbsoluteContentSize.Y + 16, 400)
        TweenService:Create(panel, TWEEN_FAST, {Size=UDim2.new(0,PANEL_W,0,h)}):Play()
        posConn = RunService.Heartbeat:Connect(reposition)
        playClick()
    end

    phClose.MouseButton1Click:Connect(closePanel)

    if addCleanup then
        addCleanup(UserInputService.InputBegan:Connect(function(input)
            if not open then return end
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
            task.defer(function()
                if not open or sliderDragging or cursorInPanel then return end
                -- Verifica também se ainda está sobre o anchorFrame (gear btn)
                local mp = UserInputService:GetMouseLocation()
                local ap = anchorFrame and anchorFrame.AbsolutePosition or Vector2.new(-9999,-9999)
                local as = anchorFrame and anchorFrame.AbsoluteSize     or Vector2.new(0,0)
                local inAnchor = mp.X>=ap.X and mp.X<=ap.X+as.X and mp.Y>=ap.Y and mp.Y<=ap.Y+as.Y
                if not inAnchor then closePanel() end
            end)
        end))
        addCleanup(function() closePanel() end)
    end

    -- ── API pública ───────────────────────────────────────────────────────────
    local panelAPI = {}
    local rowOrder = 0
    local function nextOrd() rowOrder = rowOrder + 1; return rowOrder end

    local function makeRow(h)
        local row = Instance.new("Frame")
        row.Size               = UDim2.new(1,0,0,h or 22)
        row.BackgroundTransparency = 1
        row.LayoutOrder        = nextOrd()
        row.ZIndex             = PANEL_ZIDX+2
        row.Parent             = scroll
        return row
    end

    local function makeRowLbl(parent, text, wScale)
        local lbl = Instance.new("TextLabel")
        lbl.Size               = UDim2.new(wScale or 0.44, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text               = text
        lbl.TextColor3         = theme.TextMuted
        lbl.Font               = Enum.Font.Garamond
        lbl.TextSize           = 13
        lbl.TextXAlignment     = Enum.TextXAlignment.Left
        lbl.TextTruncate       = Enum.TextTruncate.AtEnd
        lbl.ZIndex             = PANEL_ZIDX+3
        lbl.Parent             = parent
        return lbl
    end

    local function makeWidgetZone(parent, xScale)
        local z = Instance.new("Frame")
        z.Size               = UDim2.new(1-(xScale or 0.44), 0, 1, 0)
        z.Position           = UDim2.new(xScale or 0.44, 0, 0, 0)
        z.BackgroundTransparency = 1
        z.ZIndex             = PANEL_ZIDX+3
        z.Parent             = parent
        return z
    end

    function panelAPI:AddSection(title)
        local row = makeRow(20)
        row.BackgroundColor3       = theme.ConfigSectionBg
        row.BackgroundTransparency = 0
        local lbl = Instance.new("TextLabel")
        lbl.Size               = UDim2.new(1,-8,1,0)
        lbl.Position           = UDim2.new(0,8,0,0)
        lbl.BackgroundTransparency = 1
        lbl.Text               = title
        lbl.TextColor3         = theme.TextActive
        lbl.Font               = Enum.Font.Garamond
        lbl.TextSize           = 12
        lbl.TextXAlignment     = Enum.TextXAlignment.Left
        lbl.ZIndex             = PANEL_ZIDX+3
        lbl.Parent             = row
        return row
    end

    function panelAPI:AddSeparator()
        local row = makeRow(1)
        row.BackgroundColor3       = theme.BorderInactive
        row.BackgroundTransparency = 0
        return row
    end

    function panelAPI:AddLabel(text)
        local row = makeRow(18)
        local lbl = Instance.new("TextLabel")
        lbl.Size               = UDim2.new(1,0,1,0)
        lbl.BackgroundTransparency = 1
        lbl.Text               = text
        lbl.TextColor3         = theme.TextNormal
        lbl.Font               = Enum.Font.Garamond
        lbl.TextSize           = 13
        lbl.TextXAlignment     = Enum.TextXAlignment.Left
        lbl.TextWrapped        = true
        lbl.ZIndex             = PANEL_ZIDX+3
        lbl.Parent             = row
        local api = {}
        function api:SetText(t) lbl.Text = t end
        return api
    end

    function panelAPI:AddToggle(labelText, default, cb)
        local row  = makeRow(22)
        makeRowLbl(row, labelText)
        local zone = makeWidgetZone(row)

        local box = Instance.new("TextButton")
        box.Size             = UDim2.new(0,14,0,14)
        box.Position         = UDim2.new(0,0,0.5,-7)
        box.BackgroundColor3 = theme.MainBackground
        box.Text             = ""
        box.BorderSizePixel  = 0
        box.ZIndex           = PANEL_ZIDX+4
        box.Parent           = zone

        local bStroke = Instance.new("UIStroke")
        bStroke.Thickness = 1; bStroke.Color = theme.BorderInactive; bStroke.Parent = box

        local mark = Instance.new("TextLabel")
        mark.Size               = UDim2.new(1,0,1,0)
        mark.BackgroundTransparency = 1
        mark.Text               = "X"
        mark.TextColor3         = theme.ToggleXColor
        mark.Font               = Enum.Font.Garamond
        mark.TextSize           = 13
        mark.Visible            = default or false
        mark.ZIndex             = PANEL_ZIDX+5
        mark.Parent             = box

        local value     = default or false
        local callbacks = {}
        if cb then table.insert(callbacks, cb) end

        local function setVal(state)
            value           = state
            mark.Visible    = state
            bStroke.Color   = state and theme.BorderColor or theme.BorderInactive
            for _,fn in ipairs(callbacks) do task.spawn(fn, state) end
        end

        box.MouseButton1Click:Connect(function() playClick(); setVal(not value) end)
        box.MouseEnter:Connect(function()
            playHover()
            if not value then bStroke.Color = theme.BorderColor end
        end)
        box.MouseLeave:Connect(function()
            if not value then bStroke.Color = theme.BorderInactive end
        end)

        local api = { Value = value }
        function api:SetValue(v) setVal(v); self.Value = v end
        function api:OnChanged(fn) table.insert(callbacks, fn) end
        table.insert(callbacks, function(v) api.Value = v end)
        return api
    end

    function panelAPI:AddSlider(labelText, min, max, default, rounding, cb)
        rounding = rounding or 0
        local row = makeRow(30)

        local lbl = Instance.new("TextLabel")
        lbl.Size               = UDim2.new(1,0,0,14)
        lbl.BackgroundTransparency = 1
        lbl.Text               = (labelText ~= "" and labelText..": " or "")..tostring(default)
        lbl.TextColor3         = theme.TextNormal
        lbl.Font               = Enum.Font.Garamond
        lbl.TextSize           = 13
        lbl.TextXAlignment     = Enum.TextXAlignment.Left
        lbl.ZIndex             = PANEL_ZIDX+3
        lbl.Parent             = row

        local track = Instance.new("TextButton")
        track.Size             = UDim2.new(1,0,0,4)
        track.Position         = UDim2.new(0,0,0,18)
        track.BackgroundColor3 = theme.MainBackground
        track.Text             = ""
        track.BorderSizePixel  = 0
        track.ZIndex           = PANEL_ZIDX+3
        track.Parent           = row

        local tStroke = Instance.new("UIStroke")
        tStroke.Thickness=1; tStroke.Color=theme.BorderInactive; tStroke.Parent=track

        local p0   = (default-min)/(max-min)
        local fill = Instance.new("Frame")
        fill.Size             = UDim2.new(p0,0,1,0)
        fill.BackgroundColor3 = theme.BorderColor
        fill.BorderSizePixel  = 0
        fill.ZIndex           = PANEL_ZIDX+4
        fill.Parent           = track

        local knob = Instance.new("Frame")
        knob.Size             = UDim2.new(0,8,0,10)
        knob.Position         = UDim2.new(p0,-4,0.5,-5)
        knob.BackgroundColor3 = theme.TextActive
        knob.BorderSizePixel  = 0
        knob.ZIndex           = PANEL_ZIDX+5
        knob.Parent           = track

        local callbacks = {}
        if cb then table.insert(callbacks, cb) end
        local value    = default
        local dragging = false

        local function setSlider(v)
            v = math.clamp(v,min,max)
            if rounding==0 then v=math.round(v)
            else v=tonumber(string.format("%."..rounding.."f",v)) end
            value    = v
            lbl.Text = (labelText ~= "" and labelText..": " or "")..tostring(v)
            local p  = (v-min)/(max-min)
            fill.Size     = UDim2.new(p,0,1,0)
            knob.Position = UDim2.new(p,-4,0.5,-5)
            for _,fn in ipairs(callbacks) do task.spawn(fn,v) end
        end

        local function updateDrag(input)
            local rx = input.Position.X - track.AbsolutePosition.X
            setSlider(min + math.clamp(rx/track.AbsoluteSize.X,0,1)*(max-min))
        end

        track.InputBegan:Connect(function(input)
            if input.UserInputType==Enum.UserInputType.MouseButton1
            or input.UserInputType==Enum.UserInputType.Touch then
                dragging=true; sliderDragging=true; updateDrag(input); playClick()
            end
        end)
        addCleanup(UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType==Enum.UserInputType.MouseButton1
            or input.UserInputType==Enum.UserInputType.Touch then
                dragging=false; sliderDragging=false
            end
        end))
        addCleanup(UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType==Enum.UserInputType.MouseMovement
            or input.UserInputType==Enum.UserInputType.Touch) then updateDrag(input) end
        end))

        local api = { Value = value }
        function api:SetValue(v) setSlider(v) end
        function api:OnChanged(fn) table.insert(callbacks,fn) end
        table.insert(callbacks, function(v) api.Value=v end)
        return api
    end

    function panelAPI:AddColorPicker(labelText, default, cb)
        default = default or Color3.fromRGB(255,255,255)
        local swatchRow = makeRow(22)
        makeRowLbl(swatchRow, labelText)
        local zone = makeWidgetZone(swatchRow)

        local swatch = Instance.new("TextButton")
        swatch.Size             = UDim2.new(0,18,0,14)
        swatch.Position         = UDim2.new(0,0,0.5,-7)
        swatch.BackgroundColor3 = default
        swatch.Text             = ""
        swatch.BorderSizePixel  = 0
        swatch.ZIndex           = PANEL_ZIDX+4
        swatch.Parent           = zone

        local swStroke = Instance.new("UIStroke")
        swStroke.Thickness=1; swStroke.Color=theme.BorderInactive; swStroke.Parent=swatch

        local function toHex(c)
            return string.format("#%02X%02X%02X",
                math.floor(c.R*255+.5), math.floor(c.G*255+.5), math.floor(c.B*255+.5))
        end

        local hexLbl = Instance.new("TextLabel")
        hexLbl.Size               = UDim2.new(1,-22,1,0)
        hexLbl.Position           = UDim2.new(0,22,0,0)
        hexLbl.BackgroundTransparency = 1
        hexLbl.Text               = toHex(default)
        hexLbl.TextColor3         = theme.TextMuted
        hexLbl.Font               = Enum.Font.Garamond
        hexLbl.TextSize           = 11
        hexLbl.TextXAlignment     = Enum.TextXAlignment.Left
        hexLbl.ZIndex             = PANEL_ZIDX+4
        hexLbl.Parent             = zone

        local gridRow = makeRow(0)
        gridRow.ClipsDescendants = true

        local grid = Instance.new("UIGridLayout")
        grid.CellSize    = UDim2.new(0,22,0,16)
        grid.CellPadding = UDim2.new(0,3,0,3)
        grid.SortOrder   = Enum.SortOrder.LayoutOrder
        grid.Parent      = gridRow

        local gPad = Instance.new("UIPadding")
        gPad.PaddingTop    = UDim.new(0,3)
        gPad.PaddingBottom = UDim.new(0,3)
        gPad.Parent        = gridRow

        local callbacks = {}
        if cb then table.insert(callbacks, cb) end
        local value    = default
        local expanded = false
        local GRID_H   = math.ceil(#COLOR_PRESETS/5) * 19 + 6

        local function setColor(color)
            value                   = color
            swatch.BackgroundColor3 = color
            hexLbl.Text             = toHex(color)
            for _,fn in ipairs(callbacks) do task.spawn(fn, color) end
        end

        for _,color in ipairs(COLOR_PRESETS) do
            local btn = Instance.new("TextButton")
            btn.BackgroundColor3 = color; btn.Text=""; btn.BorderSizePixel=0
            btn.ZIndex = PANEL_ZIDX+4; btn.Parent = gridRow
            local bs = Instance.new("UIStroke")
            bs.Thickness=1; bs.Color=theme.BorderInactive; bs.Parent=btn
            btn.MouseEnter:Connect(function()  bs.Color=theme.BorderColor end)
            btn.MouseLeave:Connect(function()  bs.Color=theme.BorderInactive end)
            btn.MouseButton1Click:Connect(function()
                setColor(color); playClick(); expanded=false
                TweenService:Create(gridRow,TWEEN_FAST,{Size=UDim2.new(1,0,0,0)}):Play()
                swStroke.Color = theme.BorderInactive
            end)
        end

        swatch.MouseEnter:Connect(function()  swStroke.Color=theme.BorderColor; playHover() end)
        swatch.MouseLeave:Connect(function()
            if not expanded then swStroke.Color=theme.BorderInactive end
        end)
        swatch.MouseButton1Click:Connect(function()
            expanded = not expanded; playClick()
            TweenService:Create(gridRow,TWEEN_FAST,{Size=UDim2.new(1,0,0,expanded and GRID_H or 0)}):Play()
            swStroke.Color = expanded and theme.BorderColor or theme.BorderInactive
        end)

        local api = { Value = value }
        function api:SetValue(c)    setColor(c) end
        function api:SetValueRGB(c) setColor(c) end
        function api:OnChanged(fn)  table.insert(callbacks,fn) end
        table.insert(callbacks, function(v) api.Value=v end)
        return api
    end

    function panelAPI:AddDropdown(labelText, values, multi, default, cb)
        local row = makeRow(38)

        local lbl = Instance.new("TextLabel")
        lbl.Size               = UDim2.new(1,0,0,14)
        lbl.BackgroundTransparency = 1
        lbl.Text               = labelText
        lbl.TextColor3         = theme.TextNormal
        lbl.Font               = Enum.Font.Garamond
        lbl.TextSize           = 13
        lbl.TextXAlignment     = Enum.TextXAlignment.Left
        lbl.ZIndex             = PANEL_ZIDX+3
        lbl.Parent             = row

        local selected = {}
        if multi then
            if type(default)=="table" then for _,v in ipairs(default) do selected[v]=true end
            elseif default~=nil then selected[default]=true end
        else selected[default or values[1]]=true end

        local function displayText()
            if multi then
                local t={}
                for _,v in ipairs(values) do if selected[v] then t[#t+1]=tostring(v) end end
                return #t>0 and table.concat(t,", ") or "Select..."
            else
                for v,s in pairs(selected) do if s then return tostring(v) end end
                return "Select..."
            end
        end

        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(1,0,0,20)
        btn.Position         = UDim2.new(0,0,0,18)
        btn.BackgroundColor3 = theme.MainBackground
        btn.Text             = displayText()
        btn.TextColor3       = theme.TextActive
        btn.Font             = Enum.Font.Garamond
        btn.TextSize         = 13
        btn.TextTruncate     = Enum.TextTruncate.AtEnd
        btn.BorderSizePixel  = 0
        btn.ZIndex           = PANEL_ZIDX+4
        btn.Parent           = row

        local bStroke = Instance.new("UIStroke")
        bStroke.Thickness=1; bStroke.Color=theme.BorderInactive; bStroke.Parent=btn

        local menuFrame = Instance.new("Frame")
        menuFrame.BackgroundColor3 = theme.GroupBackground
        menuFrame.BorderSizePixel  = 0
        menuFrame.Visible          = false
        menuFrame.ZIndex           = PANEL_ZIDX+10
        menuFrame.Parent           = screenGui

        local mStroke = Instance.new("UIStroke")
        mStroke.Thickness=1; mStroke.Color=theme.BorderColor; mStroke.Parent=menuFrame

        local mScroll = Instance.new("ScrollingFrame")
        mScroll.Size               = UDim2.new(1,0,1,0)
        mScroll.BackgroundTransparency = 1
        mScroll.BorderSizePixel    = 0
        mScroll.ScrollBarThickness = 3
        mScroll.ScrollBarImageColor3 = theme.BorderColor
        mScroll.CanvasSize         = UDim2.new(0,0,0,0)
        mScroll.ZIndex             = PANEL_ZIDX+11
        mScroll.Parent             = menuFrame

        local mLayout = Instance.new("UIListLayout")
        mLayout.SortOrder = Enum.SortOrder.LayoutOrder; mLayout.Parent = mScroll

        local callbacks   = {}
        if cb then table.insert(callbacks, cb) end
        local dropOpen    = false
        local dropPosConn = nil

        local function getVal()
            if multi then
                local r={}
                for _,v in ipairs(values) do if selected[v] then r[#r+1]=v; r[v]=true end end
                return r
            else
                for v,s in pairs(selected) do if s then return v end end
                return nil
            end
        end

        local function closeMenu()
            if not dropOpen then return end
            dropOpen = false; menuFrame.Visible=false
            bStroke.Color = theme.BorderInactive
            if dropPosConn then dropPosConn:Disconnect(); dropPosConn=nil end
        end

        local function posMenu()
            local ap=btn.AbsolutePosition; local as=btn.AbsoluteSize
            menuFrame.Position = UDim2.new(0,ap.X,0,ap.Y+as.Y+1)
            menuFrame.Size     = UDim2.new(0,as.X,0,math.min(#values*20,140))
            mScroll.CanvasSize = UDim2.new(0,0,0,#values*20)
        end

        local function populateMenu()
            for _,c in ipairs(mScroll:GetChildren()) do
                if c:IsA("TextButton") then c:Destroy() end
            end
            for _,optVal in ipairs(values) do
                local opt = Instance.new("TextButton")
                opt.Size             = UDim2.new(1,0,0,20)
                opt.BackgroundColor3 = theme.GroupBackground
                opt.BorderSizePixel  = 0
                opt.Text             = tostring(optVal)
                opt.TextColor3       = selected[optVal] and theme.TextActive or theme.TextNormal
                opt.Font             = Enum.Font.Garamond
                opt.TextSize         = 13
                opt.TextTruncate     = Enum.TextTruncate.AtEnd
                opt.ZIndex           = PANEL_ZIDX+12
                opt.Parent           = mScroll
                opt.MouseEnter:Connect(function() opt.TextColor3=theme.TextActive; playHover() end)
                opt.MouseLeave:Connect(function()
                    if not selected[optVal] then opt.TextColor3=theme.TextNormal end
                end)
                opt.MouseButton1Click:Connect(function()
                    if multi then
                        selected[optVal]=not selected[optVal]
                        opt.TextColor3=selected[optVal] and theme.TextActive or theme.TextNormal
                        btn.Text=displayText(); playClick()
                        local v=getVal()
                        for _,fn in ipairs(callbacks) do task.spawn(fn,v) end
                    else
                        selected={}; selected[optVal]=true
                        btn.Text=tostring(optVal); closeMenu(); populateMenu()
                        for _,fn in ipairs(callbacks) do task.spawn(fn,optVal) end
                    end
                end)
            end
        end
        populateMenu()

        btn.MouseButton1Click:Connect(function()
            dropOpen = not dropOpen
            if dropOpen then
                posMenu(); menuFrame.Visible=true
                bStroke.Color=theme.BorderColor
                dropPosConn=RunService.Heartbeat:Connect(posMenu)
            else closeMenu() end
            playClick()
        end)

        UserInputService.InputBegan:Connect(function(input)
            if not dropOpen then return end
            if input.UserInputType~=Enum.UserInputType.MouseButton1 then return end
            task.defer(function()
                if not dropOpen then return end
                local mp=UserInputService:GetMouseLocation()
                local mp2=menuFrame.AbsolutePosition; local ms=menuFrame.AbsoluteSize
                local bp2=btn.AbsolutePosition;       local bs2=btn.AbsoluteSize
                local inM=mp.X>=mp2.X and mp.X<=mp2.X+ms.X and mp.Y>=mp2.Y and mp.Y<=mp2.Y+ms.Y
                local inB=mp.X>=bp2.X and mp.X<=bp2.X+bs2.X and mp.Y>=bp2.Y and mp.Y<=bp2.Y+bs2.Y
                if not inM and not inB then closeMenu() end
            end)
        end)

        local api = { Value=getVal(), Values=values }
        function api:SetValue(v)
            if multi then
                selected={}
                if type(v)=="table" then for _,x in ipairs(v) do selected[x]=true end
                else selected[v]=true end
            else selected={}; selected[v]=true end
            btn.Text=displayText(); populateMenu()
            local fv=getVal(); self.Value=fv
            for _,fn in ipairs(callbacks) do task.spawn(fn,fv) end
        end
        function api:SetValues(nv) values=nv; populateMenu() end
        function api:OnChanged(fn)  table.insert(callbacks,fn) end
        table.insert(callbacks, function(v) api.Value=v end)
        return api
    end

    function panelAPI:AddKeybind(labelText, defaultKey, cb)
        local row  = makeRow(22)
        makeRowLbl(row, labelText)
        local zone = makeWidgetZone(row)

        local curKey = (typeof(defaultKey)=="EnumItem") and defaultKey
                       or (defaultKey and Enum.KeyCode[tostring(defaultKey)]) or Enum.KeyCode.Unknown

        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(1,0,0,16)
        btn.Position         = UDim2.new(0,0,0.5,-8)
        btn.BackgroundColor3 = theme.MainBackground
        btn.Text             = "["..curKey.Name.."]"
        btn.TextColor3       = theme.TextActive
        btn.Font             = Enum.Font.Garamond
        btn.TextSize         = 12
        btn.BorderSizePixel  = 0
        btn.ZIndex           = PANEL_ZIDX+4
        btn.Parent           = zone

        local bStroke = Instance.new("UIStroke")
        bStroke.Thickness=1; bStroke.Color=theme.BorderInactive; bStroke.Parent=btn

        local callbacks  = {}
        if cb then table.insert(callbacks, cb) end
        local listening  = false
        local listenConn = nil

        local function stopListening(newKey)
            listening       = false
            curKey          = newKey
            btn.Text        = "["..newKey.Name.."]"
            btn.TextColor3  = theme.TextActive
            bStroke.Color   = theme.BorderInactive
            if listenConn then listenConn:Disconnect(); listenConn=nil end
            for _,fn in ipairs(callbacks) do task.spawn(fn,newKey) end
        end

        btn.MouseEnter:Connect(function() bStroke.Color=theme.BorderColor; playHover() end)
        btn.MouseLeave:Connect(function() if not listening then bStroke.Color=theme.BorderInactive end end)
        btn.MouseButton1Click:Connect(function()
            if listening then return end
            playClick(); listening=true
            btn.Text="[...]"; btn.TextColor3=theme.TextNormal
            bStroke.Color=theme.BorderColor
            listenConn=UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType==Enum.UserInputType.Keyboard then
                    stopListening(input.KeyCode)
                end
            end)
        end)

        local api = { Value=curKey }
        function api:SetValue(k) stopListening(k) end
        function api:OnChanged(fn) table.insert(callbacks,fn) end
        table.insert(callbacks, function(v) api.Value=v end)
        return api
    end

    function panelAPI:AddModeSelect(labelText, options, defaultIdx, cb)
        local row  = makeRow(22)
        makeRowLbl(row, labelText)
        local zone = makeWidgetZone(row)

        local idx = defaultIdx or 1
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(1,0,0,16)
        btn.Position         = UDim2.new(0,0,0.5,-8)
        btn.BackgroundColor3 = theme.MainBackground
        btn.Text             = options[idx] or options[1]
        btn.TextColor3       = theme.TextActive
        btn.Font             = Enum.Font.Garamond
        btn.TextSize         = 12
        btn.BorderSizePixel  = 0
        btn.ZIndex           = PANEL_ZIDX+4
        btn.Parent           = zone

        local bStroke = Instance.new("UIStroke")
        bStroke.Thickness=1; bStroke.Color=theme.BorderInactive; bStroke.Parent=btn

        local callbacks = {}
        if cb then table.insert(callbacks, cb) end

        btn.MouseEnter:Connect(function() bStroke.Color=theme.BorderColor; playHover() end)
        btn.MouseLeave:Connect(function() bStroke.Color=theme.BorderInactive end)
        btn.MouseButton1Click:Connect(function()
            idx=(idx % #options)+1
            btn.Text=options[idx]; playClick()
            for _,fn in ipairs(callbacks) do task.spawn(fn,idx,options[idx]) end
        end)

        local api = { Value=options[idx] }
        function api:SetIndex(i) idx=i; btn.Text=options[i]; api.Value=options[i] end
        function api:OnChanged(fn) table.insert(callbacks,fn) end
        table.insert(callbacks, function(_,v) api.Value=v end)
        return api
    end

    function panelAPI:Open()    openPanel()  end
    function panelAPI:Close()   closePanel() end
    function panelAPI:IsOpen()  return open  end
    function panelAPI:Destroy() closePanel(); panel:Destroy() end
    panelAPI.Frame = panel

    return panelAPI
end

