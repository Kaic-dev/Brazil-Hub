local function makeGearBtn(parent, theme, anchorPoint, position)
    local gear = Instance.new("TextButton")
    gear.Size               = UDim2.new(0,14,0,14)
    gear.AnchorPoint        = anchorPoint or Vector2.new(1,0.5)
    gear.Position           = position    or UDim2.new(1,-2,0.5,0)
    gear.BackgroundTransparency = 1
    gear.Text               = "⚙"
    gear.TextColor3         = theme.TextMuted
    gear.Font               = Enum.Font.Garamond
    gear.TextSize           = 13
    gear.ZIndex             = 15
    gear.Parent             = parent
    gear.MouseEnter:Connect(function() gear.TextColor3=theme.TextActive; playHover() end)
    gear.MouseLeave:Connect(function() gear.TextColor3=theme.TextMuted end)
    return gear
end

