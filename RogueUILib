    mainWindow.Size             = UDim2.new(0,570,0,420)
    mainWindow.Position         = UDim2.new(0.5,-285,0.5,-210)
    mainWindow.BackgroundColor3 = self.Theme.MainBackground
    mainWindow.BorderSizePixel  = 0
