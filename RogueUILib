                local mark = Instance.new("TextLabel")
                mark.Name               = "Mark"
                mark.Size               = UDim2.new(1,0,1,0)
                mark.BackgroundTransparency = 1
                mark.Text               = "X"
                mark.TextColor3         = RogueUI.Theme.ToggleXColor
                mark.Font               = Enum.Font.Garamond
                mark.TextSize           = 13
                mark.Visible            = default
                mark.Parent             = box

                local lblRPad = hasKeybind and -52 or -20
                local lbl = Instance.new("TextButton")
                lbl.Name               = "Label"
                lbl.Size               = UDim2.new(1,lblRPad,1,0)
                lbl.Position           = UDim2.new(0,22,0,0)
                lbl.BackgroundTransparency = 1
                lbl.Text               = text
                lbl.TextColor3         = default and RogueUI.Theme.TextActive or RogueUI.Theme.TextNormal
                lbl.Font               = Enum.Font.Garamond
                lbl.TextSize           = 15
                lbl.TextTruncate       = Enum.TextTruncate.AtEnd
                lbl.TextXAlignment     = Enum.TextXAlignment.Left
                lbl.Parent             = tFrame

                -- Badge de keybind
                local kbBadge, kbBadgeStroke
                if hasKeybind then
                    kbBadge = Instance.new("TextButton")
                    kbBadge.Size             = UDim2.new(0,30,0,12)
                    kbBadge.AnchorPoint      = Vector2.new(1,0.5)
                    kbBadge.Position         = UDim2.new(1,-18,0.5,0)
                    kbBadge.BackgroundColor3 = RogueUI.Theme.MainBackground
                    kbBadge.BorderSizePixel  = 0
                    kbBadge.Font             = Enum.Font.Garamond
                    kbBadge.TextSize         = 10
                    kbBadge.ZIndex           = 11
                    kbBadge.Parent           = tFrame

                    kbBadgeStroke = Instance.new("UIStroke")
                    kbBadgeStroke.Thickness = 1
                    kbBadgeStroke.Color     = RogueUI.Theme.BorderInactive
                    kbBadgeStroke.Parent    = kbBadge

                    if defKey then
                        toggleData.KeybindKey     = defKey
                        toggleData.KeybindEnabled = true
                    end
                end

                local function refreshBadge()
                    if not kbBadge then return end
                    if toggleData.KeybindEnabled and toggleData.KeybindKey then
                        local kn = typeof(toggleData.KeybindKey)=="EnumItem"
                                   and toggleData.KeybindKey.Name
                                   or tostring(toggleData.KeybindKey)
                        kbBadge.Text      = kn
                        kbBadge.TextColor3 = RogueUI.Theme.TextActive
                        kbBadgeStroke.Color = RogueUI.Theme.BorderColor
                    else
                        kbBadge.Text       = "–"
                        kbBadge.TextColor3 = RogueUI.Theme.TextMuted
                        kbBadgeStroke.Color = RogueUI.Theme.BorderInactive
                    end
                end
                if hasKeybind then refreshBadge() end
                toggleData._refreshBadge = refreshBadge

                local function setVal(state)
                    toggleData.Value  = state
                    mark.Visible      = state
                    lbl.TextColor3    = state and RogueUI.Theme.TextActive or RogueUI.Theme.TextNormal
                    bStroke.Color     = state and RogueUI.Theme.BorderColor or RogueUI.Theme.BorderInactive
                    for _,fn in ipairs(toggleData.OnChangedCallbacks) do task.spawn(fn,state) end
                end

                if hasKeybind then
                    addCleanup(UserInputService.InputBegan:Connect(function(input)
                        if UserInputService:GetFocusedTextBox() then return end
                        if not toggleData.KeybindEnabled or not toggleData.KeybindKey then return end
                        if input.UserInputType~=Enum.UserInputType.Keyboard then return end
                        if input.KeyCode~=toggleData.KeybindKey then return end
                        if toggleData.KeybindMode=="Toggle" then setVal(not toggleData.Value)
                        elseif toggleData.KeybindMode=="Hold" then setVal(true) end
                    end))
                    addCleanup(UserInputService.InputEnded:Connect(function(input)
                        if not toggleData.KeybindEnabled or not toggleData.KeybindKey then return end
                        if toggleData.KeybindMode~="Hold" then return end
                        if input.UserInputType~=Enum.UserInputType.Keyboard then return end
                        if input.KeyCode~=toggleData.KeybindKey then return end
                        setVal(false)
                    end))
                end

                local function fire() playClick(); setVal(not toggleData.Value) end
                box.MouseButton1Click:Connect(fire)
                lbl.MouseButton1Click:Connect(fire)

                box.MouseEnter:Connect(function()
                    playHover()
                    if not toggleData.Value then bStroke.Color=RogueUI.Theme.BorderColor end
                end)
                box.MouseLeave:Connect(function()
                    if not toggleData.Value then bStroke.Color=RogueUI.Theme.BorderInactive end
                end)
                lbl.MouseEnter:Connect(function()
                    playHover()
                    if not toggleData.Value then
                        lbl.TextColor3=RogueUI.Theme.TextActive
                        bStroke.Color=RogueUI.Theme.BorderColor
                    end
                end)
                lbl.MouseLeave:Connect(function()
                    if not toggleData.Value then
                        lbl.TextColor3=RogueUI.Theme.TextNormal
                        bStroke.Color=RogueUI.Theme.BorderInactive
                    end
                end)

                -- ── :ConfigPanel(builderFn) ───────────────────────────────────
                local panelInst = nil

                function toggleData:ConfigPanel(builderFn)
                    if panelInst then return panelInst end

                    local gear = makeGearBtn(tFrame, RogueUI.Theme)

                    if kbBadge then
                        kbBadge.MouseButton1Click:Connect(function()
                            if panelInst:IsOpen() then panelInst:Close() else panelInst:Open() end
                        end)
                    end

                    panelInst = createRichConfigPanel(
                        screenGui, tFrame, text, RogueUI.Theme, addCleanup)
                    toggleData._configPanel = panelInst

                    gear.MouseButton1Click:Connect(function()
                        if panelInst:IsOpen() then panelInst:Close() else panelInst:Open() end
                    end)

                    -- Seção Estado
                    panelInst:AddSection("Estado")
                    local stToggle = panelInst:AddToggle("Ativado", default, function(v) setVal(v) end)
                    table.insert(toggleData.OnChangedCallbacks, function(v) stToggle:SetValue(v) end)

                    -- Seção Keybind
                    if hasKeybind then
                        panelInst:AddSeparator()
                        panelInst:AddSection("Keybind")

                        local kbEnabled = panelInst:AddModeSelect(
                            "Status", {"Ativo","Inativo"},
                            toggleData.KeybindEnabled and 1 or 2,
                            function(idx)
                                toggleData.KeybindEnabled = (idx==1)
                                refreshBadge()
                            end)

                        panelInst:AddKeybind(
                            "Tecla",
                            toggleData.KeybindKey or Enum.KeyCode.Unknown,
                            function(newKey)
                                toggleData.KeybindKey     = newKey
                                toggleData.KeybindEnabled = true
                                kbEnabled:SetIndex(1)
                                refreshBadge()
                            end)

                        panelInst:AddModeSelect(
                            "Modo", {"Toggle","Hold"}, 1,
                            function(_,val) toggleData.KeybindMode=val end)
                    end

                    -- Builder do CoreManager
                    if type(builderFn)=="function" then
                        panelInst:AddSeparator()
                        builderFn(panelInst)
                    end

                    return panelInst
                end

                function toggleData:SetValue(state) setVal(state) end
                function toggleData:OnChanged(fn)
                    table.insert(toggleData.OnChangedCallbacks, fn)
                end

                return toggleData
            end

            -- ── Slider ────────────────────────────────────────────────────────
            function group_Self:AddSlider(id, opts)
                local text     = opts.Text     or id
                local min      = opts.Min      or 0
                local max      = opts.Max      or 100
                local default  = opts.Default  or min
                local cb       = opts.Callback or function() end
                local rounding = opts.Rounding or 0

                local sFrame = Instance.new("Frame")
                sFrame.Name               = id.."Slider"
                sFrame.Size               = UDim2.new(1,0,0,30)
                sFrame.BackgroundTransparency = 1
                sFrame.Parent             = content

                local lbl = Instance.new("TextLabel")
                lbl.Size               = UDim2.new(1,-16,0,14)
                lbl.BackgroundTransparency = 1
                lbl.Text               = text..": "..tostring(default)
                lbl.TextColor3         = RogueUI.Theme.TextNormal
                lbl.Font               = Enum.Font.Garamond
                lbl.TextSize           = 15
                lbl.TextTruncate       = Enum.TextTruncate.AtEnd
                lbl.TextXAlignment     = Enum.TextXAlignment.Left
                lbl.Parent             = sFrame

                local track = Instance.new("TextButton")
                track.Name             = "Track"
                track.Size             = UDim2.new(1,0,0,4)
                track.Position         = UDim2.new(0,0,0,20)
                track.BackgroundColor3 = RogueUI.Theme.MainBackground
                track.Text             = ""
                track.BorderSizePixel  = 0
                track.Parent           = sFrame

                local tStroke = Instance.new("UIStroke")
                tStroke.Thickness=1; tStroke.Color=RogueUI.Theme.BorderInactive; tStroke.Parent=track

                local p0   = (default-min)/(max-min)
                local fill = Instance.new("Frame")
                fill.Size             = UDim2.new(p0,0,1,0)
                fill.BackgroundColor3 = RogueUI.Theme.BorderColor
                fill.BorderSizePixel  = 0
                fill.Parent           = track

                local knob = Instance.new("Frame")
                knob.Size             = UDim2.new(0,8,0,10)
                knob.Position         = UDim2.new(p0,-4,0.5,-5)
                knob.BackgroundColor3 = RogueUI.Theme.TextActive
                knob.BorderSizePixel  = 0
                knob.Parent           = track

                local sliderData = { Value=default, OnChangedCallbacks={ cb } }
                RogueUI.Sliders[id] = sliderData

                local function setSlider(v)
                    v=math.clamp(v,min,max)
                    if rounding==0 then v=math.round(v)
                    else v=tonumber(string.format("%."..rounding.."f",v)) end
                    sliderData.Value = v
                    lbl.Text         = text..": "..tostring(v)
                    local p          = (v-min)/(max-min)
                    fill.Size        = UDim2.new(p,0,1,0)
                    knob.Position    = UDim2.new(p,-4,0.5,-5)
                    for _,fn in ipairs(sliderData.OnChangedCallbacks) do task.spawn(fn,v) end
                end

                local dragging = false
                local function updateDrag(input)
                    local rx = input.Position.X - track.AbsolutePosition.X
                    setSlider(min + math.clamp(rx/track.AbsoluteSize.X,0,1)*(max-min))
                end

                addCleanup(track.InputBegan:Connect(function(input)
                    if input.UserInputType==Enum.UserInputType.MouseButton1
                    or input.UserInputType==Enum.UserInputType.Touch then
                        dragging=true; updateDrag(input); playClick()
                    end
                end))
                addCleanup(UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType==Enum.UserInputType.MouseButton1
                    or input.UserInputType==Enum.UserInputType.Touch then dragging=false end
                end))
                addCleanup(UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType==Enum.UserInputType.MouseMovement
                    or input.UserInputType==Enum.UserInputType.Touch) then updateDrag(input) end
                end))

                local panelInst = nil

                function sliderData:ConfigPanel(builderFn)
                    if panelInst then return panelInst end

                    local gear = makeGearBtn(sFrame, RogueUI.Theme,
                        Vector2.new(1,0), UDim2.new(1,-2,0,0))

                    panelInst = createRichConfigPanel(
                        screenGui, sFrame, text, RogueUI.Theme, addCleanup)

                    gear.MouseButton1Click:Connect(function()
                        if panelInst:IsOpen() then panelInst:Close() else panelInst:Open() end
                    end)

                    panelInst:AddSection("Valor")
                    local valLbl   = panelInst:AddLabel(text..": "..tostring(sliderData.Value))
                    local slWidget = panelInst:AddSlider("", min, max, default, rounding,
                        function(v) setSlider(v) end)

                    -- Sincroniza ambos ao arrastar o slider da groupbox
                    table.insert(sliderData.OnChangedCallbacks, function(v)
                        valLbl:SetText(text..": "..tostring(v))
                        slWidget:SetValue(v)
                    end)

                    panelInst:AddLabel("Range: "..tostring(min).." → "..tostring(max))

                    if type(builderFn)=="function" then
                        panelInst:AddSeparator()
                        builderFn(panelInst)
                    end
                    return panelInst
                end

                function sliderData:SetValue(v) setSlider(v) end
                function sliderData:OnChanged(fn) table.insert(sliderData.OnChangedCallbacks,fn) end
                return sliderData
            end

            -- ── Dropdown ──────────────────────────────────────────────────────
            function group_Self:AddDropdown(id, opts)
                local text    = opts.Text     or id
                local values  = opts.Values   or {}
                local isMulti = opts.Multi    or false
                local default = opts.Default
                local cb      = opts.Callback or function() end

                local dFrame = Instance.new("Frame")
                dFrame.Name               = id.."Dropdown"
                dFrame.Size               = UDim2.new(1,0,0,38)
                dFrame.BackgroundTransparency = 1
                dFrame.Parent             = content

                local lbl = Instance.new("TextLabel")
                lbl.Size               = UDim2.new(1,-16,0,14)
                lbl.BackgroundTransparency = 1
                lbl.Text               = text
                lbl.TextColor3         = RogueUI.Theme.TextNormal
                lbl.Font               = Enum.Font.Garamond
                lbl.TextSize           = 15
                lbl.TextTruncate       = Enum.TextTruncate.AtEnd
                lbl.TextXAlignment     = Enum.TextXAlignment.Left
                lbl.Parent             = dFrame

                local selected = {}
                if isMulti then
                    if type(default)=="table" then for _,v in ipairs(default) do selected[v]=true end
                    elseif default~=nil then selected[default]=true end
                else selected[default or values[1]]=true end

                local function displayText()
                    if isMulti then
                        local t={}
                        for _,v in ipairs(values) do if selected[v] then t[#t+1]=tostring(v) end end
                        return #t>0 and table.concat(t,", ") or "Select..."
                    else
                        for v,s in pairs(selected) do if s then return tostring(v) end end
                        return "Select..."
                    end
                end

                local btn = Instance.new("TextButton")
                btn.Size             = UDim2.new(1,0,0,20)
                btn.Position         = UDim2.new(0,0,0,18)
                btn.BackgroundColor3 = RogueUI.Theme.MainBackground
                btn.Text             = displayText()
                btn.TextColor3       = RogueUI.Theme.TextActive
                btn.Font             = Enum.Font.Garamond
                btn.TextSize         = 15
                btn.TextTruncate     = Enum.TextTruncate.AtEnd
                btn.BorderSizePixel  = 0
                btn.Parent           = dFrame

                local bStroke = Instance.new("UIStroke")
                bStroke.Thickness=1; bStroke.Color=RogueUI.Theme.BorderInactive; bStroke.Parent=btn

                local menu = Instance.new("Frame")
                menu.Name             = id.."DDMenu"
                menu.BackgroundColor3 = RogueUI.Theme.GroupBackground
                menu.BorderSizePixel  = 0
                menu.Visible          = false
                menu.ZIndex           = 100
                menu.Parent           = screenGui

                local mStroke = Instance.new("UIStroke")
                mStroke.Thickness=1; mStroke.Color=RogueUI.Theme.BorderColor; mStroke.Parent=menu

                local mScroll = Instance.new("ScrollingFrame")
                mScroll.Size               = UDim2.new(1,0,1,0)
                mScroll.BackgroundTransparency = 1
                mScroll.BorderSizePixel    = 0
                mScroll.ScrollBarThickness = 3
                mScroll.ScrollBarImageColor3 = RogueUI.Theme.BorderColor
                mScroll.CanvasSize         = UDim2.new(0,0,0,0)
                mScroll.ZIndex             = 100
                mScroll.Parent             = menu

                local mLayout = Instance.new("UIListLayout")
                mLayout.SortOrder=Enum.SortOrder.LayoutOrder; mLayout.Parent=mScroll

                local dropData = { Value=nil, Values=values, OnChangedCallbacks={ cb } }
                RogueUI.Dropdowns[id] = dropData

                local function getVal()
                    if isMulti then
                        local r={}
                        for _,v in ipairs(values) do if selected[v] then r[#r+1]=v; r[v]=true end end
                        return r
                    else
                        for v,s in pairs(selected) do if s then return v end end
                        return nil
                    end
                end
                dropData.Value = getVal()

                local function posMenu()
                    local ap=btn.AbsolutePosition; local as=btn.AbsoluteSize
                    menu.Position = UDim2.new(0,ap.X,0,ap.Y+as.Y+1)
                    menu.Size     = UDim2.new(0,as.X,0,math.min(#dropData.Values*20,160))
                    mScroll.CanvasSize = UDim2.new(0,0,0,#dropData.Values*20)
                end

                local open=false; local posConn=nil
                local openGen=0

                local function closeMenu()
                    if not open then return end
                    open=false; openGen=openGen+1
                    menu.Visible=false
                    bStroke.Color=RogueUI.Theme.BorderInactive
                    if posConn then posConn:Disconnect(); posConn=nil end
                    if self_Window._activeDropdown == closeMenu then
                        self_Window._activeDropdown = nil
                    end
                end

                addCleanup(UserInputService.InputBegan:Connect(function(input)
                    if not open then return end
                    if input.UserInputType~=Enum.UserInputType.MouseButton1
                    and input.UserInputType~=Enum.UserInputType.Touch then return end
                    local gen = openGen
                    task.defer(function()
                        if not open or openGen ~= gen then return end
                        local mp=UserInputService:GetMouseLocation()
                        local mp2=menu.AbsolutePosition; local ms=menu.AbsoluteSize
                        local bp=btn.AbsolutePosition;   local bs=btn.AbsoluteSize
                        local inM=mp.X>=mp2.X and mp.X<=mp2.X+ms.X and mp.Y>=mp2.Y and mp.Y<=mp2.Y+ms.Y
                        local inB=mp.X>=bp.X  and mp.X<=bp.X+bs.X  and mp.Y>=bp.Y  and mp.Y<=bp.Y+bs.Y
                        if not inM and not inB then closeMenu() end
                    end)
                end))
                addCleanup(closeMenu)

                local function openMenu()
                    if self_Window._activeDropdown and self_Window._activeDropdown ~= closeMenu then
                        self_Window._activeDropdown()
                    end
                    open=true; openGen=openGen+1; self_Window._activeDropdown = closeMenu
                    posMenu(); menu.Visible=true
                    bStroke.Color=RogueUI.Theme.BorderColor
                    posConn=RunService.Heartbeat:Connect(posMenu)
                    playClick()
                end

                btn.MouseButton1Click:Connect(function()
                    if open then closeMenu(); playClick() else openMenu() end
                end)

                local function populateMenu()
                    for _,c in ipairs(mScroll:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _,optVal in ipairs(dropData.Values) do
                        local opt = Instance.new("TextButton")
                        opt.Size             = UDim2.new(1,0,0,20)
                        opt.BackgroundColor3 = RogueUI.Theme.GroupBackground
                        opt.BorderSizePixel  = 0
                        opt.Text             = tostring(optVal)
                        opt.TextColor3       = selected[optVal] and RogueUI.Theme.TextActive or RogueUI.Theme.TextNormal
                        opt.Font             = Enum.Font.Garamond
                        opt.TextSize         = 15
                        opt.TextTruncate     = Enum.TextTruncate.AtEnd
                        opt.ZIndex           = 101
                        opt.Parent           = mScroll
                        opt.MouseEnter:Connect(function() opt.TextColor3=RogueUI.Theme.TextActive; playHover() end)
                        opt.MouseLeave:Connect(function()
                            if not selected[optVal] then opt.TextColor3=RogueUI.Theme.TextNormal end
                        end)
                        opt.MouseButton1Click:Connect(function()
                            if isMulti then
                                selected[optVal]=not selected[optVal]
                                opt.TextColor3=selected[optVal] and RogueUI.Theme.TextActive or RogueUI.Theme.TextNormal
                                btn.Text=displayText(); playClick()
                                local v=getVal(); dropData.Value=v
                                for _,fn in ipairs(dropData.OnChangedCallbacks) do task.spawn(fn,v) end
                            else
                                selected={}; selected[optVal]=true
                                btn.Text=tostring(optVal); closeMenu(); populateMenu()
                                dropData.Value=optVal
                                for _,fn in ipairs(dropData.OnChangedCallbacks) do task.spawn(fn,optVal) end
                            end
                        end)
                    end
                end
                populateMenu()

                local panelInst = nil

                function dropData:ConfigPanel(builderFn)
                    if panelInst then return panelInst end

                    local gear = makeGearBtn(dFrame, RogueUI.Theme,
                        Vector2.new(1,0), UDim2.new(1,-2,0,0))

                    panelInst = createRichConfigPanel(
                        screenGui, dFrame, text, RogueUI.Theme, addCleanup)

                    gear.MouseButton1Click:Connect(function()
                        if panelInst:IsOpen() then panelInst:Close() else panelInst:Open() end
                    end)

                    panelInst:AddSection("Seleção Atual")
                    local selLbl = panelInst:AddLabel(displayText())
                    table.insert(dropData.OnChangedCallbacks, function()
                        selLbl:SetText(displayText())
                    end)

                    if type(builderFn)=="function" then
                        panelInst:AddSeparator()
                        builderFn(panelInst)
                    end
                    return panelInst
                end

                function dropData:SetValue(v)
                    if isMulti then
                        selected={}
                        if type(v)=="table" then for _,x in ipairs(v) do selected[x]=true end
                        else selected[v]=true end
                    else selected={}; selected[v]=true end
                    btn.Text=displayText(); populateMenu()
                    local fv=getVal(); self.Value=fv
                    for _,fn in ipairs(self.OnChangedCallbacks) do task.spawn(fn,fv) end
                end
                function dropData:SetValues(nv) self.Values=nv; populateMenu() end
                function dropData:OnChanged(fn) table.insert(self.OnChangedCallbacks,fn) end
                return dropData
            end

            -- ── Label ─────────────────────────────────────────────────────────
            function group_Self:AddLabel(text, isMultiLine)
                local lbl = Instance.new("TextButton")
                lbl.Name               = "Label"
                lbl.BackgroundTransparency = 1
                lbl.AutoButtonColor    = false
                lbl.Text               = text
                lbl.TextColor3         = RogueUI.Theme.TextNormal
                lbl.Font               = Enum.Font.Garamond
                lbl.TextSize           = 15
                lbl.TextXAlignment     = Enum.TextXAlignment.Left
                lbl.Parent             = content

                local function calcH(t)
                    local _,n=string.gsub(t,"\n",""); return (n+1)*17
                end
                if isMultiLine then
                    lbl.Size           = UDim2.new(1,0,0,calcH(text))
                    lbl.TextWrapped    = true
                    lbl.TextYAlignment = Enum.TextYAlignment.Top
                    lbl.RichText       = true
                else
                    lbl.Size         = UDim2.new(1,0,0,16)
                    lbl.TextTruncate = Enum.TextTruncate.AtEnd
                end

                local self2={};  local clicks={}

                function self2:SetText(t)
                    lbl.Text = t
                    if isMultiLine then lbl.Size=UDim2.new(1,0,0,calcH(t)) end
                end

                function self2:OnClick(fn)
                    if typeof(fn)~="function" then return self2 end
                    if #clicks==0 then
                        lbl.Active=true
                        lbl.MouseEnter:Connect(function() lbl.TextColor3=RogueUI.Theme.TextActive end)
                        lbl.MouseLeave:Connect(function() lbl.TextColor3=RogueUI.Theme.TextNormal end)
                        lbl.MouseButton1Click:Connect(function()
                            playClick()
                            for _,f in ipairs(clicks) do pcall(f) end
                        end)
                    end
                    table.insert(clicks,fn); return self2
                end

                function self2:AddKeyPicker(id, opts2)
                    local defKey = opts2.Default or "Insert"
                    local kd = {
                        Value = typeof(defKey)=="EnumItem" and defKey or (Enum.KeyCode[defKey] or defKey),
                        OnChangedCallbacks = {},
                    }
                    getgenv().Options[id]=kd
                    if id=="MenuKeybind" then self_Window.ToggleKeybind=kd end

                    local pb = Instance.new("TextButton")
                    pb.Size             = UDim2.new(0,60,0,14)
                    pb.Position         = UDim2.new(1,-2,0.5,0)
                    pb.AnchorPoint      = Vector2.new(1,0.5)
                    pb.BackgroundColor3 = RogueUI.Theme.MainBackground
                    pb.BorderSizePixel  = 0
                    local kn = typeof(kd.Value)=="EnumItem" and kd.Value.Name or tostring(kd.Value)
                    pb.Text             = "["..kn.."]"
                    pb.TextColor3       = RogueUI.Theme.TextActive
                    pb.Font             = Enum.Font.Garamond
                    pb.TextSize         = 13
                    pb.Parent           = lbl

                    local pbStroke = Instance.new("UIStroke")
                    pbStroke.Thickness=1; pbStroke.Color=RogueUI.Theme.BorderInactive; pbStroke.Parent=pb

                    local listening=false; local conn

                    local function stopL(nk)
                        listening=false; pb.Text="["..tostring(nk.Name).."]"
                        pb.TextColor3=RogueUI.Theme.TextActive; pbStroke.Color=RogueUI.Theme.BorderInactive
                        kd.Value=nk
                        if conn then conn:Disconnect(); conn=nil end
                        if id=="MenuKeybind" then self_Window.ToggleKeybind=kd end
                        if opts2.Callback then task.spawn(opts2.Callback,nk) end
                        for _,f in ipairs(kd.OnChangedCallbacks) do task.spawn(f,nk) end
                    end

                    pb.MouseButton1Click:Connect(function()
                        if listening then return end
                        playClick(); listening=true; pb.Text="[...]"
                        pb.TextColor3=RogueUI.Theme.TextNormal; pbStroke.Color=RogueUI.Theme.BorderColor
                        conn=addCleanup(UserInputService.InputBegan:Connect(function(input)
                            if input.UserInputType==Enum.UserInputType.Keyboard then stopL(input.KeyCode) end
                        end))
                    end)

                    function kd:SetValue(nk) stopL(nk) end
                    function kd:OnChanged(fn) table.insert(kd.OnChangedCallbacks,fn) end
                    return kd
                end

                function self2:AddColorPicker(id, opts2)
                    local defColor = opts2.Default  or Color3.fromRGB(255,255,255)
                    local cpCb     = opts2.Callback or function() end

                    local pb = Instance.new("TextButton")
                    pb.Size             = UDim2.new(0,14,0,14)
                    pb.Position         = UDim2.new(1,-2,0.5,0)
                    pb.AnchorPoint      = Vector2.new(1,0.5)
                    pb.BackgroundColor3 = defColor
                    pb.BorderSizePixel  = 0
                    pb.Text             = ""
                    pb.Parent           = lbl

                    local pbStroke = Instance.new("UIStroke")
                    pbStroke.Thickness=1; pbStroke.Color=RogueUI.Theme.BorderInactive; pbStroke.Parent=pb

                    local cmenu = Instance.new("Frame")
                    cmenu.Size             = UDim2.new(0,84,0,56)
                    cmenu.Position         = UDim2.new(1,0,1,2)
                    cmenu.AnchorPoint      = Vector2.new(1,0)
                    cmenu.BackgroundColor3 = RogueUI.Theme.GroupBackground
                    cmenu.BorderSizePixel  = 0
                    cmenu.Visible          = false
                    cmenu.ZIndex           = 200
                    cmenu.Parent           = pb

                    local csK = Instance.new("UIStroke")
                    csK.Thickness=1; csK.Color=RogueUI.Theme.BorderColor; csK.Parent=cmenu

                    local cgrid = Instance.new("UIGridLayout")
                    cgrid.CellSize    = UDim2.new(0,24,0,24)
                    cgrid.CellPadding = UDim2.new(0,4,0,4)
                    cgrid.SortOrder   = Enum.SortOrder.LayoutOrder
                    cgrid.Parent      = cmenu

                    local cpad2 = Instance.new("UIPadding")
                    cpad2.PaddingLeft   = UDim.new(0,4); cpad2.PaddingRight  = UDim.new(0,4)
                    cpad2.PaddingTop    = UDim.new(0,4); cpad2.PaddingBottom = UDim.new(0,4)
                    cpad2.Parent        = cmenu

                    local cpData = { Value=defColor, OnChangedCallbacks={ cpCb } }
                    getgenv().Options[id]=cpData

                    local copen=false
                    pb.MouseButton1Click:Connect(function()
                        copen=not copen; cmenu.Visible=copen
                        pbStroke.Color=copen and RogueUI.Theme.BorderColor or RogueUI.Theme.BorderInactive
                        playClick()
                    end)

                    local function setColor(color)
                        cpData.Value=color; pb.BackgroundColor3=color
                        for _,fn in ipairs(cpData.OnChangedCallbacks) do task.spawn(fn,color) end
                    end

                    local PRESETS2={
                        Color3.fromRGB(255,255,255),Color3.fromRGB(205,170,105),
                        Color3.fromRGB(130,130,132),Color3.fromRGB(180,50,50),
                        Color3.fromRGB(0,200,100),  Color3.fromRGB(80,180,255),
                    }
                    for _,color in ipairs(PRESETS2) do
                        local cbtn = Instance.new("TextButton")
                        cbtn.Text=""; cbtn.BackgroundColor3=color
                        cbtn.BorderSizePixel=0; cbtn.ZIndex=201; cbtn.Parent=cmenu
                        local cs=Instance.new("UIStroke")
                        cs.Thickness=1; cs.Color=RogueUI.Theme.BorderInactive; cs.Parent=cbtn
                        cbtn.MouseEnter:Connect(function() cs.Color=RogueUI.Theme.BorderColor end)
                        cbtn.MouseLeave:Connect(function() cs.Color=RogueUI.Theme.BorderInactive end)
                        cbtn.MouseButton1Click:Connect(function()
                            setColor(color); copen=false; cmenu.Visible=false
                            pbStroke.Color=RogueUI.Theme.BorderInactive; playClick()
                        end)
                    end

                    function cpData:SetValue(c)    setColor(c) end
                    function cpData:SetValueRGB(c) setColor(c) end
                    function cpData:OnChanged(fn) table.insert(cpData.OnChangedCallbacks,fn) end
                    return cpData
                end

                return self2
            end

            -- ── Button ────────────────────────────────────────────────────────
            function group_Self:AddButton(text, cb)
                local btn = Instance.new("TextButton")
                btn.Size             = UDim2.new(1,0,0,20)
                btn.BackgroundColor3 = RogueUI.Theme.MainBackground
                btn.BorderSizePixel  = 0
                btn.Text             = text
                btn.TextColor3       = RogueUI.Theme.TextNormal
                btn.Font             = Enum.Font.Garamond
                btn.TextSize         = 15
                btn.TextTruncate     = Enum.TextTruncate.AtEnd
                btn.Parent           = content

                local bs = Instance.new("UIStroke")
                bs.Thickness=1; bs.Color=RogueUI.Theme.BorderInactive; bs.Parent=btn

                btn.MouseEnter:Connect(function()
                    btn.TextColor3=RogueUI.Theme.TextActive; bs.Color=RogueUI.Theme.BorderColor; playHover()
                end)
                btn.MouseLeave:Connect(function()
                    btn.TextColor3=RogueUI.Theme.TextNormal; bs.Color=RogueUI.Theme.BorderInactive
                end)
                btn.MouseButton1Click:Connect(function()
                    playClick()
                    local ok2,err=pcall(cb)
                    if not ok2 then warn("[RogueUI] Button error:",tostring(err)) end
                end)
                return btn
            end

            return group_Self
        end -- addGroupbox

        function tabData:AddLeftGroupbox(t)  return addGroupbox(leftCol,  t) end
        function tabData:AddRightGroupbox(t) return addGroupbox(rightCol, t) end

        self_Window.Tabs[tabName] = tabData
        return tabData
    end -- AddTab

    -- ── Unload ───────────────────────────────────────────────────────────────
    function self_Window:Unload()
        playClick()
        if self_Window.OnUnload then
            local ok2,err=pcall(self_Window.OnUnload)
            if not ok2 then warn("[RogueUI] OnUnload error:",tostring(err)) end
        end
        for _,conn in ipairs(self_Window.CleanupConnections) do
            if type(conn)=="function" then pcall(conn)
            elseif conn and conn.Disconnect then
                pcall(function() conn:Disconnect() end)
            end
        end
        table.clear(self_Window.CleanupConnections)
        if screenGui then screenGui:Destroy() end
        getgenv().BrazilHubLoaded = nil
    end

    return self_Window
end

function RogueUI:AddKeyPicker(id, opts)
    print("[RogueUI] KeyPicker set for", id, opts.Default)
end

return RogueUI
