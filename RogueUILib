-- ── Sound pool ────────────────────────────────────────────────────────────────
local SOUND_POOL_SIZE = 3
local soundPool, soundPoolIndex = {}, 0
pcall(function()
    for i = 1, SOUND_POOL_SIZE do
        local s = Instance.new("Sound")
        s.Parent = workspace.CurrentCamera or workspace
        soundPool[i] = s
    end
end)

local function playSound(id, vol)
    soundPoolIndex = (soundPoolIndex % SOUND_POOL_SIZE) + 1
    local s = soundPool[soundPoolIndex]
    if not s then return end
    s.SoundId = id; s.Volume = vol or 0.5
    s:Stop(); s:Play()
end
local function playClick() playSound("rbxassetid://9114223297", 0.4) end
local function playHover() playSound("rbxassetid://9114221327", 0.2) end

-- ── Draggable ─────────────────────────────────────────────────────────────────
local function makeDraggable(frame, handle, addCleanup)
    local dragging, dragInput, dragStart, startPos = false
    local function update(input)
        local d = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + d.X,
            startPos.Y.Scale, startPos.Y.Offset + d.Y)
    end
    addCleanup(handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            addCleanup(input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end))
        end
    end))
    addCleanup(handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end))
    addCleanup(UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end))
end

