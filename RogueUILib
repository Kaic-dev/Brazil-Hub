                local track = Instance.new("TextButton")
                track.Name = "Track"
                track.Size = UDim2.new(1, 0, 0, 4)
                track.Position = UDim2.new(0, 0, 0, 20)
                track.BackgroundColor3 = RogueUI.Theme.MainBackground
                track.Text = ""
                track.BorderSizePixel = 0
                track.Parent = sliderFrame
                
                local trackBorder = Instance.new("UIStroke")
                trackBorder.Thickness = 1
                trackBorder.Color = RogueUI.Theme.BorderInactive
                trackBorder.Parent = track
                
                local fill = Instance.new("Frame")
                fill.Name = "Fill"
                fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
                fill.BackgroundColor3 = RogueUI.Theme.BorderColor
                fill.BorderSizePixel = 0
                fill.Parent = track
                
                local knob = Instance.new("Frame")
                knob.Name = "Knob"
                knob.Size = UDim2.new(0, 8, 0, 10)
                knob.Position = UDim2.new((default - min) / (max - min), -4, 0.5, -5)
                knob.BackgroundColor3 = RogueUI.Theme.TextActive
                knob.BorderSizePixel = 0
                knob.Parent = track
                
                local sliderData = { Value = default, OnChangedCallbacks = { callback } }
                RogueUI.Sliders[id] = sliderData
                
                local function set(val)
                    val = math.clamp(val, min, max)
                    if rounding == 0 then
                        val = math.round(val)
                    else
                        val = tonumber(string.format("%." .. rounding .. "f", val))
                    end
                    
                    sliderData.Value = val
                    label.Text = text .. ": " .. tostring(val)
                    
                    local pct = (val - min) / (max - min)
                    fill.Size = UDim2.new(pct, 0, 1, 0)
                    knob.Position = UDim2.new(pct, -4, 0.5, -5)
                    
                    for _, cb in ipairs(sliderData.OnChangedCallbacks) do
                        task.spawn(cb, val)
                    end
                end
                
                local dragging = false
                local function updateDrag(input)
                    local trackSize = track.AbsoluteSize.X
                    local relativeX = input.Position.X - track.AbsolutePosition.X
                    local pct = math.clamp(relativeX / trackSize, 0, 1)
                    local val = min + pct * (max - min)
                    set(val)
                end
                
                track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        updateDrag(input)
                        playClick()
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        updateDrag(input)
                    end
                end)
                
                function sliderData:SetValue(val)
                    set(val)
                end
                
                function sliderData:OnChanged(cb)
                    table.insert(sliderData.OnChangedCallbacks, cb)
                end
                
                return sliderData
            end
            
            function group_Self:AddDropdown(id, dropdownOptions)
                local text = dropdownOptions.Text or id
                local values = dropdownOptions.Values or {}
                local isMulti = dropdownOptions.Multi or false
                local default = dropdownOptions.Default
                local callback = dropdownOptions.Callback or function() end
                
                local dropdownFrame = Instance.new("Frame")
                dropdownFrame.Name = id .. "Dropdown"
                dropdownFrame.Size = UDim2.new(1, 0, 0, 38)
                dropdownFrame.BackgroundTransparency = 1
                dropdownFrame.Parent = content
                
                local label = Instance.new("TextLabel")
                label.Name = "Label"
                label.Size = UDim2.new(1, 0, 0, 14)
                label.BackgroundTransparency = 1
                label.Text = text
                label.TextColor3 = RogueUI.Theme.TextNormal
                label.Font = Enum.Font.Garamond
                label.TextSize = 15
                label.TextTruncate = Enum.TextTruncate.AtEnd
                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Parent = dropdownFrame
                
                -- Selected state
                local selectedState = {}
                if isMulti then
                    if type(default) == "table" then
                        for _, val in ipairs(default) do
                            selectedState[val] = true
                        end
                    elseif default ~= nil then
                        selectedState[default] = true
                    end
                else
                    selectedState[default or values[1]] = true
                end
                
                local function getDisplayText()
                    if isMulti then
                        local selectedList = {}
                        for _, val in ipairs(values) do
                            if selectedState[val] then
                                table.insert(selectedList, tostring(val))
                            end
                        end
                        if #selectedList == 0 then
                            return "Select..."
                        else
                            return table.concat(selectedList, ", ")
                        end
                    else
                        for val, active in pairs(selectedState) do
                            if active then return tostring(val) end
                        end
                        return "Select..."
                    end
                end
                
                local button = Instance.new("TextButton")
                button.Name = "Button"
                button.Size = UDim2.new(1, 0, 0, 20)
                button.Position = UDim2.new(0, 0, 0, 18)
                button.BackgroundColor3 = RogueUI.Theme.MainBackground
                button.Text = getDisplayText()
                button.TextColor3 = RogueUI.Theme.TextActive
                button.Font = Enum.Font.Garamond
                button.TextSize = 15
                button.TextTruncate = Enum.TextTruncate.AtEnd
                button.BorderSizePixel = 0
                button.Parent = dropdownFrame
                
                local buttonBorder = Instance.new("UIStroke")
                buttonBorder.Thickness = 1
                buttonBorder.Color = RogueUI.Theme.BorderInactive
                buttonBorder.Parent = button
                
                -- Expanded menu (overlay parented to ScreenGui for proper z-ordering)
                local menu = Instance.new("Frame")
                menu.Name = id .. "DropdownMenu"
                menu.Size = UDim2.new(0, 0, 0, 0)
                menu.BackgroundColor3 = RogueUI.Theme.GroupBackground
                menu.BorderSizePixel = 0
                menu.Visible = false
                menu.ZIndex = 100
                menu.Parent = screenGui
                
                local menuBorder = Instance.new("UIStroke")
                menuBorder.Thickness = 1
                menuBorder.Color = RogueUI.Theme.BorderColor
                menuBorder.Parent = menu
                
                local menuScroll = Instance.new("ScrollingFrame")
                menuScroll.Name = "Scroll"
                menuScroll.Size = UDim2.new(1, 0, 1, 0)
                menuScroll.BackgroundTransparency = 1
                menuScroll.BorderSizePixel = 0
                menuScroll.ScrollBarThickness = 3
                menuScroll.ScrollBarImageColor3 = RogueUI.Theme.BorderColor
                menuScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
                menuScroll.Parent = menu
                
                local menuLayout = Instance.new("UIListLayout")
                menuLayout.SortOrder = Enum.SortOrder.LayoutOrder
                menuLayout.Parent = menuScroll
                
                -- Construct return hybrid value
                local function getCallbackValue()
                    if isMulti then
                        local result = {}
                        for _, val in ipairs(values) do
                            if selectedState[val] then
                                table.insert(result, val)
                                result[val] = true
                            end
                        end
                        return result
                    else
                        for val, active in pairs(selectedState) do
                            if active then return val end
                        end
                        return nil
                    end
                end
                
                local dropdownData = { Value = getCallbackValue(), Values = values, OnChangedCallbacks = { callback } }
                RogueUI.Dropdowns[id] = dropdownData
                
                -- Position the overlay menu to appear below the button
                local function positionMenu()
                    local absPos = button.AbsolutePosition
                    local absSize = button.AbsoluteSize
                    menu.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 1)
                    menu.Size = UDim2.new(0, absSize.X, 0, math.min(#dropdownData.Values * 20, 160))
                    menuScroll.CanvasSize = UDim2.new(0, 0, 0, #dropdownData.Values * 20)
                end
                
                local open = false
                local function toggleMenu()
                    open = not open
                    if open then
                        positionMenu()
                    end
                    menu.Visible = open
                    buttonBorder.Color = open and RogueUI.Theme.BorderColor or RogueUI.Theme.BorderInactive
                    playClick()
                end
                
                -- Close dropdown when clicking outside
                UserInputService.InputBegan:Connect(function(input)
                    if not open then return end
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        -- Delay to let button click fire first
                        task.defer(function()
                            if open then
                                local mousePos = UserInputService:GetMouseLocation()
                                local menuPos = menu.AbsolutePosition
                                local menuSize = menu.AbsoluteSize
                                local btnPos = button.AbsolutePosition
                                local btnSize = button.AbsoluteSize
                                
                                local inMenu = mousePos.X >= menuPos.X and mousePos.X <= menuPos.X + menuSize.X
                                    and mousePos.Y >= menuPos.Y and mousePos.Y <= menuPos.Y + menuSize.Y
                                local inBtn = mousePos.X >= btnPos.X and mousePos.X <= btnPos.X + btnSize.X
                                    and mousePos.Y >= btnPos.Y and mousePos.Y <= btnPos.Y + btnSize.Y
                                
                                if not inMenu and not inBtn then
                                    open = false
                                    menu.Visible = false
                                    buttonBorder.Color = RogueUI.Theme.BorderInactive
                                end
                            end
                        end)
                    end
                end)
                
                button.MouseButton1Click:Connect(toggleMenu)
                
                local function populateOptions()
                    for _, child in ipairs(menuScroll:GetChildren()) do
                        if child:IsA("TextButton") then child:Destroy() end
                    end
                    
                    for i, optVal in ipairs(dropdownData.Values) do
                        local opt = Instance.new("TextButton")
                        opt.Name = tostring(optVal)
                        opt.Size = UDim2.new(1, 0, 0, 20)
                        opt.BackgroundColor3 = RogueUI.Theme.GroupBackground
                        opt.BorderSizePixel = 0
                        opt.Text = tostring(optVal)
                        opt.TextColor3 = selectedState[optVal] and RogueUI.Theme.TextActive or RogueUI.Theme.TextNormal
                        opt.Font = Enum.Font.Garamond
                        opt.TextSize = 15
                        opt.TextTruncate = Enum.TextTruncate.AtEnd
                        opt.ZIndex = 101
                        opt.Parent = menuScroll
                        
                        opt.MouseEnter:Connect(function()
                            opt.TextColor3 = RogueUI.Theme.TextActive
                            playHover()
                        end)
                        opt.MouseLeave:Connect(function()
                            if not selectedState[optVal] then
                                opt.TextColor3 = RogueUI.Theme.TextNormal
                            end
                        end)
                        
                        opt.MouseButton1Click:Connect(function()
                            if isMulti then
                                selectedState[optVal] = not selectedState[optVal]
                                opt.TextColor3 = selectedState[optVal] and RogueUI.Theme.TextActive or RogueUI.Theme.TextNormal
                                button.Text = getDisplayText()
                                playClick()
                                
                                local val = getCallbackValue()
                                dropdownData.Value = val
                                for _, cb in ipairs(dropdownData.OnChangedCallbacks) do
                                    task.spawn(cb, val)
                                end
                            else
                                selectedState = {}
                                selectedState[optVal] = true
                                button.Text = tostring(optVal)
                                toggleMenu()
                                populateOptions()
                                
                                dropdownData.Value = optVal
                                for _, cb in ipairs(dropdownData.OnChangedCallbacks) do
                                    task.spawn(cb, optVal)
                                end
                            end
                        end)
                    end
                end
                
                populateOptions()
                
                function dropdownData:SetValue(val)
                    if isMulti then
                        selectedState = {}
                        if type(val) == "table" then
                            for _, v in ipairs(val) do
                                selectedState[v] = true
                            end
                        else
                            selectedState[val] = true
                        end
                    else
                        selectedState = {}
                        selectedState[val] = true
                    end
                    
                    button.Text = getDisplayText()
                    populateOptions()
                    
                    local finalVal = getCallbackValue()
                    dropdownData.Value = finalVal
                    for _, cb in ipairs(dropdownData.OnChangedCallbacks) do
                        task.spawn(cb, finalVal)
                    end
                end
                
                function dropdownData:SetValues(newVals)
                    dropdownData.Values = newVals
                    populateOptions()
                end
                
                function dropdownData:OnChanged(cb)
                    table.insert(dropdownData.OnChangedCallbacks, cb)
                end
                
                return dropdownData
            end
            
            function group_Self:AddLabel(text, isMultiLine)
                local label = Instance.new("TextLabel")
                label.Name = "Label"
                label.BackgroundTransparency = 1
                label.Text = text
                label.TextColor3 = RogueUI.Theme.TextNormal
                label.Font = Enum.Font.Garamond
                label.TextSize = 15
                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Parent = content
                
                if isMultiLine then
                    label.Size = UDim2.new(1, 0, 0, 0)
                    label.AutomaticSize = Enum.AutomaticSize.Y
                    label.TextWrapped = true
                    label.TextYAlignment = Enum.TextYAlignment.Top
                    label.RichText = true
                else
                    label.Size = UDim2.new(1, 0, 0, 16)
                    label.TextTruncate = Enum.TextTruncate.AtEnd
                end
                
                local label_Self = {}
                function label_Self:SetText(newText)
                    label.Text = newText
                end
                function label_Self:AddKeyPicker(id, options)
                    local defaultKey = options.Default or "Insert"
                    local keyData = { Value = Enum.KeyCode[defaultKey] or defaultKey, OnChangedCallbacks = {} }
                    getgenv().Options[id] = keyData
                    
                    local pickerBtn = Instance.new("TextButton")
                    pickerBtn.Name = id .. "KeyPicker"
                    pickerBtn.Size = UDim2.new(0, 60, 0, 14)
                    pickerBtn.Position = UDim2.new(1, -2, 0.5, 0)
                    pickerBtn.AnchorPoint = Vector2.new(1, 0.5)
                    pickerBtn.BackgroundColor3 = RogueUI.Theme.MainBackground
                    pickerBtn.BorderSizePixel = 0
                    local keyName = typeof(keyData.Value) == "EnumItem" and keyData.Value.Name or tostring(keyData.Value)
                    pickerBtn.Text = "[" .. keyName .. "]"
                    pickerBtn.TextColor3 = RogueUI.Theme.TextActive
                    pickerBtn.Font = Enum.Font.Garamond
                    pickerBtn.TextSize = 13
                    pickerBtn.Parent = label
                    
                    local pickerBorder = Instance.new("UIStroke")
                    pickerBorder.Thickness = 1
                    pickerBorder.Color = RogueUI.Theme.BorderInactive
                    pickerBorder.Parent = pickerBtn
                    
                    local listening = false
                    local conn
                    
                    local function stopListening(newKey)
                        listening = false
                        pickerBtn.Text = "[" .. tostring(newKey.Name) .. "]"
                        pickerBtn.TextColor3 = RogueUI.Theme.TextActive
                        pickerBorder.Color = RogueUI.Theme.BorderInactive
                        
                        keyData.Value = newKey
                        
                        if conn then conn:Disconnect() conn = nil end
                        
                        -- Update main toggle if it is MenuKeybind
                        if id == "MenuKeybind" and self_Window then
                            self_Window.ToggleKeybind = keyData
                        end
                        
                        if options.Callback then
                            task.spawn(options.Callback, newKey)
                        end
                        for _, cb in ipairs(keyData.OnChangedCallbacks) do
                            task.spawn(cb, newKey)
                        end
                    end
                    
                    pickerBtn.MouseButton1Click:Connect(function()
                        if listening then return end
                        playClick()
                        listening = true
                        pickerBtn.Text = "[...]"
                        pickerBtn.TextColor3 = RogueUI.Theme.TextNormal
                        pickerBorder.Color = RogueUI.Theme.BorderColor
                        
                        conn = UserInputService.InputBegan:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.Keyboard then
                                stopListening(input.KeyCode)
                            end
                        end)
                    end)
                    
                    function keyData:SetValue(newKey)
                        stopListening(newKey)
                    end
                    
                    function keyData:OnChanged(cb)
                        table.insert(keyData.OnChangedCallbacks, cb)
                    end
                    
                    return keyData
                end
                function label_Self:AddColorPicker(id, options)
                    local defaultColor = options.Default or Color3.fromRGB(255, 255, 255)
                    local callback = options.Callback or function() end
                    
                    local pickerBtn = Instance.new("TextButton")
                    pickerBtn.Name = id .. "ColorPicker"
                    pickerBtn.Size = UDim2.new(0, 14, 0, 14)
                    pickerBtn.Position = UDim2.new(1, -2, 0.5, 0)
                    pickerBtn.AnchorPoint = Vector2.new(1, 0.5)
                    pickerBtn.BackgroundColor3 = defaultColor
                    pickerBtn.BorderSizePixel = 0
                    pickerBtn.Text = ""
                    pickerBtn.Parent = label
                    
                    local pickerBorder = Instance.new("UIStroke")
                    pickerBorder.Thickness = 1
                    pickerBorder.Color = RogueUI.Theme.BorderInactive
                    pickerBorder.Parent = pickerBtn
                    
                    -- Color menu overlay
                    local menu = Instance.new("Frame")
                    menu.Name = "Menu"
                    menu.Size = UDim2.new(0, 84, 0, 56)
                    menu.Position = UDim2.new(1, 0, 1, 2)
                    menu.AnchorPoint = Vector2.new(1, 0)
                    menu.BackgroundColor3 = RogueUI.Theme.GroupBackground
                    menu.BorderSizePixel = 0
                    menu.Visible = false
                    menu.ZIndex = 200
                    menu.Parent = pickerBtn
                    
                    local menuBorder = Instance.new("UIStroke")
                    menuBorder.Thickness = 1
                    menuBorder.Color = RogueUI.Theme.BorderColor
                    menuBorder.Parent = menu
                    
                    local grid = Instance.new("UIGridLayout")
                    grid.CellSize = UDim2.new(0, 24, 0, 24)
                    grid.CellPadding = UDim2.new(0, 4, 0, 4)
                    grid.SortOrder = Enum.SortOrder.LayoutOrder
                    grid.Parent = menu
                    
                    local padding = Instance.new("UIPadding")
                    padding.PaddingLeft = UDim.new(0, 4)
                    padding.PaddingRight = UDim.new(0, 4)
                    padding.PaddingTop = UDim.new(0, 4)
                    padding.PaddingBottom = UDim.new(0, 4)
                    padding.Parent = menu
                    
                    local PRESETS = {
                        Color3.fromRGB(255, 255, 255), -- White
                        Color3.fromRGB(205, 170, 105), -- Gold
                        Color3.fromRGB(130, 130, 132), -- Gray
                        Color3.fromRGB(180, 50, 50),   -- Goth Red
                        Color3.fromRGB(0, 200, 100),   -- Green
                        Color3.fromRGB(80, 180, 255)   -- Cyan/Blue
                    }
                    
                    local colorPickerData = { Value = defaultColor, OnChangedCallbacks = { callback } }
                    getgenv().Options[id] = colorPickerData
                    
                    local open = false
                    pickerBtn.MouseButton1Click:Connect(function()
                        open = not open
                        menu.Visible = open
                        pickerBorder.Color = open and RogueUI.Theme.BorderColor or RogueUI.Theme.BorderInactive
                        playClick()
                    end)
                    
                    local function set(color)
                        colorPickerData.Value = color
                        pickerBtn.BackgroundColor3 = color
                        for _, cb in ipairs(colorPickerData.OnChangedCallbacks) do
                            task.spawn(cb, color)
                        end
                    end
                    
                    for i, color in ipairs(PRESETS) do
                        local btn = Instance.new("TextButton")
                        btn.Name = "Color_" .. tostring(i)
                        btn.Text = ""
                        btn.BackgroundColor3 = color
                        btn.BorderSizePixel = 0
                        btn.ZIndex = 201
                        btn.Parent = menu
                        
                        local btnBorder = Instance.new("UIStroke")
                        btnBorder.Thickness = 1
                        btnBorder.Color = RogueUI.Theme.BorderInactive
                        btnBorder.Parent = btn
                        
                        btn.MouseEnter:Connect(function()
                            btnBorder.Color = RogueUI.Theme.BorderColor
                        end)
                        btn.MouseLeave:Connect(function()
                            btnBorder.Color = RogueUI.Theme.BorderInactive
                        end)
                        btn.MouseButton1Click:Connect(function()
                            set(color)
                            open = false
                            menu.Visible = false
                            pickerBorder.Color = RogueUI.Theme.BorderInactive
                            playClick()
                        end)
                    end
                    
                    function colorPickerData:SetValue(color)
                        set(color)
                    end
                    
                    function colorPickerData:SetValueRGB(color)
                        set(color)
                    end
                    
                    function colorPickerData:OnChanged(cb)
                        table.insert(colorPickerData.OnChangedCallbacks, cb)
                    end
                    
                    return colorPickerData
                end
                return label_Self
            end
            
            function group_Self:AddButton(text, callback)
                local btn = Instance.new("TextButton")
                btn.Name = "Button"
                btn.Size = UDim2.new(1, 0, 0, 20)
                btn.BackgroundColor3 = RogueUI.Theme.MainBackground
                btn.BorderSizePixel = 0
                btn.Text = text
                btn.TextColor3 = RogueUI.Theme.TextNormal
                btn.Font = Enum.Font.Garamond
                btn.TextSize = 15
                btn.TextTruncate = Enum.TextTruncate.AtEnd
                btn.Parent = content
                
                local btnBorder = Instance.new("UIStroke")
                btnBorder.Thickness = 1
                btnBorder.Color = RogueUI.Theme.BorderInactive
                btnBorder.Parent = btn
                
                btn.MouseEnter:Connect(function()
                    btn.TextColor3 = RogueUI.Theme.TextActive
                    btnBorder.Color = RogueUI.Theme.BorderColor
                    playHover()
                end)
                btn.MouseLeave:Connect(function()
                    btn.TextColor3 = RogueUI.Theme.TextNormal
                    btnBorder.Color = RogueUI.Theme.BorderInactive
                end)
                btn.MouseButton1Click:Connect(function()
                    playClick()
                    callback()
                end)
                
                return btn
            end
            
            return group_Self
        end
        
        function tabData:AddLeftGroupbox(groupTitle)
            return addGroupbox(leftColumn, groupTitle)
        end
        
        function tabData:AddRightGroupbox(groupTitle)
            return addGroupbox(rightColumn, groupTitle)
        end
        
        self_Window.Tabs[tabName] = tabData
        return tabData
    end
    
    function self_Window:Unload()
        playClick()
        if self_Window.OnUnload then
            local ok, err = pcall(self_Window.OnUnload)
            if not ok then warn("[RogueUI] Error in OnUnload:", tostring(err)) end
        end
        if screenGui then
            screenGui:Destroy()
        end
        getgenv().BrazilHubLoaded = nil
    end
    
    return self_Window
end

-- Compatibility keybind handling wrapper
function RogueUI:AddKeyPicker(id, options)
    -- Simply map it to a callback toggle or print since it's built-in in the CreateWindow wrapper
    print("[RogueUI] KeyPicker set for", id, options.Default)
end

return RogueUI
