local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

local AutoAim = {}
AutoAim.__index = AutoAim

function AutoAim.new()
    local self = setmetatable({}, AutoAim)

    self.enabled = false
    self.maxRange = 200
    self.fovMax = 20

    self.remote = nil
    self.mouse = nil

    self._heartbeat = nil
    self._invokeCount = 0

    return self
end

function AutoAim:setRange(range)
    self.maxRange = range
end

function AutoAim:setFov(fov)
    self.fovMax = fov
end

function AutoAim:getRemote()
    if self.remote then
        return self.remote
    end

    local requests = ReplicatedStorage:FindFirstChild("Requests")

    if not requests then
        warn("[AutoAim] Requests not found")
        return nil
    end

    local remote = requests:FindFirstChild("GetMouse")

    if not remote then
        warn("[AutoAim] GetMouse not found")
        return nil
    end

    self.remote = remote

    return remote
end

function AutoAim:updateMouse()
    self.mouse = LocalPlayer:GetMouse()
end

function AutoAim:getCharacter()
    return LocalPlayer.Character
end

function AutoAim:getHRP(character)
    if not character then
        return nil
    end

    return character:FindFirstChild("HumanoidRootPart")
end

function AutoAim:isValidTarget(model)
    if not model then
        return false
    end

    if not model.Parent then
        return false
    end

    local humanoid = model:FindFirstChildOfClass("Humanoid")

    if not humanoid then
        return false
    end

    if humanoid.Health <= 0 then
        return false
    end

    return true
end

function AutoAim:getLiveFolder()
    return Workspace:FindFirstChild("Live")
end

function AutoAim:getClosestTarget()
    local character = self:getCharacter()

    if not character then
        return nil
    end

    local hrp = self:getHRP(character)

    if not hrp then
        return nil
    end

    local liveFolder = self:getLiveFolder()

    if not liveFolder then
        return nil
    end

    local closest = nil
    local closestDistance = self.maxRange

    local children = liveFolder:GetChildren()

    for i = 1, #children do
        local model = children[i]

        if model ~= character and self:isValidTarget(model) then
            local targetHRP = model:FindFirstChild("HumanoidRootPart")

            if targetHRP then
                local distance = (targetHRP.Position - hrp.Position).Magnitude

                if distance < closestDistance then
                    closestDistance = distance
                    closest = model
                end
            end
        end
    end

    return closest
end

function AutoAim:getMouseData()
    local mouse = self.mouse

    if not mouse then
        return nil
    end

    return {
        Hit = mouse.Hit,
        Target = mouse.Target,
        UnitRay = mouse.UnitRay,
        X = mouse.X,
        Y = mouse.Y
    }
end

function AutoAim:enable()
    if self.enabled then
        return
    end

    local remote = self:getRemote()

    if not remote then
        return
    end

    self.enabled = true

    self:updateMouse()

    self._heartbeat = RunService.Heartbeat:Connect(function()
        self:updateMouse()
    end)

    remote.OnClientInvoke = function(...)
        self._invokeCount += 1

        local mouseData = self:getMouseData()

        if not mouseData then
            return {
                Hit = CFrame.new(),
                Target = nil,
                UnitRay = Ray.new(Vector3.zero, Vector3.zAxis),
                X = 0,
                Y = 0
            }
        end

        local character = self:getCharacter()

        if not character then
            return mouseData
        end

        local target = self:getClosestTarget()

        if not target then
            return mouseData
        end

        local targetHRP = target:FindFirstChild("HumanoidRootPart")

        if not targetHRP then
            return mouseData
        end

        return {
            Hit = CFrame.new(targetHRP.Position),
            Target = target,
            UnitRay = mouseData.UnitRay,
            X = mouseData.X,
            Y = mouseData.Y
        }
    end

    print("[AutoAim] enabled")
end

function AutoAim:disable()
    if not self.enabled then
        return
    end

    self.enabled = false

    if self._heartbeat then
        self._heartbeat:Disconnect()
        self._heartbeat = nil
    end

    print("[AutoAim] disabled")
end

return AutoAim
