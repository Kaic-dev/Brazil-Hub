local NoFog = {}
NoFog.enabled  = false
NoFog._connMgr = nil
NoFog._original = nil

local function safeRequireRemote(url, name)
    local ok, raw = pcall(game.HttpGet, game, url)
    if not ok then warn("[NoFog] Download falhou:", name, raw) return nil end
    local fn, err = loadstring(raw)
    if not fn then warn("[NoFog] Compilação falhou:", name, err) return nil end
    local ok2, mod = pcall(fn)
    if not ok2 then warn("[NoFog] Execução falhou:", name, mod) return nil end
    return mod
end

local ConnectionManager = safeRequireRemote(
    "https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/main/ConnectionManager",
    "ConnectionManager"
) or {
    new = function()
        return {
            add           = function(self, c) end,
            disconnectAll = function(self) end,
        }
    end,
}

local EFFECT_TYPES = {
    "Atmosphere", "BloomEffect", "ColorCorrectionEffect",
    "DepthOfFieldEffect", "SunRaysEffect",
}

local function isTargetEffect(obj)
    for _, t in ipairs(EFFECT_TYPES) do
        if obj:IsA(t) then return true end
    end
    return false
end

-- Salva estado original no momento do carregamento do módulo
local function captureOriginal()
    local Lighting = game:GetService("Lighting")
    local orig = {
        FogStart = Lighting.FogStart,
        FogEnd   = Lighting.FogEnd,
        FogColor = Lighting.FogColor,
        effects  = {},
    }
    for _, child in ipairs(Lighting:GetChildren()) do
        if isTargetEffect(child) then
            orig.effects[#orig.effects + 1] = {
                instance   = child,
                wasEnabled = child.Enabled,
            }
        end
    end
    return orig
end

NoFog._original = captureOriginal()

function NoFog:apply()
    local Lighting = game:GetService("Lighting")
    Lighting.FogEnd   = 100000
    Lighting.FogStart = 99999
    for _, child in ipairs(Lighting:GetChildren()) do
        if isTargetEffect(child) then
            pcall(function() child.Enabled = false end)
        end
    end
end

function NoFog:restoreOriginal()
    local Lighting = game:GetService("Lighting")
    if not self._original then return end
    Lighting.FogStart = self._original.FogStart
    Lighting.FogEnd   = self._original.FogEnd
    Lighting.FogColor = self._original.FogColor
    for _, data in ipairs(self._original.effects or {}) do
        if data.instance and data.instance.Parent then
            pcall(function() data.instance.Enabled = data.wasEnabled end)
        end
    end
end

function NoFog:enable()
    if self.enabled then return end
    self._connMgr = ConnectionManager.new()
    self.enabled  = true
    self:apply()

    local Lighting = game:GetService("Lighting")

    self._connMgr:add(
        Lighting.ChildAdded:Connect(function(child)
            if self.enabled and isTargetEffect(child) then
                task.defer(function()
                    if self.enabled then
                        pcall(function() child.Enabled = false end)
                    end
                end)
            end
        end),
        "Lighting.ChildAdded"
    )

    for _, prop in ipairs({"FogEnd", "FogStart", "FogColor"}) do
        self._connMgr:add(
            Lighting:GetPropertyChangedSignal(prop):Connect(function()
                if self.enabled then
                    pcall(function() self:apply() end)
                end
            end),
            "Lighting." .. prop
        )
    end
end

function NoFog:disable()
    if not self.enabled then return end
    self.enabled = false
    if self._connMgr then
        self._connMgr:disconnectAll()
        self._connMgr = nil
    end
    self:restoreOriginal()
end

function NoFog:isEnabled()
    return self.enabled
end

return NoFog
