-- ─── Utilitários externos ─────────────────────────────────────────────────────

local function safeRequireRemote(url, name)
    local ok, raw = pcall(game.HttpGet, game, url)
    if not ok then
        warn("[BetterLeaderboard] Download falhou:", name, raw)
        return nil
    end
    local fn, err = loadstring(raw)
    if not fn then
        warn("[BetterLeaderboard] Compilação falhou:", name, err)
        return nil
    end
    local ok2, mod = pcall(fn)
    if not ok2 then
        warn("[BetterLeaderboard] Execução falhou:", name, mod)
        return nil
    end
    return mod
end

local UtilsService = safeRequireRemote(
    "https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/refs/heads/main/UtilsService",
    "UtilsService"
)
local utils = UtilsService and UtilsService.new() or nil

local ConnectionManager = safeRequireRemote(
    "https://raw.githubusercontent.com/Kaic-dev/Brazil-Hub/main/ConnectionManager",
    "ConnectionManager"
) or {
    new = function()
        return {
            _conns = {},
            add           = function(self, c) self._conns[c] = true end,
            remove        = function(self, c)
                if self._conns[c] then
                    if c.Connected then c:Disconnect() end
                    self._conns[c] = nil
                end
            end,
            disconnectAll = function(self)
                for c in pairs(self._conns) do
                    if c.Connected then c:Disconnect() end
                end
                self._conns = {}
            end,
        }
    end,
}

-- ─── BetterLeaderboard ────────────────────────────────────────────────────────

local BetterLeaderboard = {}
BetterLeaderboard.__index = BetterLeaderboard

function BetterLeaderboard.new()
    local self = setmetatable({}, BetterLeaderboard)

    self.enabled              = false
    self.screenGui            = nil
    self.leaderboard          = nil
    self.scrollingFrame       = nil
    self._connMgr             = ConnectionManager.new()
    self._currentCameraTarget = nil
    self._playerCount         = 0  -- contador local evita Players:GetPlayers() toda atualização

    -- FIX: tabelas separadas por responsabilidade — sem double tracking
    -- _playerFrames:    [player] → Frame (UI)
    -- _playerConns:     [player] → { conn, ... } conexões POR PLAYER (não no connMgr global)
    self._playerFrames = {}
    self._playerConns  = {}  -- gerenciado manualmente; connMgr cuida apenas de conns globais

    return self
end

-- ─── Helpers de UI ────────────────────────────────────────────────────────────

function BetterLeaderboard:_getPlayerGui()
    local player = Players.LocalPlayer
    if not player then return nil end
    local gui = player:FindFirstChildOfClass("PlayerGui")
    if not gui then
        local ok, result = pcall(function()
            return player:WaitForChild("PlayerGui", CONFIG.PLAYERGUI_TIMEOUT)
        end)
        if ok then gui = result end
    end
    return gui
end

function BetterLeaderboard:_createScreenGui()
    local g = Instance.new("ScreenGui")
    g.Name            = "BetterLeaderboardGui"
    g.ResetOnSpawn    = false
    g.ZIndexBehavior  = Enum.ZIndexBehavior.Sibling
    return g
end

function BetterLeaderboard:_createScrollingFrame(parent)
    local sf = Instance.new("ScrollingFrame")
    sf.Name                       = "ScrollingFrame"
    sf.ScrollBarImageColor3       = CONFIG.COLORS.GREEN
    sf.MidImage                   = CONFIG.ASSETS.SCROLL_MID
    sf.Active                     = true
    sf.ScrollBarThickness         = 6
    sf.TopImage                   = CONFIG.ASSETS.SCROLL_TOP
    sf.BottomImage                = CONFIG.ASSETS.SCROLL_BOTTOM
    sf.VerticalScrollBarPosition  = Enum.VerticalScrollBarPosition.Right
    sf.BackgroundTransparency     = 1
    sf.VerticalScrollBarInset     = Enum.ScrollBarInset.ScrollBar
    sf.Position                   = UDim2.new(0, 8, 0, 8)
    sf.ScrollingDirection         = Enum.ScrollingDirection.Y
    sf.Size                       = CONFIG.SCROLLING_FRAME_SIZE
    sf.BorderSizePixel            = 0
    sf.CanvasSize                 = UDim2.new(0, 0, 0, 220)

    local layout = Instance.new("UIListLayout")
    layout.SortOrder  = Enum.SortOrder.LayoutOrder
    layout.Padding    = UDim.new(0, 2)
    layout.Parent     = sf

    sf.Parent = parent
    return sf
end

function BetterLeaderboard:_createLeaderboardGui(parent)
    local lb = Instance.new("ImageButton")
    lb.Name                 = "Leaderboard"
    lb.ScaleType            = Enum.ScaleType.Slice
    lb.ImageTransparency    = 0.8
    lb.Size                 = CONFIG.LEADERBOARD_SIZE
    lb.AnchorPoint          = Vector2.new(1, 0)
    lb.Image                = CONFIG.ASSETS.LEADERBOARD_IMAGE
    lb.BackgroundTransparency = 1
    lb.Position             = UDim2.new(1, 0, 0, 0)
    lb.BorderSizePixel      = 0
    lb.SliceCenter          = Rect.new(Vector2.new(20, 20), Vector2.new(190, 190))

    local sf = self:_createScrollingFrame(lb)
    if parent then lb.Parent = parent end
    return lb, sf
end

-- ─── Dados de player ──────────────────────────────────────────────────────────

function BetterLeaderboard:_getPlayerPrestige(player)
    if utils and utils.getPlayerPrestigeData then
        local data = utils:getPlayerPrestigeData(player)
        if data and data.level then return data.level end
    end
    return 0
end

function BetterLeaderboard:_getPlayerRogueName(player)
    if utils and utils.getPlayerRogueDisplay then
        local display = utils:getPlayerRogueDisplay(player)
        if display and #display > 0 then return display end
    end
    return nil
end

-- ─── Cor da label ─────────────────────────────────────────────────────────────

local EDICT_COLOR_MAP = {
    ["Healer T1"]      = "HEALER_T1",
    ["Healer T2"]      = "HEALER_T2",
    ["Healer T3"]      = "HEALER_T3",
    ["Seer T1"]        = "SEER_T1",
    ["Seer T2"]        = "SEER_T2",
    ["Seer T3"]        = "SEER_T3",
    ["Blademaster T1"] = "BLADEMASTER_T1",
    ["Blademaster T1.5"] = "BLADEMASTER_T1_5",
    ["Blademaster T2"] = "BLADEMASTER_T2",
}

function BetterLeaderboard:_getPlayerEdictColor(player)
    if not (utils and utils.getPlayerEdictData) then return nil end
    local data = utils:getPlayerEdictData(player)
    if not data then return nil end
    local display = data.edictDisplay or data.edict
    local key = display and EDICT_COLOR_MAP[display]
    return key and CONFIG.COLORS[key] or nil
end

function BetterLeaderboard:_getPlayerLabelColor(player)
    if self._currentCameraTarget == player then
        return CONFIG.COLORS.SPECTATING
    end
    if not player.Character then
        return CONFIG.COLORS.DEAD
    end
    return self:_getPlayerEdictColor(player) or CONFIG.COLORS.WHITE
end

-- ─── Update de cores (cache de frames para evitar GetChildren()) ──────────────

function BetterLeaderboard:_updateAllLabelsColor()
    -- FIX: itera _playerFrames diretamente — sem GetChildren() nem criação de array
    for player, frame in pairs(self._playerFrames) do
        if frame and frame.Parent then
            local label = frame:FindFirstChild("PlayerLabel")
            if label and label:IsA("TextButton") then
                local rogueDisplay = label:GetAttribute("RogueDisplay")
                local text = (rogueDisplay and rogueDisplay ~= "") and rogueDisplay or "Carregando..."
                label.Text       = text
                label.TextColor3 = self:_getPlayerLabelColor(player)

                local indicator = frame:FindFirstChild("ObservedIndicator")
                if indicator then
                    indicator.Visible = (self._currentCameraTarget == player)
                end
            end
        end
    end
end

-- ─── Câmera ───────────────────────────────────────────────────────────────────

function BetterLeaderboard:_toggleCameraToPlayer(targetPlayer)
    local camera = workspace.CurrentCamera
    if not camera then return end

    if targetPlayer == Players.LocalPlayer then return end

    if self._currentCameraTarget == targetPlayer then
        self._currentCameraTarget = nil
        local local_ = Players.LocalPlayer
        local returnTarget = nil
        if local_ and local_.Character then
            returnTarget = local_.Character:FindFirstChildOfClass("Humanoid")
        end
        if returnTarget then
            camera.CameraSubject = returnTarget
        else
            camera.CameraType = Enum.CameraType.Custom
        end
    else
        if not targetPlayer then return end
        local subject = nil
        if targetPlayer.Character then
            subject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
                   or targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        end
        if subject then
            camera.CameraSubject      = subject
            self._currentCameraTarget = targetPlayer
        end
    end

    self:_updateAllLabelsColor()
end

-- ─── Leaderboard original ─────────────────────────────────────────────────────

function BetterLeaderboard:_hideOriginalLeaderboard()
    local playerGui = self:_getPlayerGui()
    if not playerGui then return end

    -- FIX: desconecta _lbConn anterior antes de recriar
    if self._lbConn then
        self._connMgr:remove(self._lbConn)
        self._lbConn = nil
    end

    local function disableLeaderboard()
        local orig = playerGui:FindFirstChild("LeaderboardGui")
        if not orig then return end
        orig.Enabled = false

        if self._lbEnabledConn then
            self._connMgr:remove(self._lbEnabledConn)
        end
        self._lbEnabledConn = orig:GetPropertyChangedSignal("Enabled"):Connect(function()
            if self.enabled and orig.Enabled then
                orig.Enabled = false
            end
        end)
        self._connMgr:add(self._lbEnabledConn, "leaderboard.EnabledChanged")
    end

    disableLeaderboard()

    self._lbConn = playerGui.ChildAdded:Connect(function(child)
        if child.Name == "LeaderboardGui" then
            disableLeaderboard()
        end
    end)
    self._connMgr:add(self._lbConn, "playerGui.ChildAdded")
end

function BetterLeaderboard:_showOriginalLeaderboard()
    local playerGui = self:_getPlayerGui()
    if not playerGui then return end
    local orig = playerGui:FindFirstChild("LeaderboardGui")
    if orig then orig.Enabled = true end
end

