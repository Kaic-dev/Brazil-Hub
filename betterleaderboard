end

function BetterLeaderboard:_createObservedIndicator(player, parent)
    local indicator = Instance.new("Frame")
    indicator.Name                = "ObservedIndicator"
    indicator.Size                = UDim2.new(0, 14, 0, 14)
    indicator.BackgroundTransparency = 1
    indicator.BorderSizePixel     = 0
    indicator.LayoutOrder         = 2

    local outer = Instance.new("Frame")
    outer.Size              = UDim2.new(1, 0, 1, 0)
    outer.BackgroundColor3  = CONFIG.COLORS.OBSERVED
    outer.BorderSizePixel   = 0
    outer.Parent            = indicator
    local oc = Instance.new("UICorner")
    oc.CornerRadius = UDim.new(1, 0)
    oc.Parent = outer

    local pupil = Instance.new("Frame")
    pupil.Size             = UDim2.new(0, 8, 0, 8)
    pupil.Position         = UDim2.new(0.5, -4, 0.5, -4)
    pupil.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    pupil.BorderSizePixel  = 0
    pupil.Parent           = indicator
    local pc = Instance.new("UICorner")
    pc.CornerRadius = UDim.new(1, 0)
    pc.Parent = pupil

    indicator.Visible = (self._currentCameraTarget == player)
    indicator.Parent  = parent
    return indicator
end

-- FIX: _createPlayerLabel não registra mais no connMgr — retorna conns para
-- addPlayerFrame gerenciar centralizadamente em _playerConns
function BetterLeaderboard:_createPlayerLabel(player, rogueName, parent)
    local label = Instance.new("TextButton")
    label.Name                  = "PlayerLabel"
    label.TextColor3            = self:_getPlayerLabelColor(player)
    label.Text                  = rogueName or "Carregando..."
    label:SetAttribute("RogueDisplay", rogueName or "")
    label:SetAttribute("PlayerUserId", player.UserId)
    label.TextXAlignment        = Enum.TextXAlignment.Left
    label.TextYAlignment        = Enum.TextYAlignment.Center
    label.TextStrokeTransparency = 0.5
    label.Size                  = CONFIG.PLAYER_LABEL_SIZE
    label.Font                  = Enum.Font.SourceSansSemibold
    label.BackgroundTransparency = 1
    label.TextSize              = 16
    label.BorderSizePixel       = 0
    label.BackgroundColor3      = CONFIG.COLORS.WHITE
    label.LayoutOrder           = 3
    label.TextTruncate          = Enum.TextTruncate.AtEnd
    label.Parent                = parent

    local conns = {}

    -- Hover
    conns[#conns+1] = label.MouseEnter:Connect(function()
        label.TextColor3 = CONFIG.COLORS.GRAY
        label.Text       = player.Name
    end)
    conns[#conns+1] = label.MouseLeave:Connect(function()
        label.TextColor3 = self:_getPlayerLabelColor(player)
        local rd = label:GetAttribute("RogueDisplay")
        label.Text = (rd and rd ~= "") and rd or "Carregando..."
    end)

    -- Right-click: spectate
    conns[#conns+1] = label.MouseButton2Click:Connect(function()
        self:_toggleCameraToPlayer(player)
    end)

    -- Atualiza cor em mudança de personagem
    conns[#conns+1] = player.CharacterAdded:Connect(function()
        self:_updateAllLabelsColor()
    end)
    conns[#conns+1] = player.CharacterRemoving:Connect(function()
        self:_updateAllLabelsColor()
    end)

    return label, conns
end

-- FIX: _startRogueNameLoading guarda thread em _playerConns para cancelamento externo
function BetterLeaderboard:_startRogueNameLoading(player, playerLabel)
    if not (utils and utils.getPlayerRogueDisplay) then return end

    -- Flag de cancelamento por player
    local active = true
    self._rogueLoadFlags = self._rogueLoadFlags or {}
    -- Cancela carregamento anterior para este player se existir
    if self._rogueLoadFlags[player] then
        self._rogueLoadFlags[player].active = false
    end
    local flag = { active = true }
    self._rogueLoadFlags[player] = flag

    task.spawn(function()
        while flag.active and self.enabled and playerLabel and playerLabel.Parent do
            local display = utils:getPlayerRogueDisplay(player)
            if display and #display > 0 then
                if flag.active then  -- checa novamente após yield
                    playerLabel:SetAttribute("RogueDisplay", display)
                    playerLabel.Text = display
                    self:_updateAllLabelsColor()
                end
                break
            end
            task.wait(CONFIG.RETRY_INTERVAL)
        end
        if self._rogueLoadFlags and self._rogueLoadFlags[player] == flag then
            self._rogueLoadFlags[player] = nil
        end
    end)
end

-- ─── Canvas size ──────────────────────────────────────────────────────────────

function BetterLeaderboard:_updateCanvasSize()
    if not self.scrollingFrame then return end
    local frameH   = CONFIG.PLAYER_FRAME_SIZE.Y.Offset
    local spacing  = 2
    local total    = self._playerCount * (frameH + spacing)
    self.scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(total, 220))
end

-- ─── Adiciona frame de player ──────────────────────────────────────────────────

function BetterLeaderboard:addPlayerFrame(player)
    if not self.scrollingFrame then return end
    if self._playerFrames[player] then return end  -- idempotente

    local prestige  = self:_getPlayerPrestige(player)
    local rogueName = self:_getPlayerRogueName(player)

    local frame = Instance.new("Frame")
    frame.BackgroundTransparency = 1
    frame.Size                   = CONFIG.PLAYER_FRAME_SIZE
    frame.BorderSizePixel        = 0
    frame.Parent                 = self.scrollingFrame
    self._playerFrames[player]   = frame
    self._playerCount            = self._playerCount + 1

    local rowLayout = Instance.new("UIListLayout")
    rowLayout.FillDirection      = Enum.FillDirection.Horizontal
    rowLayout.VerticalAlignment  = Enum.VerticalAlignment.Center
    rowLayout.SortOrder          = Enum.SortOrder.LayoutOrder
    rowLayout.Padding            = UDim.new(0, 4)
    rowLayout.Parent             = frame

    local rowPadding = Instance.new("UIPadding")
    rowPadding.PaddingLeft = UDim.new(0, 6)
    rowPadding.Parent      = frame

    self:_createPrestigeButton(prestige, frame)
    self:_createObservedIndicator(player, frame)
    local playerLabel, labelConns = self:_createPlayerLabel(player, rogueName, frame)

    -- FIX: conexões de backpack gerenciadas localmente, sem pcall silenciador
    local extraConns = {}

    local attrSignal = player:GetAttributeChangedSignal("MaxEdict")
    extraConns[#extraConns+1] = attrSignal:Connect(function()
        self:_updateAllLabelsColor()
    end)

    local function connectBackpack(bp)
        local c1 = bp.ChildAdded:Connect(function()   self:_updateAllLabelsColor() end)
        local c2 = bp.ChildRemoved:Connect(function() self:_updateAllLabelsColor() end)
        extraConns[#extraConns+1] = c1
        extraConns[#extraConns+1] = c2
    end

    local bp = player:FindFirstChild("Backpack")
    if bp then
        connectBackpack(bp)
    else
        -- Espera Backpack aparecer; desconecta a si mesmo após encontrar
        local waitConn
        waitConn = player.ChildAdded:Connect(function(child)
            if child.Name == "Backpack" then
                connectBackpack(child)
                -- FIX: remove waitConn de extraConns e desconecta
                waitConn:Disconnect()
                for i, c in ipairs(extraConns) do
                    if c == waitConn then
                        table.remove(extraConns, i)
                        break
                    end
                end
            end
        end)
        extraConns[#extraConns+1] = waitConn
    end

    -- FIX: todas as conns do player em _playerConns — sem double tracking no connMgr
    local allConns = {}
    for _, c in ipairs(labelConns)  do allConns[#allConns+1] = c end
    for _, c in ipairs(extraConns)  do allConns[#allConns+1] = c end
    self._playerConns[player] = allConns

    if not rogueName then
        self:_startRogueNameLoading(player, playerLabel)
    end

    self:_updateCanvasSize()
end

-- ─── Enable / Disable ────────────────────────────────────────────────────────

function BetterLeaderboard:enable()
    if self.enabled then return end

    local playerGui = self:_getPlayerGui()
    if not playerGui then return end

    self.enabled      = true
    self._playerCount = 0

    self:_hideOriginalLeaderboard()
    self.screenGui                    = self:_createScreenGui()
    self.leaderboard, self.scrollingFrame = self:_createLeaderboardGui(self.screenGui)
    self.screenGui.Parent             = playerGui

    for _, p in ipairs(Players:GetPlayers()) do
        self:addPlayerFrame(p)
    end

    self._connMgr:add(
        Players.PlayerAdded:Connect(function(p)
            self:addPlayerFrame(p)
        end),
        "Players.PlayerAdded"
    )

    self._connMgr:add(
        Players.PlayerRemoving:Connect(function(p)
            -- Sai do spectate se necessário
            if self._currentCameraTarget == p then
                self:_toggleCameraToPlayer(p)
            end

            -- Cancela rogue name loading
            if self._rogueLoadFlags and self._rogueLoadFlags[p] then
                self._rogueLoadFlags[p].active = false
                self._rogueLoadFlags[p] = nil
            end

            -- FIX: desconecta conns do player diretamente de _playerConns
            local conns = self._playerConns[p]
            if conns then
                for _, c in ipairs(conns) do
                    if c and c.Connected then c:Disconnect() end
                end
                self._playerConns[p] = nil
            end

            local frame = self._playerFrames[p]
            if frame and frame.Parent then frame:Destroy() end
            self._playerFrames[p] = nil
            self._playerCount     = math.max(0, self._playerCount - 1)

            self:_updateCanvasSize()
        end),
        "Players.PlayerRemoving"
    )
end

function BetterLeaderboard:disable()
    if not self.enabled then return end
    self.enabled = false

    -- Cancela todos os rogue loaders
    if self._rogueLoadFlags then
        for _, flag in pairs(self._rogueLoadFlags) do
            flag.active = false
        end
        self._rogueLoadFlags = {}
    end

    -- FIX: desconecta conns de players manualmente (não estão no connMgr)
    for _, conns in pairs(self._playerConns) do
        for _, c in ipairs(conns) do
            if c and c.Connected then c:Disconnect() end
        end
    end
    self._playerConns  = {}
    self._playerFrames = {}
    self._playerCount  = 0

    -- Desconecta conns globais (PlayerAdded, PlayerRemoving, lb guards)
    self._connMgr:disconnectAll()

    if self.screenGui and self.screenGui.Parent then
        self.screenGui:Destroy()
    end
    self.screenGui        = nil
    self.leaderboard      = nil
    self.scrollingFrame   = nil
    self._lbConn          = nil
    self._lbEnabledConn   = nil

    self:_showOriginalLeaderboard()
end

return BetterLeaderboard
