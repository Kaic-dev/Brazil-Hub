-- Trigger Monitor Module — versão final corrigida
-- Fixes: fmtCache leak, folderCache stale ref, destroy() incompleto,
--        score logic, buffer dinâmico, Heartbeat → task.spawn

local TriggerMonitor = {}
TriggerMonitor.__index = TriggerMonitor

-- ─── Serviços ─────────────────────────────────────────────────────────────────

local RunService = game:GetService("RunService")

-- ─── Locais de globais (hot path) ─────────────────────────────────────────────

local osTime    = os.time
local osClock   = os.clock
local mathFloor = math.floor
local sfmt      = string.format
local tsort     = table.sort
local tconcat   = table.concat

-- ─── Configuração ─────────────────────────────────────────────────────────────

local TRIGGER_NAMES = {
    CryptOfKings = "CryptTrigger",
    LowerSunken  = "evileye1",
    DeepSunken   = "evileye2",
    CastleRock   = "BoundShrieker4",
    TempleOfFire = "MazeSnakes",
}

local PRIORITIES = {
    CastleRock   = 5,
    DeepSunken   = 4,
    TempleOfFire = 3,
    LowerSunken  = 2,
    CryptOfKings = 1,
}

local FOLDER_PATH           = { "Workspace", "MonsterSpawns", "Triggers" }
local LABEL_UPDATE_INTERVAL = 2.0   -- segundos (osClock)
-- FIX: tamanho máximo do cache de formatação antes de flush completo
local FMT_CACHE_MAX         = 120   -- ~2 min de deltas únicos

-- ─── Display names pré-computados ─────────────────────────────────────────────

local DISPLAY_NAMES = {}
for name in pairs(TRIGGER_NAMES) do
    DISPLAY_NAMES[name] = name:gsub("([A-Z])", " %1"):gsub("^ ", "")
end

local TRIGGER_COUNT = 0
for _ in pairs(TRIGGER_NAMES) do TRIGGER_COUNT = TRIGGER_COUNT + 1 end

-- ─── Comparator estático (não aloca closure por sort) ─────────────────────────

local function sortDesc(a, b)
    return a.score > b.score
end

-- ─── Formatação de delta ───────────────────────────────────────────────────────
-- FIX: cache por delta (não por ts absoluto) com limite de tamanho
-- Sem risco de crescimento ilimitado em sessões longas

local fmtCache     = {}
local fmtCacheSize = 0

local function formatDelta(delta)
    local cached = fmtCache[delta]
    if cached then return cached end

    -- FIX: flush por tamanho — garante teto de memória independente do tempo
    if fmtCacheSize >= FMT_CACHE_MAX then
        fmtCache     = {}
        fmtCacheSize = 0
    end

    local result
    if delta < 2 then
        result = "Agora"
    elseif delta < 60 then
        result = sfmt("%ds atrás", delta)
    elseif delta < 3600 then
        result = sfmt("%dm %ds atrás", mathFloor(delta / 60), delta % 60)
    else
        result = sfmt("%dh %dm atrás", mathFloor(delta / 3600), mathFloor((delta % 3600) / 60))
    end

    fmtCache[delta] = result
    fmtCacheSize    = fmtCacheSize + 1
    return result
end

-- ─── Folder lookup com invalidação segura ─────────────────────────────────────
-- FIX: limpa entrada stale antes de refazer lookup (evita reter objetos destruídos)

local folderCache = {}

local function getFolderByPath(pathArray)
    local key    = tconcat(pathArray, ".")
    local cached = folderCache[key]

    if cached then
        -- FIX: IsDescendantOf(game) valida que o objeto ainda está na hierarquia
        if cached.Parent ~= nil and cached:IsDescendantOf(game) then
            return cached
        end
        -- Objeto destruído/re-parentado: remove referência explicitamente
        folderCache[key] = nil
    end

    local obj = game
    for _, name in ipairs(pathArray) do
        obj = obj:FindFirstChild(name)
        if not obj then return nil end
    end

    folderCache[key] = obj
    return obj
end

-- ─── TriggerMonitor ───────────────────────────────────────────────────────────

function TriggerMonitor.new(connectionManager)
    local self = setmetatable({}, TriggerMonitor)

    self.connMgr       = connectionManager
    self.triggersLabel = nil
    self.isConnected   = false

    self.triggerTimestamps = {}
    for name in pairs(TRIGGER_NAMES) do
        self.triggerTimestamps[name] = 0
    end

    self._lastLabelUpdate = 0
    self._cachedText      = ""

    -- Buffer de tamanho dinâmico correto (não hardcoded em 5)
    self._sortBuffer = {}
    for i = 1, TRIGGER_COUNT do
        self._sortBuffer[i] = { name = "", displayName = "", ts = 0, score = 0 }
    end

    self._periodicRunning = false
    self._periodicThread  = nil

    return self
end

-- ─── Construção do texto ──────────────────────────────────────────────────────

function TriggerMonitor:_buildLabelText()
    local now    = osTime()
    local buffer = self._sortBuffer
    local idx    = 0

    for name in pairs(TRIGGER_NAMES) do
        idx = idx + 1
        local ts           = self.triggerTimestamps[name] or 0
        local priority     = PRIORITIES[name] or 0
        -- FIX: score unificado — prioridade domina, tempo sem spawn desempata
        -- Quanto maior o score, mais urgente o trigger
        local unspawnedFor = ts > 0 and (now - ts) or 999999
        local score        = priority * 10000 + unspawnedFor

        local entry = buffer[idx]
        entry.name        = name
        entry.displayName = DISPLAY_NAMES[name]
        entry.ts          = ts
        entry.score       = score
    end

    tsort(buffer, sortDesc)

    local bestName = buffer[1].name
    local lines    = {
        "Triggers (Melhor = Mais Profundo & Sem Spawn Há Mais Tempo):",
        "",
    }

    for i = 1, TRIGGER_COUNT do
        local entry   = buffer[i]
        local delta   = entry.ts > 0 and (now - entry.ts) or nil
        local timeStr = delta and formatDelta(delta) or "Nunca"
        local star    = entry.name == bestName and " ⭐" or ""
        lines[i + 2]  = sfmt("• %-18s %s%s", entry.displayName, timeStr, star)
    end

    return tconcat(lines, "\n")
end

-- ─── Update throttled ─────────────────────────────────────────────────────────

function TriggerMonitor:_updateLabel(force)
    if not self.triggersLabel then return end

    local now = osClock()
    if not force and (now - self._lastLabelUpdate) < LABEL_UPDATE_INTERVAL then
        return
    end
    self._lastLabelUpdate = now

    local text = self:_buildLabelText()
    if text ~= self._cachedText then
        self._cachedText = text
        self.triggersLabel:SetText(text)
    end
end

-- ─── Listeners ────────────────────────────────────────────────────────────────

function TriggerMonitor:connectTriggerListeners()
    if self.isConnected then return end

    local folder = getFolderByPath(FOLDER_PATH)
    if not folder then
        warn("[TriggerMonitor] Pasta não encontrada: " .. tconcat(FOLDER_PATH, "/"))
        return
    end

    for labelName, partName in pairs(TRIGGER_NAMES) do
        local part = folder:FindFirstChild(partName)
        if part then
            local lastSpawned = part:FindFirstChild("LastSpawned")
            if lastSpawned then
                -- Upvalues locais evitam lookup de self a cada disparo
                local timestamps = self.triggerTimestamps
                local monitor    = self

                self.connMgr:add(
                    lastSpawned:GetPropertyChangedSignal("Value"):Connect(function()
                        timestamps[labelName] = lastSpawned.Value
                        monitor:_updateLabel(true)
                    end)
                )

                if lastSpawned.Value > 0 then
                    self.triggerTimestamps[labelName] = lastSpawned.Value
                end
            end
        end
    end

    self.isConnected = true
    self:_updateLabel(true)
end

-- ─── Update periódico (task.spawn, não Heartbeat) ─────────────────────────────

function TriggerMonitor:startPeriodicUpdate()
    if self._periodicRunning then return end
    self._periodicRunning = true

    self._periodicThread = task.spawn(function()
        while self._periodicRunning do
            task.wait(LABEL_UPDATE_INTERVAL)
            if self._periodicRunning then
                self:_updateLabel(false)
            end
        end
    end)
end

function TriggerMonitor:stopPeriodicUpdate()
    self._periodicRunning = false
    self._periodicThread  = nil
end

-- ─── API pública ──────────────────────────────────────────────────────────────

function TriggerMonitor:setLabel(label)
    self.triggersLabel = label
    if label then self:_updateLabel(true) end
end

function TriggerMonitor:setEnabled(enabled)
    if enabled then
        self:startPeriodicUpdate()
    else
        self:stopPeriodicUpdate()
    end
end

function TriggerMonitor:updateTriggerTimestamp(name)
    if self.triggerTimestamps[name] ~= nil then
        self.triggerTimestamps[name] = osTime()
        self:_updateLabel(true)
    end
end

function TriggerMonitor:getTriggerTimestamps()
    return self.triggerTimestamps
end

function TriggerMonitor:getConfig()
    return TRIGGER_NAMES, PRIORITIES
end

-- ─── Destroy ──────────────────────────────────────────────────────────────────
-- FIX: connMgr:disconnectAll() garante que nenhuma conexão retém self no GC

function TriggerMonitor:destroy()
    self:stopPeriodicUpdate()

    -- Desconecta e libera todas as RBXScriptConnections registradas
    if self.connMgr then
        self.connMgr:disconnectAll()
    end

    self.triggersLabel = nil
    self.isConnected   = false
    self._cachedText   = ""
    self._sortBuffer   = nil
    self.connMgr       = nil

    -- Limpa caches de módulo para liberar memória
    fmtCache     = {}
    fmtCacheSize = 0
    folderCache  = {}
end

return TriggerMonitor
