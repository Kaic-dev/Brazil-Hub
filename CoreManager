local function safeRequireRemote(url, name)
    local ok, raw = pcall(game.HttpGet, game, url)
    if not ok then
        warn("[BrazilHub] Download falhou:", name, raw)
        return nil
    end
    local fn, err = loadstring(raw)
    if not fn then
        warn("[BrazilHub] Compilação falhou:", name, err)
        return nil
    end
    local ok2, mod = pcall(fn)
    if not ok2 then
        warn("[BrazilHub] Execução falhou:", name, mod)
        return nil
    end
    return mod
end

-- ─── Drawing proxy ────────────────────────────────────────────────────────────

if Drawing and Drawing.new then
    local oldDrawingNew = Drawing.new
    Drawing.new = function(class)
        local realObj = oldDrawingNew(class)
        local proxy   = newproxy(true)
        local mt      = getmetatable(proxy)
        mt.__index = function(_, k)
            local val = realObj[k]
            if type(val) == "function" then
                return function(_, ...) return val(realObj, ...) end
            end
            return val
        end
        mt.__newindex = function(_, k, v)
            if k == "Visible" then
                if not pcall(function() realObj.Visible = v end) then
                    pcall(function() realObj.Visible = v == true and 1 or 0 end)
                end
            else
                realObj[k] = v
            end
        end
        return proxy
    end
end

