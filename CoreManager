                for name, state in pairs(selected) do
                    if state then
                        clean[#clean+1] = name
                            :gsub(" %[Equipped%]$", "")
                            :gsub(" %[Backpack%]$", "")
                    end
                end
                UICallbacks.onAutoAimToolsChanged(clean)
            end)
    end)

    autoAimGroup:AddLabel("FOV Circle Color"):AddColorPicker("FOVCircleColor", {
        Default  = CONFIG.FOV_CIRCLE.DEFAULT_COLOR,
        Callback = function(color)
            if fovManager then fovManager:setColor(color) end
        end,
    })
    autoAimGroup:AddToggle("ShowFOVCircle", {
        Text     = "Show FOV Circle",
        Default  = false,
        Callback = function(v)
            if fovManager then fovManager:setVisible(v) end
        end,
    })

    if ModuleInstances.autoAim then
        ModuleInstances.autoAim:setRange(CONFIG.AUTO_AIM.DEFAULT_RANGE)
        ModuleInstances.autoAim:setTimeToHit(CONFIG.AUTO_AIM.DEFAULT_TIME_TO_HIT)
