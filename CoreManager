local function createMiscTab(miscTab)

    -- ── Fly ───────────────────────────────────────────────────────────────────
    local flyGroup = miscTab:AddLeftGroupbox("Fly")

    local flyToggle = flyGroup:AddToggle("FlyToggle", {
        Text     = "Fly",
        Default  = false,
        Callback = UICallbacks.onToggleFly,
    })

    flyToggle:ConfigPanel(function(panel)
        panel:AddSection("Velocidade")
        panel:AddLabel("WASD = direção  |  Space = subir  |  LShift = descer")
        panel:AddSlider("Speed", CONFIG.FLY.MIN_SPEED, CONFIG.FLY.MAX_SPEED,
            CONFIG.FLY.DEFAULT_SPEED, 0,
            UICallbacks.onFlySpeedChanged)
    end)

    -- ── Triggers ──────────────────────────────────────────────────────────────
    local triggersGroup = miscTab:AddLeftGroupbox("Triggers")

    if triggerMonitor then
        if not triggerMonitor.getTriggersLabelText then
            triggerMonitor.getTriggersLabelText = triggerMonitor._buildLabelText
        end

        local triggersLabel = triggersGroup:AddLabel(triggerMonitor:getTriggersLabelText(), true)
        triggerMonitor:setLabel(triggersLabel)
        triggerMonitor:connectTriggerListeners()

        triggersGroup:AddToggle("EnableTriggerMonitor", {
            Text     = "Enable Trigger Monitor",
            Default  = true,
            Callback = function(enabled) triggerMonitor:setEnabled(enabled) end,
        })
        triggerMonitor:setEnabled(true)
    else
        triggersGroup:AddLabel("Trigger Monitor not available", true)
    end

    -- ── Connections Info ──────────────────────────────────────────────────────
    local connGroup = miscTab:AddRightGroupbox("Connections")

    local labels = {
        ff      = connGroup:AddLabel("FFDetector: ..."),
        esp     = connGroup:AddLabel("PlayerESP: ..."),
        trinket = connGroup:AddLabel("TrinketESP: ..."),
        lb      = connGroup:AddLabel("BetterLB: ..."),
        nofog   = connGroup:AddLabel("NoFog: ..."),
        intent  = connGroup:AddLabel("Intent: ..."),
        fly     = connGroup:AddLabel("Fly: ..."),
        script  = connGroup:AddLabel("Script: ..."),
        perf    = connGroup:AddLabel("Performance: disabled"),
    }
    local detailsLabel = connGroup:AddLabel("Clique numa conexão p/ detalhes", true)

    -- ── Performance Monitor ───────────────────────────────────────────────────
    if PerformanceMonitor then
        local perfMonitor           = PerformanceMonitor.new()
        local memoryKickEnabled     = false
        local memoryThreshold       = 3000
        local memoryTriggered       = false
        local memoryAccumulatedTime = 0
        local memoryHoldTime        = 2.0

        perfMonitor:setLabel(labels.perf)

        connGroup:AddToggle("EnablePerformanceMonitor", {
            Text     = "Performance Monitor",
            Default  = false,
            Callback = function(enabled)
                if enabled then
                    perfMonitor:start()
                else
                    perfMonitor:stop()
                    labels.perf:SetText("Performance: disabled")
                    memoryTriggered       = false
                    memoryAccumulatedTime = 0
                end
            end,
        })
        connGroup:AddToggle("EnableMemoryAutoKick", {
            Text     = "Kick on high memory",
            Default  = false,
            Callback = function(enabled)
                memoryKickEnabled     = enabled
                memoryTriggered       = false
                memoryAccumulatedTime = 0
            end,
        })
        connGroup:AddSlider("PerformanceMemoryKickThreshold", {
            Text    = "Memory kick threshold (MB)",
            Min = 500, Max = 8000, Default = memoryThreshold, Rounding = 0,
            Callback = function(v) memoryThreshold = v end,
        })

        if connMgr then
            connMgr:add(RunService.Heartbeat:Connect(function(dt)
                if not memoryKickEnabled or not perfMonitor.isEnabled then return end
                local mem = perfMonitor:getMemoryUsage()
                if mem > 0 and mem >= memoryThreshold then
                    memoryAccumulatedTime = memoryAccumulatedTime + (dt or 0)
                else
                    memoryAccumulatedTime = 0
                    memoryTriggered       = false
                end
                if memoryAccumulatedTime >= memoryHoldTime and not memoryTriggered then
                    memoryTriggered = true
                    detailsLabel:SetText(string.format(
                        "Memória alta: %.1f MB ≥ %d MB. Kick ativado.", mem, memoryThreshold
                    ))
                    local lp = Players.LocalPlayer
                    if lp and lp.Parent then
                        lp:Kick("Brazil Hub: High memory (" .. string.format("%.1f MB", mem) .. ")")
                    end
                end
            end), "memoryKick.Heartbeat")
        end
    end

    -- ── Connection label updater ──────────────────────────────────────────────
    local lastConnUpdate       = 0
    local CONN_UPDATE_INTERVAL = 2.0

    if connMgr then
        connMgr:add(RunService.Heartbeat:Connect(function()
            local now = os.clock()
            if now - lastConnUpdate < CONN_UPDATE_INTERVAL then return end
            lastConnUpdate = now

            local function count(inst, key)
                return inst and inst[key] and inst[key].count and inst[key]:count() or 0
            end
            pcall(function() labels.ff:SetText(     "FFDetector: "  .. count(ModuleInstances.ffDetector,        "_connMgr")) end)
            pcall(function() labels.esp:SetText(    "PlayerESP: "   .. count(ModuleInstances.playerEsp,         "_connMgr")) end)
            pcall(function() labels.trinket:SetText("TrinketESP: "  .. count(ModuleInstances.trinketEsp,        "_connectionManager")) end)
            pcall(function() labels.lb:SetText(     "BetterLB: "    .. count(ModuleInstances.betterLeaderboard, "_connMgr")) end)
            pcall(function() labels.nofog:SetText(  "NoFog: "       .. count(NoFog,                             "_connMgr")) end)
            pcall(function() labels.intent:SetText( "Intent: "      .. count(Intent,                            "connectionMgr")) end)
            pcall(function() labels.fly:SetText(    "Fly: "         .. count(ModuleInstances.fly,               "_connMgr")) end)
            pcall(function() labels.script:SetText( "Script: "      .. (connMgr and connMgr:count() or 0)) end)
        end), "connLabels.Heartbeat")
    end

    -- ── Click para detalhes ───────────────────────────────────────────────────
    local function getConnInfo(name, manager)
        if not manager then
            return name .. ": não carregado ou sem ConnectionManager"
        end
        if manager.getDetails then
            local details = manager:getDetails()
            if #details == 0 then return name .. ": nenhuma conexão" end
            local lines = { name .. " (" .. #details .. "):" }
            for i, d in ipairs(details) do
                lines[#lines+1] = i .. ". " .. d.name .. " [" .. (d.connected and "ativa" or "inativa") .. "]"
            end
            return table.concat(lines, "\n")
        end
        return name .. ": " .. (manager.count and manager:count() or 0) .. " conexão(ões)"
    end

    local function attachClick(label, name, manager)
        if label and label.OnClick then
            label:OnClick(function()
                detailsLabel:SetText(getConnInfo(name, manager))
            end)
        end
    end

    attachClick(labels.ff,      "FFDetector", ModuleInstances.ffDetector        and ModuleInstances.ffDetector._connMgr)
    attachClick(labels.esp,     "PlayerESP",  ModuleInstances.playerEsp         and ModuleInstances.playerEsp._connMgr)
    attachClick(labels.trinket, "TrinketESP", ModuleInstances.trinketEsp        and ModuleInstances.trinketEsp._connectionManager)
    attachClick(labels.lb,      "BetterLB",   ModuleInstances.betterLeaderboard and ModuleInstances.betterLeaderboard._connMgr)
    attachClick(labels.nofog,   "NoFog",      NoFog   and NoFog._connMgr)
    attachClick(labels.intent,  "Intent",     Intent  and Intent.connectionMgr)
    attachClick(labels.fly,     "Fly",        ModuleInstances.fly               and ModuleInstances.fly._connMgr)
    attachClick(labels.script,  "Script",     connMgr)
end

