    local tabs = {
        Combat     = window:AddTab("Combat"),
        Visuals    = window:AddTab("Visuals"),
        Misc       = window:AddTab("Misc"),
        UISettings = window:AddTab("UI Settings"),
    }

    local fovManager = FOVCircleManager and FOVCircleManager.new() or nil
    if fovManager then
        fovManager:setUpdateCallback(function()
            fovManager:updateCircle(ModuleInstances.autoAim, connMgr)
        end)
    end

    createCombatTab(tabs.Combat, fovManager)
    createVisualsTab(tabs.Visuals)
    createMiscTab(tabs.Misc)
    createUISettingsTab(tabs.UISettings, window)
    setupManagers(tabs.UISettings, window, fovManager)

    loadingScreen:finish()
end

local ok, err = pcall(main)
if not ok then
    warn("[BrazilHub] Erro fatal no main:", tostring(err))
    getgenv().BrazilHubLoaded = false
end

