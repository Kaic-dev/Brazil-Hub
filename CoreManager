        Text     = "Player ESP",
        Default  = true,
        Callback = UICallbacks.onTogglePlayerESP,
    })
    if espToggle.Value then UICallbacks.onTogglePlayerESP(true) end

    if ModuleInstances.playerEsp and ModuleInstances.playerEsp.displayConfig then
        for configKey, defaultValue in pairs(ModuleInstances.playerEsp.displayConfig) do
            local labelText  = configKey:gsub("show",""):gsub("^%l", string.upper)
            local toggleName = configKey:gsub("show","Show")
            espGroup:AddToggle(toggleName, {
                Text     = labelText,
                Default  = defaultValue,
                Callback = function(val)
                    ModuleInstances.playerEsp.displayConfig[configKey] = val
                    if ModuleInstances.playerEsp.setDisplayConfig then
                        ModuleInstances.playerEsp:setDisplayConfig()
                    end
                end,
            })
        end
    end
    espGroup:AddSlider("PlayerESPTextSize", {
        Text = "Text Size", Default = CONFIG.PLAYER_ESP.DEFAULT_TEXT_SIZE,
        Min = 7, Max = 40, Rounding = 0, Callback = UICallbacks.onPlayerESPTextSizeChanged,
    })
    espGroup:AddLabel("Text Color"):AddColorPicker("PlayerESPTextColor", {
        Default  = CONFIG.PLAYER_ESP.DEFAULT_TEXT_COLOR,
        Title    = "Player ESP Text Color",
        Callback = UICallbacks.onPlayerESPTextColorChanged,
    })
    ModuleInstances.playerEsp:setTextSize(CONFIG.PLAYER_ESP.DEFAULT_TEXT_SIZE)
    ModuleInstances.playerEsp:setTextColor(CONFIG.PLAYER_ESP.DEFAULT_TEXT_COLOR)

    local indicatorsGroup = visualsTab:AddLeftGroupbox("Indicators")
    local Indicator = safeRequireRemote(BRAZIL_HUB_BASE_URL .. "Indicator", "Indicator")
    local indicator = Indicator and Indicator.new and Indicator.new() or nil

    if indicator then
        indicator.showDamage = true
        indicator.showHeal   = false
        indicator:enable()

        indicatorsGroup:AddToggle("EnableDamageIndicators", {
            Text    = "Damage Indicators", Default = true,
