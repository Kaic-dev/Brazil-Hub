local function safeWriteFile(path, content)
    local ok, err = pcall(function()
        if writefile then
            local parts   = string.split(path, "/")
            local current = ""
            for i = 1, #parts - 1 do
                current = current == "" and parts[i] or (current .. "/" .. parts[i])
                if makefolder and isfolder and not isfolder(current) then
                    makefolder(current)
                end
            end
            writefile(path, content)
        end
    end)
    return ok, err
end

local function safeReadFile(path)
    if readfile then
        local ok, content = pcall(readfile, path)
        if ok then return content end
    end
    return nil
end

local function safeIsFile(path)
    if isfile then
        local ok, exists = pcall(isfile, path)
        return ok and exists
    end
    return false
end

local SaveManager = {
    Library       = nil,
    Folder        = "BrazilHub/Rogue-Lineage",
    IgnoreIndexes = {},
    AutoloadFile  = "BrazilHub/Rogue-Lineage/autoload.txt",
}

function SaveManager:SetLibrary(lib) self.Library = lib end
function SaveManager:IgnoreThemeSettings() end
function SaveManager:SetIgnoreIndexes(list)
    self.IgnoreIndexes = {}
    for _, idx in ipairs(list) do self.IgnoreIndexes[idx] = true end
end
function SaveManager:SetFolder(folder)
    self.Folder       = folder
    self.AutoloadFile = folder .. "/autoload.txt"
end

function SaveManager:Save(name)
    if not name or name == "" then return false end
    local HttpService = game:GetService("HttpService")
    local data = { Toggles = { __empty = true }, Options = { __empty = true } }

    for id, toggle in pairs(Library.Toggles or {}) do
        if not self.IgnoreIndexes[id] then
            local val = toggle.Value
            if val ~= nil then data.Toggles[id] = val end
        end
    end
    for id, slider in pairs(Library.Sliders or {}) do
        if not self.IgnoreIndexes[id] then
            local val = slider.Value
            if type(val) == "number" then
                data.Options[id] = { Type = "Value", Value = val }
            end
        end
    end
    for id, dropdown in pairs(Library.Dropdowns or {}) do
        if not self.IgnoreIndexes[id] then
            local val = dropdown.Value
            if type(val) == "table" then
                data.Options[id] = { Type = "Dropdown", Multi = true,  Value = val }
            elseif type(val) == "string" then
                data.Options[id] = { Type = "Dropdown", Multi = false, Value = val }
            end
        end
    end
    for id, option in pairs(getgenv().Options or {}) do
        if not self.IgnoreIndexes[id] then
            local val = option.Value
            if typeof(val) == "EnumItem" then
                data.Options[id] = { Type = "Keybind", EnumType = tostring(val.EnumType), Value = val.Name }
            elseif typeof(val) == "Color3" then
                data.Options[id] = { Type = "Color", Value = { val.R, val.G, val.B } }
            end
        end
    end

    local encoded = HttpService:JSONEncode(data)
    encoded = encoded:gsub(',"__empty":true', ''):gsub('"__empty":true,', ''):gsub('"__empty":true', '')
    local ok, err = safeWriteFile(self.Folder .. "/configs/" .. name .. ".json", encoded)
    if not ok then warn("[SaveManager] Erro ao salvar:", tostring(err)) end
    return ok
end

function SaveManager:Load(name)
    if not name or name == "" then return false end
    local filePath = self.Folder .. "/configs/" .. name .. ".json"
    if not safeIsFile(filePath) then return false end
    local content = safeReadFile(filePath)
    if not content then return false end
    local HttpService = game:GetService("HttpService")
    local ok, data = pcall(HttpService.JSONDecode, HttpService, content)
    if not ok or type(data) ~= "table" then return false end

    if data.Toggles then
        for id, state in pairs(data.Toggles) do
            if id == "__empty" then continue end
            local t = Library.Toggles and Library.Toggles[id]
            if t and not self.IgnoreIndexes[id] then
                pcall(function() t:SetValue(state) end)
            end
        end
    end
    if data.Options then
        for id, optData in pairs(data.Options) do
            if id == "__empty" then continue end
            if not self.IgnoreIndexes[id] then
                pcall(function()
                    if type(optData) ~= "table" or not optData.Type then return end
                    if optData.Type == "Value" then
                        local s = Library.Sliders and Library.Sliders[id]
                        if s then s:SetValue(optData.Value) end
                    elseif optData.Type == "Dropdown" then
                        local d = Library.Dropdowns and Library.Dropdowns[id]
                        if d then d:SetValue(optData.Value) end
                    elseif optData.Type == "Color" then
                        local opt = getgenv().Options[id]
                        if opt then
                            local r = optData.Value
                            opt:SetValue(Color3.new(r[1], r[2], r[3]))
                        end
                    elseif optData.Type == "Keybind" then
                        local opt = getgenv().Options[id]
                        if opt then
                            local shortType = (optData.EnumType or ""):match("Enum%.(.+)") or "KeyCode"
                            local enumItem
                            local ok2, result = pcall(function() return Enum[shortType][optData.Value] end)
                            if ok2 then enumItem = result end
                            if not enumItem then
                                local ok3, result2 = pcall(function() return Enum.KeyCode[optData.Value] end)
                                if ok3 then enumItem = result2 end
                            end
                            if enumItem then opt:SetValue(enumItem) end
                        end
                    end
                end)
            end
        end
    end
    return true
end

function SaveManager:LoadAutoloadConfig()
    if safeIsFile(self.AutoloadFile) then
        local name = safeReadFile(self.AutoloadFile)
        if name and name ~= "" then self:Load(name) end
    end
end

function SaveManager:BuildConfigSection(tab)
    local configGroup  = tab:AddRightGroupbox("Configurations")
    local slots        = { "Slot 1", "Slot 2", "Slot 3", "Slot 4", "Slot 5" }
    local selectedSlot = "Slot 1"
    local autoloadOn   = false

    local function persistAutoload()
        safeWriteFile(self.AutoloadFile, autoloadOn and selectedSlot or "")
    end

    configGroup:AddDropdown("SelectedConfigSlot", {
        Values   = slots,
        Default  = "Slot 1",
        Text     = "Select Config Slot",
        Callback = function(val)
            selectedSlot = val
            if autoloadOn then persistAutoload() end
        end,
    })
    configGroup:AddButton("Save Config",  function()
        print("[SaveManager] Tentando salvar slot:", selectedSlot)
        local ok = self:Save(selectedSlot)
        print("[SaveManager] Save retornou:", ok)
    end)
    configGroup:AddButton("Load Config",  function() self:Load(selectedSlot) end)
    configGroup:AddToggle("AutoloadConfig", {
        Text     = "Autoload Selected Slot",
        Default  = false,
        Callback = function(state)
            autoloadOn = state
            persistAutoload()
        end,
    })

    task.spawn(function()
        if safeIsFile(self.AutoloadFile) then
            local cur = safeReadFile(self.AutoloadFile)
            if cur and cur ~= "" then
                autoloadOn = true
                local t = getgenv().Toggles["AutoloadConfig"]
                if t then t:SetValue(true) end
            end
        end
    end)
end

