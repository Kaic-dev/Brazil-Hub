    barGlow.Position               = UDim2.new(1, 0, 0.5, 0)
    barGlow.AnchorPoint            = Vector2.new(1, 0.5)
    barGlow.BackgroundColor3       = Color3.fromRGB(205, 170, 105)
    barGlow.BackgroundTransparency = 0.5
    barGlow.BorderSizePixel        = 0
    barGlow.Parent                 = barFill

    local status  = makeLabel("Status",  "Initializing...", 94,  14, Color3.fromRGB(130, 130, 132), 0.5)
    local counter = makeLabel("Counter", "",                114,  12, Color3.fromRGB(80, 80, 82),    0.6)
    makeLine(134)

    local screen = {
        gui         = gui,
        overlay     = overlay,
        barFill     = barFill,
        status      = status,
        counter     = counter,
        currentStep = 0,
        totalSteps  = 1,
    }

    function screen:setTotalSteps(n) self.totalSteps = n end
    function screen:setStatus(text)  self.status.Text = text end

    function screen:step(moduleName)
        self.currentStep  = self.currentStep + 1
        local pct         = math.clamp(self.currentStep / self.totalSteps, 0, 1)
        self.status.Text  = "Loading " .. moduleName .. "..."
        self.counter.Text = self.currentStep .. " / " .. self.totalSteps
        TweenService:Create(self.barFill,
            TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Size = UDim2.new(pct, 0, 1, 0) }
        ):Play()
    end

    function screen:finish()
        self.status.Text  = "Ready"
        self.counter.Text = self.totalSteps .. " / " .. self.totalSteps
        TweenService:Create(self.barFill,
            TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(205, 170, 105) }
        ):Play()
        task.wait(0.6)
        TweenService:Create(self.overlay,
            TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In),
            { BackgroundTransparency = 1 }
        ):Play()
        for _, desc in ipairs(self.gui:GetDescendants()) do
            if desc:IsA("TextLabel") then
                TweenService:Create(desc, TweenInfo.new(0.4, Enum.EasingStyle.Quart), { TextTransparency = 1 }):Play()
            elseif desc:IsA("Frame") then
                TweenService:Create(desc, TweenInfo.new(0.4, Enum.EasingStyle.Quart), { BackgroundTransparency = 1 }):Play()
            elseif desc:IsA("ImageLabel") then
                TweenService:Create(desc, TweenInfo.new(0.4, Enum.EasingStyle.Quart), { ImageTransparency = 1 }):Play()
            end
        end
        task.wait(0.6)
        self.gui:Destroy()
    end

    return screen
end

