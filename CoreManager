            CONFIG.AUTO_AIM.DEFAULT_STUDS_BEHIND.min,
            CONFIG.AUTO_AIM.DEFAULT_STUDS_BEHIND.max
        )
    end

    -- ── Auto Block ────────────────────────────────────────────────────────────
    local autoBlockGroup = combatTab:AddRightGroupbox("Auto Block")

    local abToggle = autoBlockGroup:AddToggle("AutoBlockGrapple", {
        Text     = "Auto Block",
        Default  = false,
        Callback = UICallbacks.onToggleAutoBlock,
    })

    if ModuleInstances.autoBlock then
        local allThreats     = ModuleInstances.autoBlock:getAllThreats()
        local skillOptions   = {}
        local attackOptions  = {}
        local threatIdByName = {}

        for threatId, cfg in pairs(allThreats) do
            threatIdByName[cfg.name] = threatId
            if cfg.category == "skills" then
                skillOptions[#skillOptions+1] = cfg.name
            elseif cfg.category == "attack_type" then
                attackOptions[#attackOptions+1] = cfg.name
            end
        end

        local function applyThreatDropdown(options, selected)
            print("[AutoBlock Config] Atualizando ameaças...")
            for _, name in ipairs(options) do
                local id = threatIdByName[name]
                if selected[name] then
                    local ok = ModuleInstances.autoBlock:addThreat(id, allThreats[id])
                    print("[AutoBlock Config] Adicionado:", name, "ID:", id, "Status:", ok)
                else
                    local ok = ModuleInstances.autoBlock:removeThreat(id)
                    print("[AutoBlock Config] Removido:", name, "ID:", id, "Status:", ok)
                end
            end
        end

        abToggle:ConfigPanel(function(panel)
            panel:AddSection("Skills")
            panel:AddDropdown("Skills", skillOptions, true, skillOptions,
                function(sel) applyThreatDropdown(skillOptions, sel) end)

            panel:AddSection("Attack Types")
            panel:AddDropdown("Attack Types", attackOptions, true, attackOptions,
                function(sel) applyThreatDropdown(attackOptions, sel) end)

            panel:AddSection("Block Distance")
            for threatId, cfg in pairs(allThreats) do
                panel:AddSlider(cfg.name, 5, 300, cfg.blockDistance or 50, 0,
                    function(v)
                        ModuleInstances.autoBlock:setThreatBlockDistance(threatId, v)
                    end)
            end
        end)
    end
end

