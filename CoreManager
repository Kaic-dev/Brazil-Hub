                    if not indicator._enabled then indicator:enable() end
                else
                    indicator:disable()
                end
            end,
        })
        indicatorsGroup:AddToggle("EnableRegenIndicators", {
            Text    = "Regen Indicators", Default = false,
            Callback = function(v)
                indicator.showHeal = v
                if v or indicator.showDamage then
                    if not indicator._enabled then indicator:enable() end
                else
                    indicator:disable()
                end
            end,
        })
    else
        indicatorsGroup:AddLabel("Indicators not available")
    end

    local ffGroup = visualsTab:AddRightGroupbox("FF Detector")
    local ffToggle = ffGroup:AddToggle("FFDetectorToggle", {
        Text    = "FF Detector", Default = true,
        Callback = UICallbacks.onToggleFFDetector,
    })
    if ffToggle.Value then UICallbacks.onToggleFFDetector(true) end
    ffGroup:AddSlider("BillboardMaxDist", {
        Text = "Billboard Max Dist", Default = CONFIG.FF_DETECTOR.DEFAULT_BILLBOARD_DISTANCE,
        Min = 10, Max = 300, Rounding = 0, Callback = UICallbacks.onBillboardDistanceChanged,
    })
    ffGroup:AddSlider("BillboardTextSize", {
        Text = "Billboard Text Size", Default = CONFIG.FF_DETECTOR.DEFAULT_BILLBOARD_TEXT_SIZE,
        Min = 7, Max = 40, Rounding = 0, Callback = UICallbacks.onBillboardTextSizeChanged,
    })

    local otherGroup = visualsTab:AddRightGroupbox("Other")
    otherGroup:AddToggle("TrinketESP",        { Text = "Trinket ESP",        Default = false, Callback = UICallbacks.onToggleTrinketESP })
    otherGroup:AddToggle("IntentBillboard",   { Text = "Intent Billboard",   Default = false, Callback = UICallbacks.onToggleIntentBillboard })
    otherGroup:AddToggle("BetterLeaderboard", { Text = "Better Leaderboard", Default = false, Callback = UICallbacks.onToggleBetterLeaderboard })
    otherGroup:AddToggle("NoFogToggle",       { Text = "No Fog",             Default = false, Callback = UICallbacks.onToggleNoFog })
