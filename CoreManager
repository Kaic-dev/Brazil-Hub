    autoAimGroup:AddToggle("ShowFOVCircle", {
        Text     = "Show FOV Circle",
        Default  = false,
        Callback = function(v)
            if fovManager then fovManager:setVisible(v) end
        end,
    })
    autoAimGroup:AddSlider("StudsBehindMin", {
        Text = "Studs Behind Min", Default = CONFIG.AUTO_AIM.DEFAULT_STUDS_BEHIND.min,
        Min = 5, Max = 50, Rounding = 0, Callback = UICallbacks.onStudsBehindMinChanged,
    })
    autoAimGroup:AddSlider("StudsBehindMax", {
        Text = "Studs Behind Max", Default = CONFIG.AUTO_AIM.DEFAULT_STUDS_BEHIND.max,
        Min = 5, Max = 50, Rounding = 0, Callback = UICallbacks.onStudsBehindMaxChanged,
    })
    autoAimGroup:AddDropdown("AutoAimTools", {
        Values   = CONFIG.AUTO_AIM.AVAILABLE_TOOLS,
        Default  = 1,
        Multi    = true,
        Text     = "Auto-Aim Tools",
        Callback = function(selected)
            local clean = {}
            for _, name in ipairs(selected) do
                clean[#clean+1] = name:gsub(" %[Equipped%]$",""):gsub(" %[Backpack%]$","")
            end
            UICallbacks.onAutoAimToolsChanged(clean)
        end,
    })

    ModuleInstances.autoAim:setRange(CONFIG.AUTO_AIM.DEFAULT_RANGE)
    ModuleInstances.autoAim:setTimeToHit(CONFIG.AUTO_AIM.DEFAULT_TIME_TO_HIT)
    ModuleInstances.autoAim:setStudsBehindRange(
        CONFIG.AUTO_AIM.DEFAULT_STUDS_BEHIND.min,
        CONFIG.AUTO_AIM.DEFAULT_STUDS_BEHIND.max
    )

    local autoBlockGroup = combatTab:AddRightGroupbox("Auto Block")
    autoBlockGroup:AddToggle("AutoBlockGrapple", {
        Text     = "Auto Block",
        Default  = false,
        Tooltip  = "Bloqueia automaticamente ataques selecionados",
        Callback = UICallbacks.onToggleAutoBlock,
    })

    local allThreats     = ModuleInstances.autoBlock:getAllThreats()
    local skillOptions   = {}
    local attackOptions  = {}
    local threatIdByName = {}

    for threatId, cfg in pairs(allThreats) do
        threatIdByName[cfg.name] = threatId
        if cfg.category == "skills" then
            skillOptions[#skillOptions+1] = cfg.name
        elseif cfg.category == "attack_type" then
            attackOptions[#attackOptions+1] = cfg.name
        end
    end

    local function applyThreatDropdown(options, selected)
        for _, name in ipairs(options) do
            local id = threatIdByName[name]
            if selected[name] then
                ModuleInstances.autoBlock:addThreat(id, allThreats[id])
            else
                ModuleInstances.autoBlock:removeThreat(id)
            end
        end
    end

    autoBlockGroup:AddDropdown("SkillsDropdown", {
        Values   = skillOptions, Default = skillOptions, Multi = true, Text = "Skills",
        Callback = function(sel) applyThreatDropdown(skillOptions, sel) end,
    })
    autoBlockGroup:AddDropdown("AttackTypesDropdown", {
        Values   = attackOptions, Default = attackOptions, Multi = true, Text = "Attack Types",
        Callback = function(sel) applyThreatDropdown(attackOptions, sel) end,
    })

    for threatId, cfg in pairs(allThreats) do
        local lbl = cfg.name .. " Block Dist"
        autoBlockGroup:AddSlider(lbl, {
            Text     = lbl,
            Default  = cfg.blockDistance or 50,
            Min = 5, Max = 300, Rounding = 0,
            Callback = function(v)
                ModuleInstances.autoBlock:setThreatBlockDistance(threatId, v)
            end,
        })
    end
end

