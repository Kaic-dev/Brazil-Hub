local function waitForLoaded()
    if not game:IsLoaded() then
        game.Loaded:Wait()
    end

    local LocalPlayer = Players.LocalPlayer
    local tries = 0
    while not LocalPlayer and tries < 10 do
        local conn
        local done = false
        conn = Players.PlayerAdded:Connect(function(p)
            LocalPlayer = p
            done = true
        end)
        local t0 = os.clock()
        while not done and (os.clock() - t0) < 2 do
            task.wait(0.1)
        end
        pcall(function() conn:Disconnect() end)
        if not LocalPlayer then
            LocalPlayer = Players.LocalPlayer
        end
        tries = tries + 1
    end

    if not LocalPlayer then
        warn("[waitForLoaded] LocalPlayer não encontrado após várias tentativas!")
        return nil, nil
    end

    local playerGui  = LocalPlayer:FindFirstChild("PlayerGui")
    local guiTries   = 0
    while not playerGui and guiTries < 10 do
        playerGui = LocalPlayer:FindFirstChild("PlayerGui")
            or LocalPlayer:WaitForChild("PlayerGui", 5)
        guiTries = guiTries + 1
    end
    if not playerGui then
        warn("[waitForLoaded] PlayerGui não encontrado após várias tentativas!")
    end
    return LocalPlayer, playerGui
end

