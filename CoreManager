local function safeNew(module, name, ...)
    if not (module and type(module.new) == "function") then
        warn("[BrazilHub] Módulo não carregado ou sem .new():", name)
        return nil
    end
    local ok, inst = pcall(module.new, module, ...)
    if not ok then
        warn("[BrazilHub] Erro ao instanciar:", name, inst)
        return nil
    end
    return inst
end

