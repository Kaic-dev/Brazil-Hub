-- FIX: Save — Keybind usa EnumType.Name para ser agnóstico ao tipo de Enum;
--             Dropdown detecta corretamente single (string) e multi (table)
function SaveManager:Save(name)
    if not name or name == "" then return false end
    local HttpService = game:GetService("HttpService")
    local data = { Toggles = {}, Options = {} }

    for id, toggle in pairs(getgenv().Toggles) do
        if not self.IgnoreIndexes[id] then
            data.Toggles[id] = toggle.Value
        end
    end

    for id, option in pairs(getgenv().Options) do
        if not self.IgnoreIndexes[id] then
            local val = option.Value

            if typeof(val) == "EnumItem" then
                -- Salva o EnumType junto para restaurar corretamente
                data.Options[id] = {
                    Type      = "Keybind",
                    EnumType  = tostring(val.EnumType),
                    Value     = val.Name,
                }
            elseif typeof(val) == "Color3" then
                data.Options[id] = {
                    Type  = "Color",
                    Value = { val.R, val.G, val.B },
                }
            elseif type(val) == "table" then
                -- Multi-dropdown: valor é tabela de strings selecionadas
                data.Options[id] = { Type = "Dropdown", Multi = true,  Value = val }
            elseif type(val) == "string" and option.Values then
                -- Single-dropdown: valor é string
                data.Options[id] = { Type = "Dropdown", Multi = false, Value = val }
            else
                data.Options[id] = { Type = "Value", Value = val }
            end
        end
    end

    local ok, err = safeWriteFile(
        self.Folder .. "/configs/" .. name .. ".json",
        HttpService:JSONEncode(data)
    )
    if not ok then warn("[SaveManager] Erro ao salvar:", tostring(err)) end
    return ok
end

-- FIX: Load — tratamento completo para Dropdown (single e multi) e Keybind robusto
function SaveManager:Load(name)
    if not name or name == "" then return false end
    local filePath = self.Folder .. "/configs/" .. name .. ".json"
    if not safeIsFile(filePath) then return false end
    local content = safeReadFile(filePath)
    if not content then return false end
    local HttpService = game:GetService("HttpService")
    local ok, data = pcall(HttpService.JSONDecode, HttpService, content)
    if not ok or type(data) ~= "table" then return false end

    if data.Toggles then
        for id, state in pairs(data.Toggles) do
            local t = getgenv().Toggles[id]
            if t and not self.IgnoreIndexes[id] then
                pcall(function() t:SetValue(state) end)
            end
        end
    end

    if data.Options then
        for id, optData in pairs(data.Options) do
            local opt = getgenv().Options[id]
            if opt and not self.IgnoreIndexes[id] then
                pcall(function()
                    if type(optData) == "table" and optData.Type then

                        if optData.Type == "Keybind" then
                            -- Tenta restaurar pelo EnumType salvo; fallback para KeyCode
                            local enumType = optData.EnumType
                            local enumItem = nil
                            if enumType then
                                -- Ex: "Enum.KeyCode" → tenta Enum.KeyCode[value]
                                local shortType = enumType:match("Enum%.(.+)") or enumType
                                local ok2, result = pcall(function()
                                    return Enum[shortType][optData.Value]
                                end)
                                if ok2 then enumItem = result end
                            end
                            -- Fallback seguro para KeyCode
                            if not enumItem then
                                local ok3, result = pcall(function()
                                    return Enum.KeyCode[optData.Value]
                                end)
                                if ok3 then enumItem = result end
                            end
                            if enumItem then opt:SetValue(enumItem) end

                        elseif optData.Type == "Color" then
                            local r = optData.Value
                            opt:SetValue(Color3.new(r[1], r[2], r[3]))

                        elseif optData.Type == "Dropdown" then
                            -- Tanto single (string) quanto multi (table) passam o .Value direto
                            opt:SetValue(optData.Value)

                        else
                            -- "Value" e qualquer tipo desconhecido
                            opt:SetValue(optData.Value)
                        end

                    else
                        -- Formato legado (valor direto sem wrapper)
                        opt:SetValue(optData)
                    end
                end)
            end
        end
    end

    return true
end

function SaveManager:LoadAutoloadConfig()
    if safeIsFile(self.AutoloadFile) then
        local name = safeReadFile(self.AutoloadFile)
        if name and name ~= "" then self:Load(name) end
    end
end

-- FIX: BuildConfigSection — autoload é atualizado sempre que slot OU toggle mudam,
--      garantindo que o arquivo reflita o slot correto no momento do save.
function SaveManager:BuildConfigSection(tab)
    local configGroup  = tab:AddRightGroupbox("Configurations")
    local slots        = { "Slot 1", "Slot 2", "Slot 3", "Slot 4", "Slot 5" }
    local selectedSlot = "Slot 1"
    local autoloadOn   = false

    local function persistAutoload()
        safeWriteFile(self.AutoloadFile, autoloadOn and selectedSlot or "")
    end

    configGroup:AddDropdown("SelectedConfigSlot", {
        Values   = slots,
        Default  = "Slot 1",
        Text     = "Select Config Slot",
        Callback = function(val)
            selectedSlot = val
            -- FIX: re-persiste se autoload estiver ativo com o novo slot
            if autoloadOn then persistAutoload() end
        end,
    })
    configGroup:AddButton("Save Config",  function() self:Save(selectedSlot) end)
    configGroup:AddButton("Load Config",  function() self:Load(selectedSlot) end)
    configGroup:AddToggle("AutoloadConfig", {
        Text     = "Autoload Selected Slot",
        Default  = false,
        Callback = function(state)
            autoloadOn = state
            persistAutoload()
        end,
    })

    task.spawn(function()
        if safeIsFile(self.AutoloadFile) then
            local cur = safeReadFile(self.AutoloadFile)
            if cur and cur ~= "" then
                autoloadOn = true
                local t = getgenv().Toggles["AutoloadConfig"]
                if t then t:SetValue(true) end
            end
        end
    end)
end

